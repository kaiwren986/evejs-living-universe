+}
+
+function ensureState(nowMs = Date.now()) {
+  const current = readState(nowMs);
+  const result = writeState(current, nowMs);
+  return result.success ? result.data : current;
+}
+
+function updateState(updater, nowMs = Date.now(), options = {}) {
