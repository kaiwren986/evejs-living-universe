+++ b/server/scripts/verifyLivingIndustryEconomy.js
@@ -0,0 +1,186 @@
+"use strict";
+
+const assert = require("assert/strict");
+
+const catalog = require("../src/space/npc/ambientTraffic/livingEconomyCatalog");
+const industry = require("../src/space/npc/ambientTraffic/livingEconomyIndustry");
+const procurement = require("../src/space/npc/ambientTraffic/livingEconomyProcurement");
+const stateStore = require("../src/space/npc/ambientTraffic/livingEconomyState");
+const telemetry = require("../src/space/npc/ambientTraffic/livingEconomyTelemetry");
+
+function key(stationID, typeID) {
+  return `${Number(stationID)}:${Number(typeID)}`;
+}
+
+function getStockRow(stockMap, stationID, typeID) {
+  return stockMap.get(key(stationID, typeID)) || {
+    station_id: Number(stationID),
+    type_id: Number(typeID),
+    quantity: 0,
+    price: catalog.getGood(typeID)?.priceAnchor || 1,
+  };
+}
+
+async function main() {
+  const nowMs = 1_700_000_000_000;
+  const state = stateStore.buildDefaultState();
+  const station = catalog.getStation(60003760);
+  const product = catalog.getGood(210);
+  const recipe = industry.getRecipe(product);
+  assert.equal(recipe.blueprintTypeID, 811);
+  assert.equal(recipe.productQuantityPerRun, 100);
+  assert.equal(recipe.timePerRunSeconds, 300);
+  assert.deepEqual(
+    recipe.materials.map((entry) => [entry.typeID, entry.quantityPerRun]),
+    [[34, 69], [35, 43], [36, 2]],
+  );
+
+  const badgerRecipe = industry.getRecipe(catalog.getGood(648));
+  assert.equal(badgerRecipe.blueprintTypeID, 983);
+  assert.equal(badgerRecipe.timePerRunSeconds, 12_000);
+  assert.equal(badgerRecipe.materials.length, 7);
+
+  const stockMap = new Map();
+  stockMap.set(key(station.stationID, product.typeID), {
+    station_id: station.stationID,
+    type_id: product.typeID,
+    quantity: 0,
+    price: product.priceAnchor,
+  });
+  for (const material of recipe.materials) {
+    const good = catalog.getGood(material.typeID);
+    stockMap.set(key(station.stationID, material.typeID), {
+      station_id: station.stationID,
+      type_id: material.typeID,
+      quantity: 1_000_000,
+      price: good.priceAnchor,
+    });
+  }
+
+  const adjustments = [];
+  const events = [];
+  const dependencies = {
+    getStockRow,
+    async adjustStock(details) {
+      const row = getStockRow(stockMap, details.station.stationID, details.good.typeID);
+      const nextQuantity = Math.max(0, row.quantity + Number(details.deltaQuantity || 0));
+      const response = { ...row, quantity: nextQuantity };
+      stockMap.set(key(details.station.stationID, details.good.typeID), response);
+      adjustments.push({ ...details, nextQuantity });
+      return { success: true, response };
+    },
+    addEvent(kind, _job, details, occurredAtMs) {
+      events.push({ kind, ...details, occurredAtMs });
+    },
+  };
+
+  const candidate = industry._testing.buildCandidate(
+    state,
+    stockMap,
+    getStockRow,
+    station,
+    product,
+    nowMs,
+  );
+  assert.ok(candidate, "a mineral-funded Scourge production candidate was not created");
+  assert.equal(candidate.runs, 24);
+  assert.equal(candidate.outputQuantity, 2_400);
+  assert.equal(candidate.durationSeconds, 7_200);
+
+  const beforeInputs = new Map(recipe.materials.map((entry) => [
+    entry.typeID,
+    getStockRow(stockMap, station.stationID, entry.typeID).quantity,
+  ]));
+  const job = industry._testing.createJob(state, candidate, nowMs);
+  assert.equal(
+    await industry._testing.reserveInputs(state, job, stockMap, dependencies, nowMs),
+    true,
+  );
+  assert.equal(job.status, "running");
+  assert.equal(job.endsAtMs, nowMs + 7_200_000);
+  for (const input of job.inputs) {
+    assert.equal(
+      getStockRow(stockMap, station.stationID, input.typeID).quantity,
+      beforeInputs.get(input.typeID) - input.quantity,
+      `${input.typeName} was not conserved`,
+    );
+  }
+  assert.equal(
+    await industry._testing.completeJob(
+      state,
+      job,
+      stockMap,
+      dependencies,
+      job.endsAtMs - 1,
+    ),
+    false,
+    "industry completed before the official blueprint clock elapsed",
+  );
+  assert.equal(getStockRow(stockMap, station.stationID, product.typeID).quantity, 0);
+  assert.equal(
+    await industry._testing.completeJob(
+      state,
+      job,
+      stockMap,
+      dependencies,
+      job.endsAtMs,
+    ),
+    true,
+  );
+  assert.equal(job.status, "completed");
+  assert.equal(getStockRow(stockMap, station.stationID, product.typeID).quantity, 2_400);
+  assert.equal(state.metrics.industryJobsInstalled, 1);
+  assert.equal(state.metrics.industryJobsCompleted, 1);
+  assert.equal(state.metrics.industryOutputUnitsProduced, 2_400);
+  assert.equal(state.metrics.productionRuns, 24);
+  assert.equal(events.filter((event) => event.kind === "industry_job_started").length, 1);
+  assert.equal(events.filter((event) => event.kind === "industry_job_completed").length, 1);
+
+  const period = telemetry.buildIndustryPeriod(state, nowMs - 1, job.endsAtMs + 1);
+  assert.equal(period.jobsInstalled, 1);
+  assert.equal(period.jobsCompleted, 1);
+  assert.equal(period.outputUnitsProduced, 2_400);
+  assert.equal(period.byProduct[0].typeID, product.typeID);
+
+  assert.equal(catalog.PROCUREMENT_GOODS.length, 20);
+  assert.equal(catalog.PROCUREMENT_INPUT_GOODS.length, 27);
+  for (const typeID of [597, 593, 587, 19744, 650, 653, 453, 486, 523]) {
+    const racialProduct = catalog.getGood(typeID);
+    const racialRecipe = industry.getRecipe(racialProduct);
+    assert.ok(racialProduct && racialRecipe, `missing racial T1 recipe for ${typeID}`);
+    assert.ok(racialRecipe.materials.every((entry) => (
+      catalog.isMineralGood(catalog.getGood(entry.typeID))
+    )));
+  }
+  const procurementCandidates = procurement._testing.buildCandidates(new Map(), getStockRow);
+  assert.ok(
+    procurementCandidates.some((entry) => catalog.isMineralGood(entry.good)),
+    "industrial corporations are not procuring minerals",
+  );
+
+  console.log(JSON.stringify({
+    success: true,
+    blueprint: {
+      blueprintTypeID: recipe.blueprintTypeID,
+      product: product.name,
+      runs: candidate.runs,
+      durationMinutes: candidate.durationSeconds / 60,
+      outputQuantity: candidate.outputQuantity,
+      inputs: job.inputs,
+    },
+    starterShipRecipe: {
+      product: "Badger",
+      blueprintTypeID: badgerRecipe.blueprintTypeID,
+      durationMinutesPerRun: badgerRecipe.timePerRunSeconds / 60,
+      mineralTypes: badgerRecipe.materials.length,
+    },
+    procurementInputTypes: catalog.PROCUREMENT_INPUT_GOODS.length,
+    telemetry: period,
+    marketAdjustments: adjustments.length,
+  }, null, 2));
+}
+
+main().catch((error) => {
+  console.error(error.stack || error.message);
+  process.exitCode = 1;
+});
