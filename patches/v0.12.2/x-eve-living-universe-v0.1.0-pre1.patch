+"use strict";
+
+const assert = require("assert/strict");
+const fs = require("fs");
+const os = require("os");
+const path = require("path");
+
+const temporaryDataDirectory = fs.mkdtempSync(path.join(os.tmpdir(), "evejs-estate-prologue-"));
