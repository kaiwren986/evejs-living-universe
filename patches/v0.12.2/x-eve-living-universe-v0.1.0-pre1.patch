+function getRuntimeModule() {
+  return runtimeModuleOverride || require("./xEveRuntime");
+}
+
+function checkpointSourceJournal(options = {}) {
+  if (
+    options.force !== true &&
+    circuitState.sourceGeneration <= circuitState.sourceDurableGeneration
