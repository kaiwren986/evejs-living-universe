+      `X-Eve state read failed at ${pathArg}: ${result && result.errorMsg || "UNKNOWN"}`,
+      { path: pathArg, storeError: result && result.errorMsg || "UNKNOWN" },
+    );
+  }
+
+  function writePath(pathArg, value, writeOptions = {}) {
