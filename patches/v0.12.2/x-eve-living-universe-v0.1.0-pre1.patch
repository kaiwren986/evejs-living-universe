+sync_authored_gamestore_data() {
+  local relative_path
+  local source_path
+  local destination_path
+  local -a authored_paths=(
+    "liveEventDefinitions/data.json"
+  )
+
+  for relative_path in "${authored_paths[@]}"; do
+    source_path="${AUTHORED_GAMESTORE_ROOT}/${relative_path}"
+    destination_path="${GAMESTORE_DATA}/${relative_path}"
+    if [[ ! -f "${source_path}" ]]; then
+      log "Required authored game data is missing from the image: ${relative_path}"
+      return 1
+    fi
+    if [[ -f "${destination_path}" ]] && cmp --silent "${source_path}" "${destination_path}"; then
+      continue
+    fi
+    mkdir -p "$(dirname "${destination_path}")"
+    cp "${source_path}" "${destination_path}"
+    log "Installed authored game data: ${relative_path}"
+  done
+}
+
 initialize() {
   mkdir -p "${DATA_ROOT}"
   ensure_gamestore
+  sync_authored_gamestore_data
   log "Persistent game data initialization is complete."
 }
 
