+    adjustmentID:
+      `living-industry:${toPositiveInt(economyState.createdAtMs, 0)}:` +
+      `${job.jobID}:${job.stationID}:output:${job.productTypeID}`,
+    station,
+    good,
+    deltaQuantity: job.productQuantity,
+    reason: `NPC industry completion ${job.jobID}`,
+    stockMap,
