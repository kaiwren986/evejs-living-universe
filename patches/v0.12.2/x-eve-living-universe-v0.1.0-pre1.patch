+    pendingEventsSinceHandoff: 0,
+    lastObservedHandoffAtMs: 0,
+    lastObservedHandoffSuccesses: 0,
+    nextHandoffAttemptAtMs: 0,
+    lastJournalRows: 0,
+    lastFailureAtMs: 0,
+    lastFailureEventID: null,
