new file mode 100644
index 0000000000000000000000000000000000000000..7dec75b5a723185ea170e64b640e6a1480b4f065
--- /dev/null
+++ b/server/scripts/verifyStarterProgression.js
@@ -0,0 +1,128 @@
+const assert = require("assert");
+
+const config = require("../src/config");
+const {
+  getCharacterCreationRace,
+} = require("../src/services/character/characterCreationData");
+const {
+  RACE_PROGRESSION,
+  buildStarterPlansForRace,
+} = require("../src/services/character/starterProgressionRuntime");
+const {
+  resolveItemByTypeID,
+} = require("../src/services/inventory/itemTypeRegistry");
+const {
+  calculateSkillPointsForLevel,
+  getSkillTypeByID,
+} = require("../src/services/skills/skillState");
+const {
+  MAX_NUM_SKILLS,
+  canonicalizeSkillRequirements,
+} = require("../src/services/skills/plans/skillPlanState");
+
+const LARGE_INJECTOR_SP_BELOW_FIVE_MILLION = 500000;
+const MIN_USEFUL_STARTER_PLAN_SP = 300000;
+
+function getTargetLevels(requirements) {
+  const targetLevels = new Map();
+  for (const requirement of requirements) {
+    targetLevels.set(
+      requirement.typeID,
+      Math.max(targetLevels.get(requirement.typeID) || 0, requirement.level),
+    );
+  }
+  return targetLevels;
+}
+
+function calculateIncrementalSkillPoints(targetLevels, starterSkills) {
+  let total = 0;
+  for (const [typeID, targetLevel] of targetLevels.entries()) {
+    const skillType = getSkillTypeByID(typeID);
+    assert(skillType, `Missing published skill type ${typeID}`);
+    const starterLevel = starterSkills.get(typeID) || 0;
+    total += Math.max(
+      0,
+      calculateSkillPointsForLevel(skillType.skillRank, targetLevel) -
+        calculateSkillPointsForLevel(skillType.skillRank, starterLevel),
+    );
+  }
+  return total;
+}
+
+assert.strictEqual(config.omegaLicenseEnabled, true, "All characters must resolve as Omega");
+assert.strictEqual(config.skillTrainingSpeed, 200, "Local skill training speed must be 200x");
+assert.strictEqual(
+  config.newCharacterStarterProgressionEnabled,
+  true,
+  "New-character starter progression must be enabled locally",
+);
+assert.strictEqual(config.newCharacterStarterSkillInjectorTypeID, 40520);
+assert.strictEqual(config.newCharacterStarterSkillInjectorQuantity, 1);
+
+const injectorType = resolveItemByTypeID(config.newCharacterStarterSkillInjectorTypeID);
+assert(injectorType, "Configured starter injector must be a published inventory type");
+assert.strictEqual(injectorType.published, true);
+assert.strictEqual(injectorType.name, "Large Skill Injector");
+
+const verificationRows = [];
+for (const raceID of Object.keys(RACE_PROGRESSION).map(Number)) {
+  const race = RACE_PROGRESSION[raceID];
+  const creationRace = getCharacterCreationRace(raceID);
+  assert(creationRace, `Missing starter-skill data for ${race.name}`);
+  const starterSkills = new Map(
+    creationRace.skills.map((skill) => [skill.typeID, skill.level]),
+  );
+  const plans = buildStarterPlansForRace(raceID);
+  assert.strictEqual(plans.length, 2, `${race.name} must receive two starter plans`);
+
+  for (const plan of plans) {
+    const canonicalRequirements = canonicalizeSkillRequirements(plan.requirements);
+    assert(
+      canonicalRequirements.length <= MAX_NUM_SKILLS,
+      `${plan.name} exceeds the personal skill-plan entry limit`,
+    );
+    const targetLevels = getTargetLevels(canonicalRequirements);
+    const incrementalSP = calculateIncrementalSkillPoints(targetLevels, starterSkills);
+    assert(
+      incrementalSP <= LARGE_INJECTOR_SP_BELOW_FIVE_MILLION,
+      `${plan.name} costs ${incrementalSP} SP, more than one Large Skill Injector provides`,
+    );
+    assert(
+      incrementalSP >= MIN_USEFUL_STARTER_PLAN_SP,
+      `${plan.name} costs only ${incrementalSP} SP and is not a meaningful starter route`,
+    );
+
+    if (plan.key === "cruiser") {
+      assert.strictEqual(
+        targetLevels.get(race.cruiserTypeID),
+        2,
+        `${plan.name} must end at racial Cruiser II`,
+      );
+    } else if (plan.key === "industry") {
+      assert.strictEqual(
+        targetLevels.get(17940),
+        1,
+        `${plan.name} must unlock Mining Barge I`,
+      );
+      assert.strictEqual(
+        targetLevels.get(race.industrialTypeID),
+        1,
+        `${plan.name} must include the racial industrial skill`,
+      );
+    } else {
+      assert.fail(`Unexpected starter plan key ${plan.key}`);
+    }
+
+    verificationRows.push({
+      race: race.name,
+      plan: plan.name,
+      planEntries: canonicalRequirements.length,
+      skills: targetLevels.size,
+      incrementalSP,
+      injectorSPRemaining: LARGE_INJECTOR_SP_BELOW_FIVE_MILLION - incrementalSP,
+    });
+  }
+}
+
+console.table(verificationRows);
+console.log("Starter progression verification passed.");
