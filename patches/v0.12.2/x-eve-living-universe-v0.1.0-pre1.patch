+
+function openCircuit(reason, options = {}) {
+  const nowMs = Math.max(0, Math.trunc(toFiniteNumber(options.nowMs, Date.now())));
+  if (circuitState.open !== true) {
+    circuitState.metrics.circuitTrips += 1;
+    circuitState.openedAtMs = nowMs;
+  }
