+#!/usr/bin/env node
+
+const assert = require("assert");
+const path = require("path");
+
+const {
+  buildShipResourceState,
+} = require(path.join(__dirname, "../src/services/fitting/liveFittingState"));
+const {
+  resolveItemByTypeID,
+} = require(path.join(__dirname, "../src/services/inventory/itemTypeRegistry"));
+
+const ATTRIBUTE_MAX_VELOCITY = 37;
+const ATTRIBUTE_ARMOR_HP = 265;
+const ATTRIBUTE_CAPACITOR_CAPACITY = 482;
+const SHIELD_RESONANCE_ATTRIBUTE_IDS = Object.freeze([271, 274, 273, 272]);
+
+function buildSkillMap(skillTypeID, level) {
+  return new Map([[
+    skillTypeID,
+    {
+      typeID: skillTypeID,
+      skillLevel: level,
+      trainedSkillLevel: level,
+      effectiveSkillLevel: level,
+    },
+  ]]);
+}
+
+function buildState(typeID, skillTypeID, level) {
+  const metadata = resolveItemByTypeID(typeID);
+  if (!metadata) {
+    throw new Error(`Missing item metadata for ship type ${typeID}.`);
+  }
+
+  return buildShipResourceState(0, {
+    ...metadata,
+    itemID: 920000000000 + typeID,
+    typeID,
+    ownerID: 0,
+  }, {
+    fittedItems: [],
+    skillMap: buildSkillMap(skillTypeID, level),
+  });
+}
+
+function assertAttribute(typeID, skillTypeID, attributeID, expectedLevel0, expectedLevel5) {
+  const level0 = buildState(typeID, skillTypeID, 0);
+  const level5 = buildState(typeID, skillTypeID, 5);
+  assert.strictEqual(level0.attributes[attributeID], expectedLevel0);
+  assert.strictEqual(level5.attributes[attributeID], expectedLevel5);
+  return {
+    level0: level0.attributes[attributeID],
+    level5: level5.attributes[attributeID],
+  };
+}
+
+const gilaLevel0 = buildState(17715, 3334, 0);
+const gilaLevel5 = buildState(17715, 3334, 5);
+const gilaLevel0Resonances = SHIELD_RESONANCE_ATTRIBUTE_IDS.map(
+  (attributeID) => gilaLevel0.attributes[attributeID],
+);
+const gilaLevel5Resonances = SHIELD_RESONANCE_ATTRIBUTE_IDS.map(
+  (attributeID) => gilaLevel5.attributes[attributeID],
+);
+assert.deepStrictEqual(gilaLevel0Resonances, [1, 0.8, 0.6, 0.5]);
+assert.deepStrictEqual(gilaLevel5Resonances, [0.8, 0.64, 0.48, 0.4]);
+assert.strictEqual(
+  gilaLevel5.attributes[657],
+  -20,
+  "Caldari Cruiser V must scale the Gila's per-level shipBonusCC2 source value.",
+);
+
+const tayraVelocity = assertAttribute(
+  649,
+  3342,
+  ATTRIBUTE_MAX_VELOCITY,
+  115,
+  143.75,
+);
+const apocalypseCapacitor = assertAttribute(
+  11936,
+  3339,
+  ATTRIBUTE_CAPACITOR_CAPACITY,
+  6600,
+  8250,
+);
+const augororArmor = assertAttribute(
+  29337,
+  3335,
+  ATTRIBUTE_ARMOR_HP,
+  3100,
+  4650,
+);
+
+console.log(JSON.stringify({
+  gila: {
+    caldariCruiserLevel0Resonances: gilaLevel0Resonances,
+    caldariCruiserLevel5Resonances: gilaLevel5Resonances,
+    scaledShipBonusCC2: gilaLevel5.attributes[657],
+  },
+  tayra: {
+    maxVelocity: tayraVelocity,
+  },
+  apocalypseImperialIssue: {
+    capacitorCapacity: apocalypseCapacitor,
+  },
+  augororNavyIssue: {
+    armorHP: augororArmor,
+  },
+}, null, 2));
