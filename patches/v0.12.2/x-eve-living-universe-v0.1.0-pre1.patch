+++ b/server/scripts/verifyLiveEventsCore.js
@@ -0,0 +1,307 @@
+"use strict";
+
+const assert = require("assert/strict");
+const fs = require("fs");
+const os = require("os");
+const path = require("path");
+
+const { getDefaultCatalog } = require("../src/space/liveEvents/liveEventCatalog");
+const { LiveEventRuntime, PHASE, createNoopHandler } = require(
+  "../src/space/liveEvents/liveEventRuntime"
+);
+const config = require("../src/config");
+const tableOwnership = require("../src/gameStore/tableOwnership");
+
+function cloneValue(value) {
+  return value === undefined ? undefined : JSON.parse(JSON.stringify(value));
+}
+
+function createMemoryStateStore() {
+  const events = new Map();
+  const archive = new Map();
+  const transactions = new Map();
+  let nextSerial = 1;
+  return {
+    ensureInitialized() {
+      return { success: true, data: { schemaVersion: 1, nextEventSerial: nextSerial } };
+    },
+    allocateEventID() {
+      const serial = nextSerial++;
+      return {
+        success: true,
+        data: { eventID: `test-event-${String(serial).padStart(4, "0")}`, serial },
+      };
+    },
+    listEvents() {
+      return [...events.values()].map(cloneValue);
+    },
+    getEvent(eventID) {
+      return cloneValue(events.get(String(eventID)) || null);
+    },
+    saveEvent(event) {
+      events.set(String(event.eventID), cloneValue(event));
+      return { success: true };
+    },
+    removeEvent(eventID) {
+      return { success: events.delete(String(eventID)) };
+    },
+    archiveEvent(event, nowMs) {
+      const archived = { ...cloneValue(event), archivedAtMs: nowMs };
+      archive.set(String(event.eventID), archived);
+      events.delete(String(event.eventID));
+      return { success: true, data: cloneValue(archived) };
+    },
+    listArchivedEvents() {
+      return [...archive.values()].map(cloneValue);
+    },
+    getTransaction(transactionID) {
+      return cloneValue(transactions.get(String(transactionID)) || null);
+    },
+    saveTransaction(transaction) {
+      transactions.set(String(transaction.transactionID), cloneValue(transaction));
+      return { success: true };
+    },
+  };
+}
+
+function verifyCatalog() {
+  const catalog = getDefaultCatalog();
+  const definitions = catalog.listDefinitions({ includeDisabled: true });
+  assert.ok(definitions.length >= 3);
+  assert.equal(catalog.getDefinition("kernel.noop").eventType, "noop");
+  assert.equal(catalog.getDefinition("industrial.mining.highsec.small").enabled, true);
+  assert.equal(catalog.getDefinition("industrial.mining.highsec.small").revision, 2);
+  assert.equal(
+    catalog.getDefinition("industrial.mining.highsec.small").producer.targetActiveCount,
+    1,
+  );
+  assert.equal(
+    catalog.getDefinition("industrial.mining.highsec.small").content.virtualQuantityPerCycle,
+    500,
+  );
+  assert.equal(catalog.getDefinition("battle.aftermath.skirmish.small").limits.dynamicObjects, 48);
+  assert.equal(typeof config.liveEventsEnabled, "boolean");
+  assert.equal(config.liveEventsSchedulerIntervalMs, 5_000);
+  assert.equal(config.liveEventsSchedulerBudgetMs, 2);
+  assert.equal(tableOwnership.getTableOwnership("liveEventRuntime").domain, "in-space");
+  assert.equal(tableOwnership.getTableOwnership("liveEventDefinitions").tier, "static");
+  return definitions.length;
+}
+
+function verifyRuntime() {
+  const stateStore = createMemoryStateStore();
+  let nowMs = 1_700_000_000_000;
+  let monotonicMs = 0;
+  const runtime = new LiveEventRuntime({
+    stateStore,
+    catalog: getDefaultCatalog(),
+    clock: () => nowMs,
+    monotonicClock: () => monotonicMs,
+    options: {
+      enabled: true,
+      schedulerIntervalMs: 5_000,
+      schedulerBudgetMs: 2,
+      maxJobsPerPass: 3,
+      maxActiveGlobal: 10,
+      maxActivePerSystem: 10,
+      enableProducers: false,
+    },
+  });
+  runtime.registerHandler("noop", createNoopHandler());
+  assert.equal(runtime.start({ force: true }).success, true);
+
+  const createdIDs = [];
+  for (let index = 0; index < 7; index += 1) {
+    const created = runtime.scheduleEvent("kernel.noop", {
+      force: true,
+      ignoreCaps: true,
+      systemID: 30000142 + index,
+      nowMs,
+    });
+    assert.equal(created.success, true);
+    createdIDs.push(created.data.eventID);
+  }
+  assert.equal(runtime.getSnapshot().queueSize, 7);
+
+  const firstPass = runtime.runDueWork(nowMs, { maxJobs: 3, budgetMs: 2 });
+  assert.equal(firstPass.data.processedJobs, 3);
+  assert.equal(firstPass.data.deferredJobs, 1);
+  assert.equal(
+    stateStore.listEvents().filter((event) => event.phase === PHASE.DORMANT).length,
+    3,
+  );
+
+  const secondPass = runtime.runDueWork(nowMs, { maxJobs: 3, budgetMs: 2 });
+  assert.equal(secondPass.data.processedJobs, 3);
+  const thirdPass = runtime.runDueWork(nowMs, { maxJobs: 3, budgetMs: 2 });
+  assert.equal(thirdPass.data.processedJobs, 1);
+  assert.ok(stateStore.listEvents().every((event) => event.phase === PHASE.DORMANT));
+
+  for (let transition = 0; transition < 5; transition += 1) {
+    nowMs += 1_000;
+    for (;;) {
+      const result = runtime.runDueWork(nowMs, { maxJobs: 3, budgetMs: 2 });
+      if (result.data.deferredJobs === 0) {
+        break;
+      }
+    }
+  }
+  assert.ok(stateStore.listEvents().every((event) => event.phase === PHASE.COMPLETED));
+  assert.equal(runtime.getSnapshot().queueSize, 0);
+  assert.equal(runtime.getSnapshot().metrics.completedEvents, 7);
+
+  const operatorEvent = runtime.scheduleEvent("kernel.noop", {
+    force: true,
+    ignoreCaps: true,
+    systemID: 30000142,
+    nowMs,
+  });
+  assert.equal(operatorEvent.success, true);
+  assert.equal(runtime.advanceEventNow(operatorEvent.data.eventID, nowMs).data.phase, PHASE.DORMANT);
+  assert.equal(runtime.requestCleanup(operatorEvent.data.eventID, {
+    nowMs,
+    reason: "verification",
+  }).data.phase, PHASE.CLEANUP);
+  assert.equal(runtime.advanceEventNow(operatorEvent.data.eventID, nowMs).data.phase, PHASE.COMPLETED);
+  assert.equal(runtime.getSnapshot().metrics.operatorAdvances, 2);
+  assert.equal(runtime.getSnapshot().metrics.operatorCleanupRequests, 1);
+
+  const failingRuntime = new LiveEventRuntime({
+    stateStore: createMemoryStateStore(),
+    catalog: getDefaultCatalog(),
+    clock: () => nowMs,
+    monotonicClock: () => monotonicMs,
+    options: {
+      enabled: true,
+      schedulerBudgetMs: 2,
+      maxJobsPerPass: 8,
+      maxActiveGlobal: 2,
+      maxActivePerSystem: 1,
+      recoveryBaseDelayMs: 5_000,
+      enableProducers: false,
+    },
+  });
+  failingRuntime.registerHandler("noop", {
+    advance() {
+      throw new Error("verification failure");
+    },
+  });
+  failingRuntime.start({ force: true });
+  const failedEvent = failingRuntime.scheduleEvent("kernel.noop", {
+    force: true,
+    systemID: 30000142,
+    nowMs,
+  });
+  failingRuntime.runDueWork(nowMs);
+  const recovered = failingRuntime.stateStore.getEvent(failedEvent.data.eventID);
+  assert.equal(recovered.phase, PHASE.RECOVERY_PENDING);
+  assert.equal(recovered.retryCount, 1);
+  assert.match(recovered.lastError, /verification failure/);
+
+  runtime.stop();
+  failingRuntime.stop();
+  return createdIDs.length;
+}
+
+function verifyProducerAndRetention() {
+  const stateStore = createMemoryStateStore();
+  const nowMs = 1_700_100_000_000;
+  for (let index = 0; index < 103; index += 1) {
+    stateStore.saveEvent({
+      eventID: `completed-${String(index).padStart(4, "0")}`,
+      eventType: "noop",
+      definitionID: "kernel.noop",
+      phase: PHASE.COMPLETED,
+      createdAtMs: nowMs - index,
+      updatedAtMs: nowMs - index,
+    });
+  }
+  const runtime = new LiveEventRuntime({
+    stateStore,
+    catalog: getDefaultCatalog(),
+    clock: () => nowMs,
+    monotonicClock: () => 0,
+    options: {
+      enabled: true,
+      enableProducers: true,
+      producerMaintenanceIntervalMs: 60_000,
+      completedRetentionCount: 100,
+      archiveBatchSize: 4,
+      maxActiveGlobal: 2,
+      maxActivePerSystem: 1,
+    },
+  });
+  const first = runtime.maintainProducerTargets(nowMs);
+  assert.equal(first.checked, true);
+  assert.equal(first.createdCount, 1);
+  assert.equal(first.archivedCount, 3);
+  const active = stateStore.listEvents().filter((event) => event.phase !== PHASE.COMPLETED);
+  assert.equal(active.length, 1);
+  assert.equal(active[0].definitionID, "industrial.mining.highsec.small");
+  assert.equal(active[0].systemID, 30000140);
+  assert.equal(stateStore.listEvents().filter((event) => event.phase === PHASE.COMPLETED).length, 100);
+  assert.equal(stateStore.listArchivedEvents().length, 3);
+  const second = runtime.maintainProducerTargets(nowMs + 1);
+  assert.equal(second.checked, false);
+  assert.equal(second.createdCount, 0);
+  assert.equal(runtime.getSnapshot().metrics.producerEventsCreated, 1);
+  assert.equal(runtime.getSnapshot().metrics.archivedEvents, 3);
+  return { created: first.createdCount, archived: first.archivedCount };
+}
+
+function verifyPersistence() {
+  const tempRoot = fs.mkdtempSync(path.join(os.tmpdir(), "evejs-live-events-"));
+  const dataDir = path.join(tempRoot, "data");
+  fs.mkdirSync(dataDir, { recursive: true });
+  process.env.EVEJS_GAMESTORE_DATA_DIR = dataDir;
+  try {
+    const { createStateStore } = require("../src/space/liveEvents/liveEventState");
+    const gameStore = require("../src/gameStore");
+    const sqliteStore = require("../src/gameStore/sqliteStore");
+    const store = createStateStore();
+    assert.equal(store.ensureInitialized(1_000).success, true);
+    const allocation = store.allocateEventID(1_000);
+    assert.equal(allocation.success, true);
+    assert.equal(
+      store.saveEvent({
+        eventID: allocation.data.eventID,
+        eventType: "noop",
+        definitionID: "kernel.noop",
+        phase: PHASE.SCHEDULED,
+        revision: 1,
+        nextTransitionAtMs: 1_000,
+      }).success,
+      true,
+    );
+    assert.equal(store.getEvent(allocation.data.eventID).eventID, allocation.data.eventID);
+    assert.equal(store.archiveEvent(store.getEvent(allocation.data.eventID), 2_000).success, true);
+    assert.equal(store.getEvent(allocation.data.eventID), null);
+    assert.equal(store.listArchivedEvents()[0].archivedAtMs, 2_000);
+    gameStore.flushTableSync("liveEventRuntime");
+    assert.ok(sqliteStore.rowCount("liveEventRuntime") >= 2);
+    gameStore._closeSqliteForTests();
+    return allocation.data.eventID;
+  } finally {
+    fs.rmSync(tempRoot, { recursive: true, force: true });
+  }
+}
+
+function runVerification() {
+  return {
+    success: true,
+    definitions: verifyCatalog(),
+    completedEvents: verifyRuntime(),
+    producer: verifyProducerAndRetention(),
+    persistedEventID: verifyPersistence(),
+  };
+}
+
+if (require.main === module) {
+  console.log(JSON.stringify(runVerification(), null, 2));
+}
+
+module.exports = {
+  createMemoryStateStore,
+  runVerification,
+};
+
diff --git a/server/scripts/verifyLiveNpcFittedModuleWreckDrops.js b/server/scripts/verifyLiveNpcFittedModuleWreckDrops.js
new file mode 100644
index 0000000000000000000000000000000000000000..24cdd7def5188cbe608017ef0d00498c27989ce2
--- /dev/null
+++ b/server/scripts/verifyLiveNpcFittedModuleWreckDrops.js
@@ -0,0 +1,141 @@
+"use strict";
+
+const assert = require("assert/strict");
+
+const spaceRuntime = require("../src/space/runtime");
+const npcData = require("../src/space/npc/npcData");
+const nativeNpcService = require("../src/space/npc/nativeNpcService");
+const {
+  destroyNativeNpcEntityWithWreck,
+  destroyNativeWreck,
+} = require("../src/space/npc/nativeNpcWreckService");
+
+const SYSTEM_ID = 30000142;
+const MAX_DROP_ATTEMPTS = 100;
+
+function buildContext() {
+  const scene = spaceRuntime.ensureScene(SYSTEM_ID);
+  assert.ok(scene, "Jita scene must load");
+  return {
+    systemID: SYSTEM_ID,
+    scene,
+    anchorKind: "station",
+    anchorLabel: "Live fitted-module wreck verification anchor",
+    anchorEntity: {
+      kind: "station",
+      itemID: 60003760,
+      itemName: "Jita IV - Moon 4 - Caldari Navy Assembly Plant",
+      radius: 1_000,
+      position: { x: 0, y: 0, z: 0 },
+      direction: { x: 1, y: 0, z: 0 },
+    },
+  };
+}
+
+function spawnTransientProfile(context, profileID, attempt) {
+  const definition = npcData.buildNpcDefinition(profileID);
+  assert.ok(definition, `${profileID} must resolve`);
+  const result = nativeNpcService.spawnNativeNpcEntityInContext(context, definition, {
+    transient: true,
+    materializeRuntime: true,
+    skipInitialBehaviorTick: true,
+    broadcast: false,
+    spawnStateOverride: {
+      position: { x: 100_000 + (attempt * 2_000), y: 0, z: 0 },
+      velocity: { x: 0, y: 0, z: 0 },
+      direction: { x: 1, y: 0, z: 0 },
+      targetPoint: { x: 100_000 + (attempt * 2_000), y: 0, z: 0 },
+      mode: "STOP",
+      speedFraction: 0,
+    },
+  });
+  assert.equal(result.success, true, `${profileID} transient spawn failed: ${result.errorMsg || "unknown"}`);
+  assert.ok(result.data && result.data.entity, `${profileID} did not materialize a runtime ship`);
+  return result.data.entity;
+}
+
+function destroyTransientProfile(context, profileID, attempt) {
+  const entity = spawnTransientProfile(context, profileID, attempt);
+  const result = destroyNativeNpcEntityWithWreck(SYSTEM_ID, entity, {
+    removeContents: true,
+  });
+  assert.equal(result.success, true, `${profileID} destruction failed: ${result.errorMsg || "unknown"}`);
+  return result;
+}
+
+function cleanupWreck(result) {
+  const wreckID = result && result.data && result.data.wreck && result.data.wreck.wreckID;
+  if (!wreckID) {
+    return;
+  }
+  const cleanup = destroyNativeWreck(wreckID, {
+    removeContents: true,
+  });
+  assert.equal(cleanup.success, true, `transient wreck ${wreckID} cleanup failed`);
+}
+
+function verifyIndustrialFittedDrop(context) {
+  for (let attempt = 0; attempt < MAX_DROP_ATTEMPTS; attempt += 1) {
+    const result = destroyTransientProfile(context, "ore_mining_retriever", attempt);
+    const fittedDrops = result.data.wreckItems.filter(
+      (item) => item && item.sourceKind === "fitted_module",
+    );
+    const destruction = result.data.fittedModuleDestruction;
+    assert.equal(destruction.policyID, "legacy_industrial_conservative");
+    assert.equal(destruction.policySource, "legacy_fallback");
+    assert.deepEqual(destruction.dropChances, {
+      techOne: 0.2,
+      techTwo: 0.03,
+      specialGrade: 0,
+    });
+    cleanupWreck(result);
+    if (fittedDrops.length > 0) {
+      const droppedTypeIDs = new Set(destruction.dropped.map((item) => item.typeID));
+      assert.ok(
+        fittedDrops.every((item) => droppedTypeIDs.has(item.typeID)),
+        "wreck fitted-module rows must match the exact destroyed ship fittings",
+      );
+      return {
+        attempts: attempt + 1,
+        fittedDrops: destruction.dropped,
+      };
+    }
+  }
+  assert.fail(`no fitted module survived in ${MAX_DROP_ATTEMPTS} deterministic Retriever destructions`);
+}
+
+function verifyProtectedConcordFit(context) {
+  const result = destroyTransientProfile(context, "concord_response", 1_000);
+  const destruction = result.data.fittedModuleDestruction;
+  assert.equal(destruction.policyID, "legacy_protected_law_enforcement");
+  assert.equal(destruction.protectedReason, "law_enforcement");
+  assert.equal(destruction.dropped.length, 0);
+  assert.equal(
+    result.data.wreckItems.filter((item) => item && item.sourceKind === "fitted_module").length,
+    0,
+  );
+  cleanupWreck(result);
+  return {
+    destroyedFittedModules: destruction.destroyed.length,
+  };
+}
+
+function runVerification() {
+  const context = buildContext();
+  const industrial = verifyIndustrialFittedDrop(context);
+  const concord = verifyProtectedConcordFit(context);
+  return {
+    success: true,
+    systemID: SYSTEM_ID,
+    industrial,
+    concord,
+  };
+}
+
+if (require.main === module) {
+  console.log(JSON.stringify(runVerification(), null, 2));
+}
+
+module.exports = {
+  runVerification,
+};
diff --git a/server/scripts/verifyLivingBattleModuleEffects.js b/server/scripts/verifyLivingBattleModuleEffects.js
new file mode 100644
index 0000000000000000000000000000000000000000..86cb728b3261b8b28b9b76462f9180f70abf02b0
--- /dev/null
+++ b/server/scripts/verifyLivingBattleModuleEffects.js
@@ -0,0 +1,497 @@
+"use strict";
+
+process.env.EVEJS_SKIP_NPC_STARTUP = "1";
+process.env.EVEJS_LIVING_UNIVERSE_ENABLED = "false";
+process.env.EVEJS_LIVING_ECONOMY_ENABLED = "false";
+
+const assert = require("assert/strict");
+
+const spaceRuntime = require("../src/space/runtime");
+const npcData = require("../src/space/npc/npcData");
+const npcService = require("../src/space/npc/npcService");
+const nativeNpcService = require("../src/space/npc/nativeNpcService");
+const nativeNpcStore = require("../src/space/npc/nativeNpcStore");
+const npcBehaviorLoop = require("../src/space/npc/npcBehaviorLoop");
+const npcEquipment = require("../src/space/npc/npcEquipment");
+const npcRegistry = require("../src/space/npc/npcRegistry");
+const {
+  TRAFFIC_DOCTRINES,
+} = require("../src/space/npc/governance/trafficDoctrineCatalog");
+const {
+  REGIONAL_TRAFFIC_DOCTRINES,
+} = require("../src/space/npc/governance/regionalTrafficDoctrineCatalog");
+const {
+  getLivingProfileID,
+} = require("../src/space/npc/ambientTraffic/ambientTrafficNpcCatalog");
+
+const SYSTEM_ID = 30000142;
+const OPERATOR_KIND = "livingBattleEffectsVerifier";
+const COMBAT_ROLES = new Set(["escort", "police", "highsec_pirate"]);
+
+function toInt(value, fallback = 0) {
+  const numeric = Math.trunc(Number(value) || 0);
+  return Number.isFinite(numeric) ? numeric : fallback;
+}
+
+function cleanupVerifierEntities() {
+  for (const controller of nativeNpcStore.listNativeControllersForSystem(SYSTEM_ID)) {
+    if (String(controller && controller.operatorKind || "") !== OPERATOR_KIND) continue;
+    npcService.destroyNpcControllerByEntityID(controller.entityID, {
+      removeContents: true,
+    });
+  }
+}
+
+function spawnCombatDoctrine(scene, doctrine, index) {
+  const definition = npcData.buildNpcDefinition(getLivingProfileID(doctrine.doctrineID));
+  assert.ok(definition, `${doctrine.doctrineID} profile did not resolve`);
+  const pirate = doctrine.role === "highsec_pirate";
+  const position = {
+    x: 1_000_000 + ((index % 8) * 2_500),
+    y: pirate ? 0 : 30_000,
+    z: Math.floor(index / 8) * 2_500,
+  };
+  const result = nativeNpcService.spawnNativeNpcEntityInContext(
+    {
+      systemID: SYSTEM_ID,
+      scene,
+      anchorKind: "coordinates",
+      anchorLabel: "Living battle effect verifier",
+      anchorEntity: {
+        kind: "coordinates",
+        itemID: 0,
+        itemName: "Living battle effect verifier",
+        position,
+        direction: { x: 1, y: 0, z: 0 },
+        radius: 0,
+      },
+    },
+    definition,
+    {
+      transient: true,
+      materializeRuntime: true,
+      broadcast: false,
+      skipInitialBehaviorTick: true,
+      runtimeKind: "nativeAmbient",
+      operatorKind: OPERATOR_KIND,
+      ownerIDOverride: pirate ? 980000001 : 980000002,
+      corporationIDOverride: Number(doctrine.corporationID) || (pirate ? 1000127 : 1000035),
+      warFactionIDOverride: Number(doctrine.factionID) || (pirate ? 500010 : 500001),
+      loadoutSeed: `living-battle-effects:${doctrine.doctrineID}`,
+      behaviorOverrides: {
+        autoAggro: false,
+        autoActivateWeapons: false,
+        targetPreference: "none",
+        returnToHomeWhenIdle: false,
+      },
+      spawnStateOverride: {
+        position,
+        velocity: { x: 0, y: 0, z: 0 },
+        direction: { x: 1, y: 0, z: 0 },
+        targetPoint: position,
+        mode: "STOP",
+        speedFraction: 0,
+      },
+    },
+  );
+  assert.equal(
+    result.success,
+    true,
+    `${doctrine.doctrineID} failed to materialize: ${result.errorMsg || "unknown"}`,
+  );
+  return {
+    doctrine,
+    definition,
+    entity: result.data.entity,
+  };
+}
+
+function putAtSurfaceDistance(source, target, surfaceDistanceMeters) {
+  source.position = { x: 1_500_000, y: 0, z: 0 };
+  target.position = {
+    x:
+      source.position.x +
+      Math.max(0, Number(source.radius) || 0) +
+      Math.max(0, Number(target.radius) || 0) +
+      surfaceDistanceMeters,
+    y: 0,
+    z: 0,
+  };
+}
+
+function lockTarget(scene, source, target) {
+  if (scene.getTargetsForEntity(source).includes(target.itemID)) return;
+  const result = scene.finalizeTargetLock(source, target, {
+    nowMs: scene.getCurrentSimTimeMs(),
+  });
+  assert.equal(result && result.success, true, `${source.itemID} could not lock ${target.itemID}`);
+}
+
+function activeEffectForModule(entity, moduleID) {
+  if (!(entity.activeModuleEffects instanceof Map)) return null;
+  const direct = entity.activeModuleEffects.get(moduleID) || null;
+  if (direct) return direct;
+  return [...entity.activeModuleEffects.values()].find((effectState) => (
+    effectState &&
+    Array.isArray(effectState.bankModuleIDs) &&
+    effectState.bankModuleIDs.includes(moduleID)
+  )) || null;
+}
+
+function refillVerifierCapacitor(entity) {
+  entity.capacitorChargeRatio = 1;
+}
+
+function makeVerifierTargetDurable(entity) {
+  entity.shieldCapacity = 1_000_000_000_000;
+  entity.armorHP = 1_000_000_000_000;
+  entity.structureHP = 1_000_000_000_000;
+  entity.conditionState = {
+    ...(entity.conditionState || {}),
+    damage: 0,
+    armorDamage: 0,
+    shieldCharge: 1,
+    incapacitated: false,
+  };
+}
+
+function verifyWeapons(scene, records, fxEvents, activationOutcomes) {
+  const summaries = [];
+  for (const record of records) {
+    const source = record.entity;
+    const target = record.doctrine.role === "highsec_pirate"
+      ? records.find((candidate) => candidate.doctrine.role === "police").entity
+      : records.find((candidate) => candidate.doctrine.role === "highsec_pirate").entity;
+    putAtSurfaceDistance(source, target, 5_000);
+    refillVerifierCapacitor(source);
+    lockTarget(scene, source, target);
+    const modules = npcEquipment.getNpcWeaponModules(source);
+    assert.ok(modules.length > 0, `${record.doctrine.doctrineID} has no live weapon modules`);
+    const eventStart = fxEvents.length;
+    npcBehaviorLoop.__testing.syncNpcWeapons(scene, source, target);
+    const weaponEffects = modules.map((moduleItem) => ({
+      moduleItem,
+      effectState: activeEffectForModule(source, moduleItem.itemID),
+    }));
+    for (const entry of weaponEffects) {
+      assert.ok(
+        entry.effectState,
+        `${record.doctrine.doctrineID} weapon ${entry.moduleItem.itemName} did not activate: ${
+          JSON.stringify((() => {
+            const outcome = activationOutcomes.get(entry.moduleItem.itemID) || null;
+            return outcome && {
+              success: outcome.success,
+              errorMsg: outcome.errorMsg || null,
+              effectName: outcome.data && outcome.data.effectState && outcome.data.effectState.effectName,
+              stopReason: outcome.data && outcome.data.effectState && outcome.data.effectState.stopReason,
+            };
+          })())
+        }`,
+      );
+      assert.ok(
+        String(entry.effectState.guid || "").startsWith("effects."),
+        `${record.doctrine.doctrineID} weapon ${entry.moduleItem.itemName} has no client FX GUID`,
+      );
+      assert.ok(
+        String(entry.effectState.weaponFamily || "").length > 0,
+        `${record.doctrine.doctrineID} weapon ${entry.moduleItem.itemName} has no weapon family`,
+      );
+    }
+    const startEvents = fxEvents.slice(eventStart).filter((event) => (
+      event.shipID === source.itemID && event.options.start === true
+    ));
+    assert.ok(startEvents.length > 0, `${record.doctrine.doctrineID} emitted no weapon FX`);
+    const turretModules = weaponEffects.filter((entry) => (
+      String(entry.effectState.weaponFamily || "").toLowerCase().includes("turret")
+    ));
+    if (turretModules.length > 0) {
+      const presentedModuleIDs = new Set(startEvents.map((event) => toInt(event.options.moduleID, 0)));
+      for (const entry of turretModules) {
+        assert.ok(
+          presentedModuleIDs.has(toInt(entry.moduleItem.itemID, 0)),
+          `${record.doctrine.doctrineID} did not bind turret FX to ${entry.moduleItem.itemName}`,
+        );
+      }
+    }
+    const missileModules = weaponEffects.filter((entry) => (
+      String(entry.effectState.weaponFamily || "").toLowerCase().includes("missile")
+    ));
+    if (missileModules.length > 1) {
+      const bank = missileModules[0].effectState.bankModuleIDs || [];
+      assert.equal(
+        new Set(bank).size,
+        missileModules.length,
+        `${record.doctrine.doctrineID} missile bank lost launcher membership`,
+      );
+    }
+    summaries.push({
+      doctrineID: record.doctrine.doctrineID,
+      weapons: modules.length,
+      families: [...new Set(weaponEffects.map((entry) => entry.effectState.weaponFamily))],
+      effectiveRangesMeters: [...new Set(modules.map((moduleItem) => (
+        Math.round(npcEquipment.estimateNpcWeaponEffectiveRange(source, moduleItem))
+      )))].sort((left, right) => left - right),
+      startFx: startEvents.length,
+    });
+  }
+  return summaries;
+}
+
+function verifyPropulsion(scene, records, fxEvents) {
+  let modules = 0;
+  for (const record of records) {
+    const source = record.entity;
+    const target = record.doctrine.role === "highsec_pirate"
+      ? records.find((candidate) => candidate.doctrine.role === "police").entity
+      : records.find((candidate) => candidate.doctrine.role === "highsec_pirate").entity;
+    const propulsion = npcEquipment.getNpcPropulsionModules(source);
+    const authoredPropulsionCount = record.doctrine.modules
+      .filter((entry) => [439, 12056, 12058, 12066, 12068].includes(entry.typeID))
+      .reduce((sum, entry) => sum + entry.quantity, 0);
+    assert.equal(
+      propulsion.length,
+      authoredPropulsionCount,
+      `${record.doctrine.doctrineID} did not retain its fitted propulsion module`,
+    );
+    if (propulsion.length <= 0) continue;
+    putAtSurfaceDistance(source, target, 30_000);
+    refillVerifierCapacitor(source);
+    const eventStart = fxEvents.length;
+    npcBehaviorLoop.__testing.syncNpcPropulsion(scene, source, target, {
+      useChasePropulsion: true,
+      chasePropulsionActivateDistanceMeters: 18_000,
+      chasePropulsionDeactivateDistanceMeters: 10_000,
+    });
+    const effectState = activeEffectForModule(source, propulsion[0].moduleItem.itemID);
+    assert.ok(effectState, `${record.doctrine.doctrineID} propulsion did not activate`);
+    assert.equal(effectState.guid, "effects.Afterburner");
+    assert.ok(
+      fxEvents.slice(eventStart).some((event) => (
+        event.shipID === source.itemID &&
+        event.guid === "effects.Afterburner" &&
+        event.options.start === true
+      )),
+      `${record.doctrine.doctrineID} emitted no afterburner FX`,
+    );
+    modules += propulsion.length;
+  }
+  return modules;
+}
+
+function verifyHostileModules(scene, records, fxEvents) {
+  let modules = 0;
+  const families = new Set();
+  for (const record of records) {
+    const hostile = npcEquipment.getNpcHostileModules(record.entity);
+    if (hostile.length <= 0) continue;
+    const target = record.doctrine.role === "highsec_pirate"
+      ? records.find((candidate) => candidate.doctrine.role === "police").entity
+      : records.find((candidate) => candidate.doctrine.role === "highsec_pirate").entity;
+    putAtSurfaceDistance(record.entity, target, 4_000);
+    refillVerifierCapacitor(record.entity);
+    lockTarget(scene, record.entity, target);
+    const eventStart = fxEvents.length;
+    npcBehaviorLoop.__testing.syncNpcHostileModules(scene, record.entity, target);
+    for (const entry of hostile) {
+      const effectState = activeEffectForModule(record.entity, entry.moduleItem.itemID);
+      assert.ok(effectState, `${record.doctrine.doctrineID} hostile module did not activate`);
+      assert.ok(String(effectState.guid || "").startsWith("effects."));
+      families.add(String(entry.definition && entry.definition.family || "unknown"));
+      modules += 1;
+    }
+    assert.ok(
+      fxEvents.slice(eventStart).some((event) => (
+        event.shipID === record.entity.itemID && event.options.start === true
+      )),
+      `${record.doctrine.doctrineID} emitted no hostile-module FX`,
+    );
+  }
+  assert.ok(families.has("ecmJammer"), "Blackbird ECM was not classified");
+  assert.ok(families.has("stasisWebifier"), "Merlin webifier was not classified");
+  assert.ok(families.has("warpScrambler"), "Kestrel warp scrambler was not classified");
+  return { modules, families: [...families].sort() };
+}
+
+function verifySelfRepair(scene, records, fxEvents) {
+  let modules = 0;
+  for (const record of records) {
+    const selfModules = npcEquipment.getNpcSelfModules(record.entity);
+    if (selfModules.length <= 0) continue;
+    const target = record.doctrine.role === "highsec_pirate"
+      ? records.find((candidate) => candidate.doctrine.role === "police").entity
+      : records.find((candidate) => candidate.doctrine.role === "highsec_pirate").entity;
+    record.entity.conditionState = {
+      ...(record.entity.conditionState || {}),
+      shieldCharge: 0.5,
+      armorDamage: 0.5,
+    };
+    refillVerifierCapacitor(record.entity);
+    const eventStart = fxEvents.length;
+    npcBehaviorLoop.__testing.syncNpcSelfModules(scene, record.entity, target, {
+      combatEnabled: true,
+    });
+    for (const entry of selfModules) {
+      const effectState = activeEffectForModule(record.entity, entry.moduleItem.itemID);
+      assert.ok(effectState, `${record.doctrine.doctrineID} self repair did not activate`);
+      const expectedGuid = entry.definition && entry.definition.family === "armorRepair"
+        ? "effects.ArmorRepair"
+        : "effects.ShieldBoosting";
+      assert.equal(effectState.guid, expectedGuid);
+      modules += 1;
+    }
+    assert.ok(
+      fxEvents.slice(eventStart).some((event) => (
+        event.shipID === record.entity.itemID &&
+        ["effects.ShieldBoosting", "effects.ArmorRepair"].includes(event.guid) &&
+        event.options.start === true
+      )),
+      `${record.doctrine.doctrineID} emitted no local-repair FX`,
+    );
+  }
+  assert.ok(modules >= 2, "Raven and Rokh shield boosters were not both recognized");
+  return modules;
+}
+
+function verifyRemoteRepair(scene, records, fxEvents) {
+  let moduleCount = 0;
+  for (const support of records) {
+    const modules = npcEquipment.getNpcAssistanceModules(support.entity);
+    if (modules.length <= 0) continue;
+    const ally = records.find((record) => (
+      record !== support &&
+      record.doctrine.role === "police" &&
+      (!support.doctrine.factionKey || record.doctrine.factionKey === support.doctrine.factionKey)
+    ));
+    assert.ok(ally, `${support.doctrine.doctrineID} has no same-faction repair target`);
+    putAtSurfaceDistance(support.entity, ally.entity, 4_000);
+    refillVerifierCapacitor(support.entity);
+    ally.entity.conditionState = {
+      ...(ally.entity.conditionState || {}),
+      shieldCharge: 0.45,
+      armorDamage: 0.45,
+    };
+    const controller = npcRegistry.getControllerByEntityID(support.entity.itemID);
+    assert.ok(controller, `${support.doctrine.doctrineID} controller is missing`);
+    const eventStart = fxEvents.length;
+    const maintained = npcBehaviorLoop.__testing.syncNpcAssistanceModules(
+      scene,
+      support.entity,
+      controller,
+    );
+    assert.equal(maintained, true, `${support.doctrine.doctrineID} did not select its damaged ally`);
+    for (const entry of modules) {
+      const effectState = activeEffectForModule(support.entity, entry.moduleItem.itemID);
+      assert.ok(effectState, `${support.doctrine.doctrineID} remote repair did not activate`);
+      assert.ok(String(effectState.guid || "").startsWith("effects."));
+      moduleCount += 1;
+    }
+    assert.ok(
+      fxEvents.slice(eventStart).some((event) => (
+        event.shipID === support.entity.itemID &&
+        event.options.start === true
+      )),
+      `${support.doctrine.doctrineID} emitted no remote-repair FX`,
+    );
+  }
+  assert.ok(moduleCount >= 2, "no remote-repair doctrine activated");
+  return moduleCount;
+}
+
+function verifyMissileVolley(scene, records) {
+  const kestrel = records.find((record) => (
+    record.doctrine.doctrineID === "jita_pirate_standard_kestrel_v4"
+  ));
+  const target = records.find((record) => record.doctrine.role === "police");
+  assert.ok(kestrel && target, "Kestrel missile-volley test hulls are missing");
+  putAtSurfaceDistance(kestrel.entity, target.entity, 25_000);
+  lockTarget(scene, kestrel.entity, target.entity);
+  const weaponModules = npcEquipment.getNpcWeaponModules(kestrel.entity);
+  const activeEffect = weaponModules
+    .map((moduleItem) => activeEffectForModule(kestrel.entity, moduleItem.itemID))
+    .find((effectState) => effectState && String(effectState.weaponFamily).includes("missile"));
+  assert.ok(activeEffect, "Kestrel missile bank is not active");
+  const launchAtMs = Math.max(
+    scene.getCurrentSimTimeMs() + 1,
+    Number(activeEffect.nextCycleAtMs) + 1,
+  );
+  scene.tick(launchAtMs);
+  const missile = [...scene.dynamicEntities.values()].find((entity) => (
+    entity && entity.kind === "missile" && entity.sourceShipID === kestrel.entity.itemID
+  ));
+  assert.ok(missile, "Kestrel firing cycle did not materialize a missile ball");
+  assert.equal(new Set(missile.launchModules || []).size, 4, "Kestrel volley did not use all launchers");
+  assert.equal(missile.missileSnapshot && missile.missileSnapshot.bankSize, 4);
+  return {
+    missileTypeID: missile.typeID,
+    launchers: new Set(missile.launchModules || []).size,
+    bankSize: missile.missileSnapshot.bankSize,
+  };
+}
+
+function runVerification() {
+  cleanupVerifierEntities();
+  const scene = spaceRuntime.ensureScene(SYSTEM_ID);
+  assert.ok(scene, "Jita scene did not load");
+  const fxEvents = [];
+  const activationOutcomes = new Map();
+  const originalBroadcastSpecialFx = scene.broadcastSpecialFx.bind(scene);
+  const originalActivateGenericModule = scene.activateGenericModule.bind(scene);
+  scene.broadcastSpecialFx = (shipID, guid, options = {}, visibilityEntity = null) => {
+    fxEvents.push({ shipID, guid, options: { ...options } });
+    return originalBroadcastSpecialFx(shipID, guid, options, visibilityEntity);
+  };
+  scene.activateGenericModule = (session, moduleItem, effectName, options = {}) => {
+    const outcome = originalActivateGenericModule(session, moduleItem, effectName, options);
+    activationOutcomes.set(Number(moduleItem && moduleItem.itemID), outcome);
+    return outcome;
+  };
+
+  const regionalEffectDoctrines = REGIONAL_TRAFFIC_DOCTRINES.filter((doctrine) => (
+    COMBAT_ROLES.has(String(doctrine.role || "")) &&
+    (
+      /_policecommand_(command|support)_v1$/.test(doctrine.doctrineID) ||
+      /_pirate(standard|veteran|elite|command)_1_v1$/.test(doctrine.doctrineID)
+    )
+  ));
+  const combatDoctrines = [...TRAFFIC_DOCTRINES, ...regionalEffectDoctrines].filter((doctrine) => (
+    COMBAT_ROLES.has(String(doctrine.role || ""))
+  ));
+  const records = combatDoctrines.map((doctrine, index) => (
+    spawnCombatDoctrine(scene, doctrine, index)
+  ));
+  for (const record of records) makeVerifierTargetDurable(record.entity);
+
+  try {
+    const weapons = verifyWeapons(scene, records, fxEvents, activationOutcomes);
+    const missileVolley = verifyMissileVolley(scene, records);
+    const propulsionModules = verifyPropulsion(scene, records, fxEvents);
+    const hostile = verifyHostileModules(scene, records, fxEvents);
+    const selfRepairModules = verifySelfRepair(scene, records, fxEvents);
+    const remoteRepairModules = verifyRemoteRepair(scene, records, fxEvents);
+    return {
+      success: true,
+      doctrines: records.length,
+      weaponModules: weapons.reduce((sum, entry) => sum + entry.weapons, 0),
+      weaponFxStarts: weapons.reduce((sum, entry) => sum + entry.startFx, 0),
+      propulsionModules,
+      hostile,
+      selfRepairModules,
+      remoteRepairModules,
+      missileVolley,
+      fxGuids: [...new Set(fxEvents.map((event) => event.guid).filter(Boolean))].sort(),
+      weapons,
+    };
+  } finally {
+    scene.broadcastSpecialFx = originalBroadcastSpecialFx;
+    scene.activateGenericModule = originalActivateGenericModule;
+    cleanupVerifierEntities();
+  }
+}
+
+if (require.main === module) {
+  console.log(JSON.stringify(runVerification(), null, 2));
+}
+
+module.exports = {
+  runVerification,
+};
