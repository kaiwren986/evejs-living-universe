+  }
+  for (const skill of prologueRuntime.FAMILY_ESTATE_SKILL_FLOOR) {
+    assert.ok(getSkillTypeByID(skill.typeID), `Missing skill ${skill.typeID}`);
+    assert.ok(skill.level >= 1 && skill.level <= 5, `Invalid level for ${skill.typeID}`);
