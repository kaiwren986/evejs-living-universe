+function applySnapshot(Database, serverRoot, snapshotPath, config) {
+  const databasePath = path.join(
+    serverRoot,
+    "externalservices",
+    "market-server",
+    "data",
+    "generated",
+    "market.sqlite",
+  );
+  if (!fs.existsSync(snapshotPath)) throw new Error("Snapshot not found: " + snapshotPath);
+  const backupDir = path.join(
+    serverRoot,
+    "backups",
+    "x-eve-universe-market",
+    timestampForPath(),
+  );
+  const backupFiles = copyDatabaseFamily(databasePath, backupDir);
+  const topology = loadTopology(serverRoot);
+  const database = new Database(databasePath);
+  const now = new Date().toISOString();
+  try {
+    database.pragma("foreign_keys = OFF");
+    database.pragma("busy_timeout = 5000");
+    database.prepare("ATTACH DATABASE ? AS mirror").run(path.resolve(snapshotPath));
+    const snapshotReportRow = database
+      .prepare("SELECT value FROM mirror.meta WHERE key = ?")
+      .get("report");
+    if (!snapshotReportRow) throw new Error("Snapshot report metadata is missing.");
+    const snapshotReport = JSON.parse(snapshotReportRow.value);
+    const insertRegion = database.prepare(
+      "INSERT OR REPLACE INTO regions (region_id, region_name) VALUES (?, ?)",
+    );
+    const insertSystem = database.prepare(
+      [
+        "INSERT OR REPLACE INTO solar_systems",
+        "(solar_system_id, region_id, constellation_id, solar_system_name, security)",
+        "VALUES (?, ?, ?, ?, ?)",
+      ].join("\n"),
+    );
+    const insertStation = database.prepare(
+      [
+        "INSERT OR REPLACE INTO stations",
+        "(station_id, solar_system_id, constellation_id, region_id, station_name, security)",
+        "VALUES (?, ?, ?, ?, ?, ?)",
+      ].join("\n"),
+    );
+    const transaction = database.transaction(() => {
+      for (const [regionId, regionName] of topology.regionNames.entries()) {
+        insertRegion.run(regionId, regionName);
+      }
+      for (const system of topology.solarSystems) {
+        insertSystem.run(
+          Number(system.solarSystemID),
+          Number(system.regionID),
+          Number(system.constellationID),
+          String(system.solarSystemName || system.solarSystemID),
+          Number(system.security) || 0,
+        );
+      }
+      for (const station of topology.stationById.values()) {
+        insertStation.run(
+          station.stationId,
+          station.solarSystemId,
+          station.constellationId,
+          station.regionId,
+          station.stationName,
+          station.security,
+        );
+      }
+      database.exec("DELETE FROM seed_stock; DELETE FROM seed_buy_orders;");
+      database
+        .prepare(
+          [
+            "INSERT INTO seed_stock (",
+            " station_id, solar_system_id, constellation_id, region_id, type_id,",
+            " price, quantity, initial_quantity, price_version, updated_at",
+            ") SELECT station_id, solar_system_id, constellation_id, region_id, type_id,",
+            " price, quantity, quantity, 1, ?",
+            " FROM mirror.plan_rows WHERE bid = 0",
+          ].join("\n"),
+        )
+        .run(now);
+      database
+        .prepare(
+          [
+            "INSERT INTO seed_buy_orders (",
+            " station_id, solar_system_id, constellation_id, region_id, type_id,",
+            " price, quantity, initial_quantity, price_version, updated_at",
+            ") SELECT station_id, solar_system_id, constellation_id, region_id, type_id,",
+            " price, quantity, quantity, 1, ?",
+            " FROM mirror.plan_rows WHERE bid = 1",
+          ].join("\n"),
+        )
+        .run(now);
+      database.exec("DELETE FROM region_summaries; DELETE FROM system_seed_summaries;");
+      const regionIds = database
+        .prepare(
+          "SELECT region_id FROM seed_stock UNION SELECT region_id FROM seed_buy_orders ORDER BY region_id",
+        )
+        .all()
+        .map((row) => Number(row.region_id));
+      const systemIds = database
+        .prepare(
+          "SELECT solar_system_id FROM seed_stock UNION SELECT solar_system_id FROM seed_buy_orders ORDER BY solar_system_id",
+        )
+        .all()
+        .map((row) => Number(row.solar_system_id));
+      const insertRegionSummary = database.prepare(REGION_SUMMARY_SQL);
+      for (const regionId of regionIds) {
+        insertRegionSummary.run(regionId, regionId, regionId, regionId, regionId, now);
+      }
+      const insertSystemSummary = database.prepare(SYSTEM_SUMMARY_SQL);
+      for (const systemId of systemIds) {
+        insertSystemSummary.run(systemId, systemId, systemId, now);
+      }
+      const manifestRow = database
+        .prepare("SELECT value FROM manifest WHERE key = ?")
+        .get("manifest_json");
+      const manifest = manifestRow ? JSON.parse(manifestRow.value) : {};
+      manifest.generated_at = now;
+      manifest.selection_mode = "esi_public_npc_station_mirror";
+      manifest.selection_label = "ESI public NPC-station market mirror";
+      manifest.selected_solar_system_ids = [];
+      manifest.selected_solar_system_names = [];
+      manifest.region_count = Number(
+        database.prepare("SELECT COUNT(*) count FROM regions").get().count,
+      );
+      manifest.solar_system_count = Number(
+        database.prepare("SELECT COUNT(*) count FROM solar_systems").get().count,
+      );
+      manifest.station_count = Number(
+        database.prepare("SELECT COUNT(*) count FROM stations").get().count,
+      );
+      manifest.seed_row_count = Number(
+        database
+          .prepare(
+            "SELECT (SELECT COUNT(*) FROM seed_stock) + (SELECT COUNT(*) FROM seed_buy_orders) count",
+          )
+          .get().count,
+      );
+      manifest.default_quantity_per_station_type = 0;
+      manifest.seed_buy_orders_enabled = true;
+      manifest.station_jitter_percent = 0;
+      manifest.region_jitter_percent = 0;
+      manifest.universe_market_mirror = {
+        tool: TOOL_NAME + "/" + TOOL_VERSION,
+        applied_at: now,
+        snapshot_path: path.resolve(snapshotPath),
+        compatibility_date: config.compatibilityDate,
+        price_policy: config.pricePolicy,
+        snapshot_report: snapshotReport,
+      };
+      database
+        .prepare("INSERT OR REPLACE INTO manifest (key, value) VALUES (?, ?)")
+        .run("manifest_json", JSON.stringify(manifest, null, 2));
+    });
+    transaction();
+    database.pragma("analysis_limit = 10000");
+    database.exec("ANALYZE");
+    const quickCheck = database.pragma("quick_check", { simple: true });
+    if (quickCheck !== "ok") throw new Error("SQLite quick_check failed: " + quickCheck);
+    database.prepare("DETACH DATABASE mirror").run();
+    return {
+      ok: true,
+      databasePath,
+      backupDir,
+      backupFiles,
+      quickCheck,
+      sellRows: Number(database.prepare("SELECT COUNT(*) count FROM seed_stock").get().count),
+      buyRows: Number(
+        database.prepare("SELECT COUNT(*) count FROM seed_buy_orders").get().count,
+      ),
+      stockedStations: Number(
+        database
+          .prepare(
+            "SELECT COUNT(*) count FROM (SELECT station_id FROM seed_stock UNION SELECT station_id FROM seed_buy_orders)",
+          )
+          .get().count,
+      ),
+      stockedSystems: Number(
+        database
+          .prepare(
+            "SELECT COUNT(*) count FROM (SELECT solar_system_id FROM seed_stock UNION SELECT solar_system_id FROM seed_buy_orders)",
+          )
+          .get().count,
+      ),
+      stockedRegions: Number(
+        database
+          .prepare(
+            "SELECT COUNT(*) count FROM (SELECT region_id FROM seed_stock UNION SELECT region_id FROM seed_buy_orders)",
+          )
+          .get().count,
+      ),
+    };
+  } finally {
+    database.close();
+  }
+}
+
+async function applyCommand(args) {
+  const serverRoot = requireServerRoot(args);
+  const config = loadConfig(args.configPath);
+  if (!args.snapshotPath) throw new Error("--snapshot is required for apply.");
+  await assertServicesStopped();
+  const Database = loadDatabaseConstructor(serverRoot);
+  const result = applySnapshot(
+    Database,
+    serverRoot,
+    path.resolve(args.snapshotPath),
+    config,
+  );
+  console.log(JSON.stringify(result, null, 2));
+  return result;
+}
+
+function doctorCommand(args) {
+  const serverRoot = requireServerRoot(args);
+  const Database = loadDatabaseConstructor(serverRoot);
+  const databasePath = path.join(
+    serverRoot,
+    "externalservices",
+    "market-server",
+    "data",
+    "generated",
+    "market.sqlite",
+  );
+  const database = new Database(databasePath, { readonly: true, fileMustExist: true });
+  try {
+    const result = {
+      ok: true,
+      databasePath,
+      quickCheck: database.pragma("quick_check", { simple: true }),
+      stations: Number(database.prepare("SELECT COUNT(*) count FROM stations").get().count),
+      systems: Number(database.prepare("SELECT COUNT(*) count FROM solar_systems").get().count),
+      regions: Number(database.prepare("SELECT COUNT(*) count FROM regions").get().count),
+      sellRows: Number(database.prepare("SELECT COUNT(*) count FROM seed_stock").get().count),
+      buyRows: Number(
+        database.prepare("SELECT COUNT(*) count FROM seed_buy_orders").get().count,
+      ),
+      stockedStations: Number(
+        database
+          .prepare(
+            "SELECT COUNT(*) count FROM (SELECT station_id FROM seed_stock UNION SELECT station_id FROM seed_buy_orders)",
+          )
+          .get().count,
+      ),
+      playerOrders: Number(
+        database.prepare("SELECT COUNT(*) count FROM market_orders").get().count,
+      ),
+    };
+    result.ok = result.quickCheck === "ok";
+    console.log(JSON.stringify(result, null, 2));
+    return result;
+  } finally {
+    database.close();
+  }
+}
+
+async function main() {
+  const args = parseArgs(process.argv.slice(2));
+  if (args.command === "help") {
+    console.log(usage());
+    return;
+  }
+  if (args.command === "snapshot") await snapshotCommand(args);
+  else if (args.command === "apply") await applyCommand(args);
+  else if (args.command === "doctor") doctorCommand(args);
+  else throw new Error("Unknown command: " + args.command);
+}
+
+if (require.main === module) {
+  main().catch((error) => {
+    console.error("ERROR: " + (error && error.stack ? error.stack : error));
+    process.exitCode = 1;
+  });
+}
+
+module.exports = {
+  DEFAULT_CONFIG,
+  applySnapshot,
+  calculatePairPrices,
+  loadConfig,
+  mergeDeep,
+  optionalHeaderNumber,
+  parseArgs,
+  positiveNumber,
+  roundPrice,
+  selectAnchor,
+  sideLivePrice,
+};
