index 0000000000000000000000000000000000000000..35aba43a3563cee6ff38267b158cd390b3fc634b
--- /dev/null
+++ b/server/scripts/verifyVirtualMiningTransactions.js
@@ -0,0 +1,218 @@
+"use strict";
+
+const assert = require("assert/strict");
+const path = require("path");
+
+const {
+  createVirtualMiningTransactionService,
+} = require(path.join(__dirname, "../src/services/mining/virtualMiningTransactions"));
+
+function cloneValue(value) {
+  return value === undefined ? undefined : JSON.parse(JSON.stringify(value));
+}
+
+function createFakeRepository(initialSystemRecord) {
+  let systemRecord = cloneValue(initialSystemRecord);
+  let flushFailure = false;
+  let writeCount = 0;
+  let flushCount = 0;
+  return {
+    read(_table, pathArg) {
+      return pathArg === "/systems/30000142" && systemRecord
+        ? { success: true, data: cloneValue(systemRecord) }
+        : { success: false, errorMsg: "ENTRY_NOT_FOUND" };
+    },
+    write(_table, pathArg, value) {
+      if (pathArg !== "/systems/30000142") {
+        return { success: false, errorMsg: "INVALID_PATH" };
+      }
+      systemRecord = cloneValue(value);
+      writeCount += 1;
+      return { success: true };
+    },
+    flushTableSync() {
+      flushCount += 1;
+      return flushFailure
+        ? { success: false, errorMsg: "TEST_FLUSH_FAILURE" }
+        : { success: true, flushed: true };
+    },
+    setFlushFailure(value) {
+      flushFailure = value === true;
+    },
+    snapshot() {
+      return {
+        systemRecord: cloneValue(systemRecord),
+        writeCount,
+        flushCount,
+      };
+    },
+  };
+}
+
+function normalizeStateRecord(record = {}) {
+  return {
+    ...cloneValue(record),
+    revision: Math.max(0, Math.trunc(Number(record.revision) || 0)),
+    remainingQuantity: Math.max(0, Math.trunc(Number(record.remainingQuantity) || 0)),
+    updatedAtMs: Math.max(0, Math.trunc(Number(record.updatedAtMs) || 0)),
+  };
+}
+
+function createService(repository) {
+  return createVirtualMiningTransactionService({
+    repository,
+    tableName: "miningRuntimeState",
+    normalizeStateRecord,
+  });
+}
+
+function request(transactionID, allocations) {
+  return {
+    transactionID,
+    eventID: "live-event-0001",
+    systemID: 30000142,
+    beltID: 40009077,
+    allocations,
+  };
+}
+
+function run() {
+  const repository = createFakeRepository({
+    entities: {
+      1001: {
+        entityID: 1001,
+        beltID: 40009077,
+        yieldTypeID: 1230,
+        yieldKind: "ore",
+        originalQuantity: 100,
+        remainingQuantity: 100,
+        revision: 2,
+      },
+      1002: {
+        entityID: 1002,
+        beltID: 40009077,
+        yieldTypeID: 1228,
+        yieldKind: "ore",
+        originalQuantity: 50,
+        remainingQuantity: 50,
+      },
+      1003: {
+        entityID: 1003,
+        beltID: 40009078,
+        yieldTypeID: 1224,
+        yieldKind: "ore",
+        originalQuantity: 80,
+        remainingQuantity: 80,
+      },
+      5020000000001: {
+        entityID: 5020000000001,
+        beltID: 40009077,
+        yieldTypeID: 1230,
+        yieldKind: "ore",
+        originalQuantity: 7,
+        remainingQuantity: 7,
+      },
+    },
+  });
+  const service = createService(repository);
+  const sceneGuard = { isSystemSceneLoaded: () => false, nowMs: 123456 };
+
+  const firstRequest = request("virtual-mining:0001", [
+    { entityID: 1001, quantity: 10 },
+    { entityID: 1001, requestedQuantity: 20 },
+    { entityID: 1002, quantity: 200 },
+    { entityID: 1003, quantity: 10 },
+    { entityID: 9999, quantity: 10 },
+    { entityID: 5020000000001, quantity: 5 },
+  ]);
+  const first = service.applyPersistedMiningBatch(firstRequest, sceneGuard);
+  assert.equal(first.success, true);
+  assert.equal(first.idempotent, false);
+  assert.equal(first.data.totalRequestedQuantity, 255);
+  assert.equal(first.data.totalAcceptedQuantity, 85);
+
+  const afterFirst = repository.snapshot();
+  assert.equal(afterFirst.writeCount, 1, "one system-row write commits state and journal together");
+  assert.equal(afterFirst.systemRecord.entities[1001].remainingQuantity, 70);
+  assert.equal(afterFirst.systemRecord.entities[1001].revision, 3);
+  assert.equal(afterFirst.systemRecord.entities[1002].remainingQuantity, 0);
+  assert.equal(afterFirst.systemRecord.entities[1002].revision, 1);
+  assert.equal(afterFirst.systemRecord.entities[1003].remainingQuantity, 80);
+  assert.equal(
+    afterFirst.systemRecord.entities[5020000000001].remainingQuantity,
+    2,
+    "generated multi-trillion asteroid IDs must not be clamped to the quantity limit",
+  );
+  assert.ok(afterFirst.systemRecord.virtualMiningTransactions["virtual-mining:0001"]);
+
+  const restartedService = createService(repository);
+  const replay = restartedService.applyPersistedMiningBatch(firstRequest, sceneGuard);
+  assert.equal(replay.success, true);
+  assert.equal(replay.idempotent, true);
+  assert.equal(repository.snapshot().writeCount, 1, "replay must not deplete resources twice");
+
+  const conflict = restartedService.applyPersistedMiningBatch(
+    request("virtual-mining:0001", [{ entityID: 1001, quantity: 1 }]),
+    sceneGuard,
+  );
+  assert.equal(conflict.success, false);
+  assert.equal(conflict.errorMsg, "TRANSACTION_CONFLICT");
+
+  const activeScene = restartedService.applyPersistedMiningBatch(
+    request("virtual-mining:0002", [{ entityID: 1001, quantity: 1 }]),
+    { isSystemSceneLoaded: () => true },
+  );
+  assert.equal(activeScene.errorMsg, "SCENE_ACTIVE");
+  assert.equal(
+    restartedService.applyPersistedMiningBatch(
+      request("virtual-mining:0003", [{ entityID: 1001, quantity: 1 }]),
+    ).errorMsg,
+    "SCENE_GUARD_REQUIRED",
+  );
+
+  repository.setFlushFailure(true);
+  const uncertain = restartedService.applyPersistedMiningBatch(
+    request("virtual-mining:0004", [{ entityID: 1001, quantity: 10 }]),
+    sceneGuard,
+  );
+  assert.equal(uncertain.errorMsg, "PERSISTENCE_FAILED");
+  assert.equal(repository.snapshot().systemRecord.entities[1001].remainingQuantity, 60);
+
+  repository.setFlushFailure(false);
+  const recovered = createService(repository).applyPersistedMiningBatch(
+    request("virtual-mining:0004", [{ entityID: 1001, quantity: 10 }]),
+    sceneGuard,
+  );
+  assert.equal(recovered.success, true);
+  assert.equal(recovered.idempotent, true);
+  assert.equal(repository.snapshot().systemRecord.entities[1001].remainingQuantity, 60);
+
+  let nestedResult = null;
+  const reentrantRequest = request("virtual-mining:0005", [{ entityID: 1001, quantity: 1 }]);
+  const reentrant = createService(repository);
+  const outer = reentrant.applyPersistedMiningBatch(reentrantRequest, {
+    isSystemSceneLoaded() {
+      nestedResult = reentrant.applyPersistedMiningBatch(reentrantRequest, sceneGuard);
+      return false;
+    },
+  });
+  assert.equal(nestedResult.errorMsg, "SYSTEM_BUSY");
+  assert.equal(outer.success, true);
+
+  process.stdout.write(`${JSON.stringify({
+    success: true,
+    committedTransaction: first.data.transactionID,
+    acceptedQuantity: first.data.totalAcceptedQuantity,
+    replayWasIdempotent: replay.idempotent,
+    recoveredAfterFlushFailure: recovered.idempotent,
+    serializedReentrantCall: nestedResult.errorMsg,
+  }, null, 2)}\n`);
+}
+
+try {
+  run();
+} catch (error) {
+  console.error(error);
+  process.exitCode = 1;
+}
+
diff --git a/server/scripts/verifyXEveCore.js b/server/scripts/verifyXEveCore.js
