@@ -0,0 +1,99 @@
+"use strict";
+
+const assert = require("node:assert/strict");
+
+const conflict = require("../src/space/npc/ambientTraffic/livingConflictRuntime");
+const universe = require("../src/space/npc/ambientTraffic/livingUniverseRuntime");
+
+function runVerification() {
+  const nowMs = Date.now();
+  const state = universe._testing.buildPopulationPlan(4_000, nowMs);
+  const combatActors = Object.values(state.actors).filter((actor) => (
+    actor.role === "police" || actor.role === "highsec_pirate"
+  ));
+  const hullCounts = {};
+  for (const actor of combatActors) {
+    hullCounts[actor.shipTypeID] = (hullCounts[actor.shipTypeID] || 0) + 1;
+  }
+  for (const typeID of [602, 603, 620, 621, 623, 632, 638, 16227, 16238, 24688, 24698]) {
+    assert.ok(hullCounts[typeID] > 0, `combat population must contain hull type ${typeID}`);
+  }
+
+  const encounter = conflict.forceEncounter(state, nowMs, 30000142, {
+    isFlightEligible: () => true,
+    estimateTravelMs: () => 30_000,
+  }, {
+    forceMajor: true,
+    combatDefendersOnly: true,
+    wingFlightCount: 3,
+    stagingDelayMs: 15_000,
+  });
+  assert.ok(encounter, "operator battle must be schedulable");
+  assert.equal(encounter.battleClass, "major");
+  assert.equal(encounter.attackerFlightIDs.length, 3);
+  assert.equal(encounter.defenderFlightIDs.length, 3);
+  assert.equal(encounter.attackerActorIDs.length, 12);
+  assert.equal(encounter.defenderActorIDs.length, 9);
+  assert.equal(encounter.plannedShipCount, 21);
+  assert.equal(encounter.forcedByOperator, true);
+  assert.equal(encounter.targetSystemID, 30000142);
+  const attackerHullIDs = new Set(
+    encounter.attackerActorIDs.map((actorID) => state.actors[actorID].shipTypeID),
+  );
+  const defenderHullIDs = new Set(
+    encounter.defenderActorIDs.map((actorID) => state.actors[actorID].shipTypeID),
+  );
+  assert.ok(attackerHullIDs.size >= 6, "major attacker wing must mix doctrine tiers");
+  assert.ok(defenderHullIDs.size >= 5, "major defender wing must mix doctrine tiers");
+  assert.ok(
+    attackerHullIDs.has(638) || attackerHullIDs.has(24698),
+    "major attacker wing must contain a battlecruiser or battleship",
+  );
+  assert.ok(
+    defenderHullIDs.has(24688) || defenderHullIDs.has(16227),
+    "major defender wing must contain a battlecruiser or battleship",
+  );
+  for (const flightID of [...encounter.attackerFlightIDs, ...encounter.defenderFlightIDs]) {
+    assert.equal(state.flights[flightID].encounterID, encounter.encounterID);
+    assert.ok(encounter.participantSnapshots[flightID]);
+  }
+  const movedFlightIDs = [];
+  conflict.tick(state, nowMs + 15_001, {
+    isFlightEligible: () => true,
+    isSystemObserved: () => false,
+    moveFlightToSystem(flight, systemID) {
+      flight.currentSystemID = systemID;
+      movedFlightIDs.push(flight.flightID);
+    },
+  });
+  assert.equal(state.encounters[encounter.encounterID].phase, conflict.PHASE.ACTIVE);
+  assert.deepEqual(
+    [...new Set(movedFlightIDs)].sort(),
+    [...encounter.attackerFlightIDs, ...encounter.defenderFlightIDs].sort(),
+    "every wing flight must enter the battle system",
+  );
+
+  return {
+    success: true,
+    population: Object.keys(state.actors).length,
+    combatHullTypes: Object.keys(hullCounts).length,
+    hullCounts,
+    battle: {
+      encounterID: encounter.encounterID,
+      class: encounter.battleClass,
+      attackers: encounter.attackerActorIDs.length,
+      defenders: encounter.defenderActorIDs.length,
+      totalShips: encounter.plannedShipCount,
+      stagingSeconds: Math.round((encounter.startsAtMs - nowMs) / 1_000),
+      flightsMovedAtContact: movedFlightIDs.length,
+      attackerHullTypes: attackerHullIDs.size,
+      defenderHullTypes: defenderHullIDs.size,
+    },
+  };
+}
+
+if (require.main === module) {
+  console.log(JSON.stringify(runVerification(), null, 2));
+}
+
+module.exports = { runVerification };
