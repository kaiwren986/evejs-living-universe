diff --git a/server/scripts/verifyRegionalTrafficDoctrines.js b/server/scripts/verifyRegionalTrafficDoctrines.js
new file mode 100644
index 0000000000000000000000000000000000000000..86def699a25d33ebfd55ba4c86130f9f24e43013
--- /dev/null
+++ b/server/scripts/verifyRegionalTrafficDoctrines.js
@@ -0,0 +1,185 @@
+"use strict";
+
+process.env.EVEJS_SKIP_NPC_STARTUP = "1";
+process.env.EVEJS_LIVING_UNIVERSE_ENABLED = "false";
+process.env.EVEJS_LIVING_ECONOMY_ENABLED = "false";
+
+const assert = require("assert/strict");
+
+const npcData = require("../src/space/npc/npcData");
+const { resolveItemByTypeID } = require("../src/services/inventory/itemTypeRegistry");
+const {
+  validateGovernedNpcDefinition,
+} = require("../src/space/npc/governance/npcDoctrineGovernance");
+const regionalCatalog = require("../src/space/npc/governance/regionalTrafficDoctrineCatalog");
+const economyCatalog = require("../src/space/npc/ambientTraffic/livingEconomyCatalog");
+const economyIndustry = require("../src/space/npc/ambientTraffic/livingEconomyIndustry");
+const livingUniverseRuntime = require("../src/space/npc/ambientTraffic/livingUniverseRuntime");
+const { getLivingProfileID } = require("../src/space/npc/ambientTraffic/ambientTrafficNpcCatalog");
+
+function flattenHullIDs(empire) {
+  return new Set([
+    empire.shuttle,
+    ...empire.haulers,
+    ...Object.values(empire.hulls).flat(),
+  ]);
+}
+
+function verifyCatalog() {
+  const doctrines = regionalCatalog.REGIONAL_TRAFFIC_DOCTRINES;
+  const groups = regionalCatalog.REGIONAL_SPAWN_GROUP_DEFINITIONS;
+  assert.equal(doctrines.length, 152, "unexpected regional doctrine count");
+  assert.equal(groups.length, 60, "unexpected regional spawn-group count");
+  assert.equal(new Set(doctrines.map((row) => row.doctrineID)).size, doctrines.length);
+  assert.equal(new Set(groups.map((row) => row.spawnGroupID)).size, groups.length);
+  const replacementTypeIDs = new Set();
+
+  for (const doctrine of doctrines) {
+    assert.ok(resolveItemByTypeID(doctrine.shipTypeID), `${doctrine.doctrineID} hull is missing`);
+    assert.ok(economyCatalog.getGood(doctrine.shipTypeID), `${doctrine.doctrineID} hull is absent from the replacement economy`);
+    replacementTypeIDs.add(Number(doctrine.shipTypeID));
+    for (const entry of [
+      ...(doctrine.modules || []),
+      ...(doctrine.charges || []),
+      ...(doctrine.droneBay || []),
+    ]) {
+      assert.ok(resolveItemByTypeID(entry.typeID), `${doctrine.doctrineID} item ${entry.typeID} is missing`);
+      assert.ok(economyCatalog.getGood(entry.typeID), `${doctrine.doctrineID} item ${entry.typeID} is absent from the replacement economy`);
+      replacementTypeIDs.add(Number(entry.typeID));
+    }
+    const definition = npcData.buildNpcDefinition(getLivingProfileID(doctrine.doctrineID));
+    assert.ok(definition, `${doctrine.doctrineID} did not generate an NPC profile`);
+    const validation = validateGovernedNpcDefinition(definition);
+    assert.equal(
+      validation.success,
+      true,
+      `${doctrine.doctrineID} governance failed: ${validation.errorMsg || "unknown"}`,
+    );
+    assert.equal(Number(definition.profile.shipTypeID), Number(doctrine.shipTypeID));
+    assert.equal(Number(definition.profile.factionID), Number(doctrine.factionID));
+  }
+
+  const foundationAssemblyTypeIDs = [];
+  for (const typeID of replacementTypeIDs) {
+    const recipe = economyIndustry.getRecipe(economyCatalog.getGood(typeID));
+    assert.ok(recipe, `replacement item ${typeID} has no production recipe`);
+    assert.ok(recipe.materials.length > 0, `replacement item ${typeID} has an empty recipe`);
+    assert.ok(recipe.materials.every((entry) => (
+      economyCatalog.isMineralGood(economyCatalog.getGood(entry.typeID))
+    )), `replacement item ${typeID} has an input outside the foundation economy`);
+    if (recipe.foundationAssembly === true) foundationAssemblyTypeIDs.push(typeID);
+  }
+
+  for (const group of groups) {
+    const definition = npcData.getNpcSpawnGroup(group.spawnGroupID);
+    assert.ok(definition, `${group.spawnGroupID} did not generate a spawn group`);
+    assert.equal(
+      definition.entries.reduce((sum, entry) => sum + Number(entry.count || 1), 0),
+      group.entries.length,
+      `${group.spawnGroupID} changed its intended ship count`,
+    );
+  }
+  return {
+    doctrines: doctrines.length,
+    groups: groups.length,
+    replacementTypes: replacementTypeIDs.size,
+    foundationAssemblyTypes: foundationAssemblyTypeIDs.sort((left, right) => left - right),
+  };
+}
+
+function verifyPopulation() {
+  const state = livingUniverseRuntime._testing.buildPopulationPlan(800, 1_700_000_000_000);
+  const actors = Object.values(state.actors);
+  const flights = Object.values(state.flights);
+  const empiresByRaceID = new Map(
+    Object.values(regionalCatalog.EMPIRE_DEFINITIONS).map((empire) => [empire.raceID, empire]),
+  );
+  const pirateRaceByKey = new Map(
+    Object.values(regionalCatalog.PIRATE_DEFINITIONS).map((pirate) => [
+      pirate.key,
+      regionalCatalog.EMPIRE_DEFINITIONS[pirate.raceKey].raceID,
+    ]),
+  );
+  const pirateHullIDsByKey = new Map(
+    Object.values(regionalCatalog.PIRATE_DEFINITIONS).map((pirate) => [
+      pirate.key,
+      new Set(Object.values(pirate.hulls).map(Number)),
+    ]),
+  );
+
+  for (const actor of actors) {
+    if (["miner", "mining_support"].includes(actor.role)) continue;
+    const profile = npcData.getNpcProfile(actor.profileID);
+    assert.ok(profile, `${actor.actorID} profile is missing`);
+    if (actor.role === "highsec_pirate") {
+      assert.ok(pirateRaceByKey.has(actor.pirateFactionKey));
+      assert.equal(Number(profile.factionID), Number(actor.factionID));
+      assert.equal(Number(profile.raceID), pirateRaceByKey.get(actor.pirateFactionKey));
+      assert.ok(
+        pirateHullIDsByKey.get(actor.pirateFactionKey).has(Number(actor.shipTypeID)),
+        `${actor.actorID} uses a non-faction pirate hull ${actor.shipTypeID}`,
+      );
+      continue;
+    }
+    const empireKey = regionalCatalog.getEmpireKeyForAffiliation(actor.factionID, actor.raceID);
+    const empire = regionalCatalog.EMPIRE_DEFINITIONS[empireKey] ||
+      empiresByRaceID.get(Number(actor.raceID));
+    if (!empire) continue;
+    assert.equal(Number(profile.raceID), empire.raceID, `${actor.actorID} uses the wrong racial profile`);
+    assert.ok(flattenHullIDs(empire).has(actor.shipTypeID), `${actor.actorID} uses a foreign hull`);
+  }
+
+  const pirateActors = actors.filter((actor) => actor.role === "highsec_pirate");
+  assert.equal(new Set(pirateActors.map((actor) => actor.pirateFactionKey)).size, 5);
+  for (const flight of flights.filter((entry) => entry.family === "pirate")) {
+    const expectedKey = livingUniverseRuntime._testing.getPirateGroupKeyForSecurity(
+      flight.minimumSecurity,
+    );
+    assert.equal(
+      flight.spawnGroupID,
+      regionalCatalog.getPirateGroupID(flight.doctrineFactionKey, expectedKey),
+      `${flight.flightID} difficulty does not match security ${flight.minimumSecurity}`,
+    );
+  }
+
+  const tierPower = {};
+  for (const [groupKey, expectedSecurity] of [
+    [regionalCatalog.GROUP_KEYS.pirateStandard, 0.9],
+    [regionalCatalog.GROUP_KEYS.pirateVeteran, 0.6],
+    [regionalCatalog.GROUP_KEYS.pirateElite, 0.3],
+    [regionalCatalog.GROUP_KEYS.pirateCommand, 0.0],
+  ]) {
+    assert.equal(livingUniverseRuntime._testing.getPirateGroupKeyForSecurity(expectedSecurity), groupKey);
+    const groupID = regionalCatalog.getPirateGroupID("guristas", groupKey);
+    const group = npcData.getNpcSpawnGroup(groupID);
+    tierPower[groupKey] = group.entries.reduce((sum, entry) => {
+      const profile = npcData.getNpcProfile(entry.profileID);
+      const loadout = npcData.getNpcLoadout(profile.loadoutID);
+      return sum + Number(loadout.governance.survivabilityProfile.combatPower || 0);
+    }, 0);
+  }
+  assert.ok(tierPower.pirateVeteran > tierPower.pirateStandard);
+  assert.ok(tierPower.pirateElite > tierPower.pirateVeteran);
+  assert.ok(tierPower.pirateCommand > tierPower.pirateElite);
+
+  return {
+    actors: actors.length,
+    flights: flights.length,
+    pirateActors: pirateActors.length,
+    pirateFactions: [...new Set(pirateActors.map((actor) => actor.pirateFactionKey))].sort(),
+    tierPower,
+  };
+}
+
+function runVerification() {
+  const result = {
+    catalog: verifyCatalog(),
+    population: verifyPopulation(),
+  };
+  process.stdout.write(`${JSON.stringify(result, null, 2)}\n`);
+  return result;
+}
+
+if (require.main === module) runVerification();
+
+module.exports = { runVerification };
diff --git a/server/scripts/verifyShipDerivedAttributeNotifications.js b/server/scripts/verifyShipDerivedAttributeNotifications.js
new file mode 100644
index 0000000000000000000000000000000000000000..87bb60b3949283d083762a8c7e90884451675708
--- /dev/null
+++ b/server/scripts/verifyShipDerivedAttributeNotifications.js
@@ -0,0 +1,306 @@
+#!/usr/bin/env node
+
+const assert = require("assert");
+const path = require("path");
+
+const runtime = require(path.join(__dirname, "../src/space/runtime"));
+const {
+  getTypeEffectRecords,
+} = require(path.join(__dirname, "../src/services/fitting/liveFittingState"));
+const {
+  resolveItemByTypeID,
+} = require(path.join(__dirname, "../src/services/inventory/itemTypeRegistry"));
+
+const SYSTEM_ID = 30002780;
+const CHARACTER_ID = 140000005;
+const SHIP_ID = 910100001;
+const GILA_TYPE_ID = 17715;
+const CALDARI_CRUISER_SKILL_TYPE_ID = 3334;
+const SHIELD_MANAGEMENT_SKILL_TYPE_ID = 3419;
+const MECHANICS_SKILL_TYPE_ID = 3392;
+const HULL_UPGRADES_SKILL_TYPE_ID = 3394;
+const ENDURING_MULTISPECTRUM_SHIELD_HARDENER_TYPE_ID = 54291;
+const MULTISPECTRUM_SHIELD_HARDENER_II_TYPE_ID = 2281;
+const LARGE_SHIELD_EXTENDER_II_TYPE_ID = 3841;
+const MEDIUM_CORE_DEFENSE_FIELD_EXTENDER_I_TYPE_ID = 31790;
+const ACTIVE_SHIELD_RESONANCE_EFFECT_ID = 5230;
+const EXPECTED_SHIELD_CAPACITY = 20912.03125;
+const EXPECTED_ACTIVE_EHP = 80134;
+const SHIELD_RESONANCE_ATTRIBUTE_IDS = Object.freeze([271, 272, 273, 274]);
+const EXPECTED_PASSIVE_RESONANCES = Object.freeze({
+  271: 0.8,
+  272: 0.4,
+  273: 0.48,
+  274: 0.64,
+});
+const EXPECTED_ACTIVE_RESONANCES = Object.freeze({
+  271: 0.403896,
+  272: 0.201948,
+  273: 0.242337,
+  274: 0.323117,
+});
+
+function createSession() {
+  return {
+    characterID: CHARACTER_ID,
+    notifications: [],
+    socket: {
+      destroyed: false,
+    },
+    _space: {
+      shipID: SHIP_ID,
+      initialStateSent: true,
+      simTimeMs: 1775000000000,
+      simFileTime: 133000000000000000,
+    },
+    sendNotification(name, source, payload) {
+      this.notifications.push({ name, source, payload });
+    },
+  };
+}
+
+function createItem(typeID, itemID, flagID = 0) {
+  const metadata = resolveItemByTypeID(typeID);
+  if (!metadata) {
+    throw new Error(`Missing item metadata for type ${typeID}.`);
+  }
+
+  return {
+    ...metadata,
+    itemID,
+    typeID,
+    flagID,
+    ownerID: 0,
+    moduleState: {
+      online: true,
+    },
+  };
+}
+
+function createHardenerEffectState(moduleItem) {
+  const effectRecord = getTypeEffectRecords(moduleItem.typeID).find(
+    (effect) => effect.effectID === ACTIVE_SHIELD_RESONANCE_EFFECT_ID,
+  );
+  if (!effectRecord) {
+    throw new Error(`Missing hardener effect for type ${moduleItem.typeID}.`);
+  }
+
+  return {
+    moduleID: moduleItem.itemID,
+    moduleFlagID: moduleItem.flagID,
+    effectID: effectRecord.effectID,
+    effectName: effectRecord.name,
+    effectRecord,
+    typeID: moduleItem.typeID,
+    isGeneric: true,
+    affectsShipDerivedState: true,
+  };
+}
+
+function readShieldResonances(entity) {
+  const attributes = entity.passiveDerivedState.attributes;
+  return Object.fromEntries(
+    SHIELD_RESONANCE_ATTRIBUTE_IDS.map((attributeID) => [
+      attributeID,
+      attributes[attributeID],
+    ]),
+  );
+}
+
+function calculateUniformDamageEHP(resourceState) {
+  const attributes = resourceState.attributes;
+  const averageResonance = (attributeIDs) => (
+    attributeIDs.reduce((sum, attributeID) => sum + attributes[attributeID], 0) /
+    attributeIDs.length
+  );
+  const shieldEHP = resourceState.shieldCapacity /
+    averageResonance([271, 274, 273, 272]);
+  const armorEHP = resourceState.armorHP /
+    averageResonance([267, 270, 269, 268]);
+  const structureEHP = resourceState.structureHP /
+    averageResonance([113, 110, 109, 111]);
+  return Math.round(shieldEHP + armorEHP + structureEHP);
+}
+
+function extractShipAttributeChanges(session) {
+  return session.notifications
+    .filter((notification) => notification.name === "OnModuleAttributeChanges")
+    .flatMap((notification) => (
+      notification.payload &&
+      notification.payload[0] &&
+      Array.isArray(notification.payload[0].items)
+        ? notification.payload[0].items
+        : []
+    ))
+    .filter((change) => (
+      Array.isArray(change) &&
+      change[0] === "OnModuleAttributeChange" &&
+      Number(change[2]) === SHIP_ID
+    ));
+}
+
+function assertResonanceChanges(changes, expectedNew, expectedOld) {
+  assert.deepStrictEqual(
+    changes.map((change) => Number(change[3])),
+    SHIELD_RESONANCE_ATTRIBUTE_IDS,
+    "The client must receive each shield resonance attribute exactly once.",
+  );
+
+  for (const change of changes) {
+    const attributeID = Number(change[3]);
+    assert.strictEqual(
+      change[5],
+      expectedNew[attributeID],
+      `Unexpected new value for attribute ${attributeID}.`,
+    );
+    assert.strictEqual(
+      change[6],
+      expectedOld[attributeID],
+      `Unexpected old value for attribute ${attributeID}.`,
+    );
+  }
+}
+
+const session = createSession();
+const hardenerItems = [
+  createItem(ENDURING_MULTISPECTRUM_SHIELD_HARDENER_TYPE_ID, 910100011, 19),
+  createItem(MULTISPECTRUM_SHIELD_HARDENER_II_TYPE_ID, 910100012, 20),
+];
+const fittedItems = [
+  ...hardenerItems,
+  ...[21, 22, 23].map((flagID, index) => (
+    createItem(LARGE_SHIELD_EXTENDER_II_TYPE_ID, 910100020 + index, flagID)
+  )),
+  ...[92, 93, 94].map((flagID, index) => (
+    createItem(
+      MEDIUM_CORE_DEFENSE_FIELD_EXTENDER_I_TYPE_ID,
+      910100030 + index,
+      flagID,
+    )
+  )),
+];
+const shipMetadata = resolveItemByTypeID(GILA_TYPE_ID);
+const skillMap = new Map([[
+  CALDARI_CRUISER_SKILL_TYPE_ID,
+  {
+    typeID: CALDARI_CRUISER_SKILL_TYPE_ID,
+    skillLevel: 5,
+    trainedSkillLevel: 5,
+    effectiveSkillLevel: 5,
+  },
+], [
+  SHIELD_MANAGEMENT_SKILL_TYPE_ID,
+  {
+    typeID: SHIELD_MANAGEMENT_SKILL_TYPE_ID,
+    skillLevel: 5,
+    trainedSkillLevel: 5,
+    effectiveSkillLevel: 5,
+  },
+], [
+  MECHANICS_SKILL_TYPE_ID,
+  {
+    typeID: MECHANICS_SKILL_TYPE_ID,
+    skillLevel: 5,
+    trainedSkillLevel: 5,
+    effectiveSkillLevel: 5,
+  },
+], [
+  HULL_UPGRADES_SKILL_TYPE_ID,
+  {
+    typeID: HULL_UPGRADES_SKILL_TYPE_ID,
+    skillLevel: 5,
+    trainedSkillLevel: 5,
+    effectiveSkillLevel: 5,
+  },
+]]);
+const entity = runtime._testing.buildRuntimeShipEntityForTesting({
+  ...shipMetadata,
+  itemID: SHIP_ID,
+  typeID: GILA_TYPE_ID,
+  ownerID: 0,
+  pilotCharacterID: 0,
+  fittedItems,
+  skillMap,
+  position: { x: 0, y: 0, z: 0 },
+  velocity: { x: 0, y: 0, z: 0 },
+}, SYSTEM_ID, { session });
+const scene = new runtime._testing.SolarSystemScene(SYSTEM_ID);
+scene.dynamicEntities.clear();
+scene.simTimeMs = session._space.simTimeMs;
+scene.dynamicEntities.set(entity.itemID, entity);
+
+const passiveBeforeActivation = readShieldResonances(entity);
+assert.deepStrictEqual(passiveBeforeActivation, EXPECTED_PASSIVE_RESONANCES);
+assert.strictEqual(
+  entity.passiveDerivedState.shieldCapacity,
+  EXPECTED_SHIELD_CAPACITY,
+  "The complete defensive fit must preserve extender, rig, and skill ordering.",
+);
+
+for (const moduleItem of hardenerItems) {
+  entity.activeModuleEffects.set(
+    moduleItem.itemID,
+    createHardenerEffectState(moduleItem),
+  );
+}
+const activationResult = scene.refreshShipEntityDerivedState(entity, {
+  session,
+  broadcast: false,
+  notifyTargeting: true,
+});
+assert.strictEqual(activationResult.success, true);
+const activeResonances = readShieldResonances(entity);
+assert.deepStrictEqual(activeResonances, EXPECTED_ACTIVE_RESONANCES);
+const activeEHP = calculateUniformDamageEHP(entity.passiveDerivedState);
+assert.strictEqual(
+  activeEHP,
+  EXPECTED_ACTIVE_EHP,
+  "The active in-space Gila must match the fitting simulator's displayed EHP.",
+);
+const activationChanges = extractShipAttributeChanges(session);
+assertResonanceChanges(
+  activationChanges,
+  EXPECTED_ACTIVE_RESONANCES,
+  EXPECTED_PASSIVE_RESONANCES,
+);
+
+session.notifications.length = 0;
+entity.activeModuleEffects.clear();
+const deactivationResult = scene.refreshShipEntityDerivedState(entity, {
+  session,
+  broadcast: false,
+  notifyTargeting: true,
+});
+assert.strictEqual(deactivationResult.success, true);
+const passiveAfterDeactivation = readShieldResonances(entity);
+assert.deepStrictEqual(passiveAfterDeactivation, EXPECTED_PASSIVE_RESONANCES);
+const deactivationChanges = extractShipAttributeChanges(session);
+assertResonanceChanges(
+  deactivationChanges,
+  EXPECTED_PASSIVE_RESONANCES,
+  EXPECTED_ACTIVE_RESONANCES,
+);
+
+session.notifications.length = 0;
+const unchangedResult = scene.refreshShipEntityDerivedState(entity, {
+  session,
+  broadcast: false,
+  notifyTargeting: true,
+});
+assert.strictEqual(unchangedResult.success, true);
+assert.deepStrictEqual(
+  extractShipAttributeChanges(session),
+  [],
+  "An unchanged derived state must not emit ship attribute notifications.",
+);
+
+console.log(JSON.stringify({
+  passiveBeforeActivation,
+  activeResonances,
+  passiveAfterDeactivation,
+  shieldCapacity: entity.passiveDerivedState.shieldCapacity,
+  activeEHP,
+  activationAttributeIDs: activationChanges.map((change) => change[3]),
+  deactivationAttributeIDs: deactivationChanges.map((change) => change[3]),
+  unchangedNotificationCount: extractShipAttributeChanges(session).length,
+}, null, 2));
diff --git a/server/scripts/verifyShipModifierOperationOrder.js b/server/scripts/verifyShipModifierOperationOrder.js
