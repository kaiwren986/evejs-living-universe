+        economyState,
+        candidate.station.stationID,
+        "science",
+      );
+      if (!pilot) continue;
+      const activity = toFiniteNumber(original.materialEfficiency, 0) < BLUEPRINT_TARGET_ME
+        ? ACTIVITY.RESEARCH_MATERIAL
