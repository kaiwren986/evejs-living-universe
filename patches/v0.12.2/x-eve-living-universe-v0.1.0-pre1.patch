+
+function normalizePositiveInteger(value, fallback = 0) {
+  const numeric = Number(value);
+  return Number.isFinite(numeric) && numeric > 0
+    ? Math.trunc(numeric)
+    : fallback;
+}
+
+function resolveRaceProgression(raceID) {
+  return RACE_PROGRESSION[normalizePositiveInteger(raceID, 1)] || RACE_PROGRESSION[1];
+}
+
+function buildStarterPlansForRace(raceID) {
+  const race = resolveRaceProgression(raceID);
+  const cruiserRequirements = [
+    ...COMMON_COMBAT_REQUIREMENTS,
+    ...race.tankRequirements,
+    ...race.weaponRequirements,
+    { typeID: race.frigateTypeID, level: 3 },
+    { typeID: race.destroyerTypeID, level: 3 },
+    { typeID: race.cruiserTypeID, level: 2 },
+    { typeID: race.sensorCompensationTypeID, level: 2 },
+    { typeID: race.mediumWeaponTypeID, level: 3 },
+  ];
+  const industryRequirements = [
+    ...INDUSTRY_REQUIREMENTS,
+    { typeID: race.industrialTypeID, level: 1 },
+  ];
+
+  return [
+    {
+      key: "cruiser",
+      name: `${race.name} Cruiser Starter`,
+      description:
+        `A focused ${race.name} combat route to Cruiser II with practical level III support, tank, weapon, navigation, fitting, targeting, drone, and rigging skills.`,
+      requirements: cruiserRequirements,
+    },
+    {
+      key: "industry",
+      name: "Mining & Industry Starter",
+      description:
+        "An alternative starter route to Mining Barge I with useful mining, manufacturing, reprocessing, drone, shield, fitting, survey, salvage, and racial industrial skills.",
+      requirements: industryRequirements,
+    },
+  ];
+}
+
+function provisionNewCharacterStarterProgression(options = {}) {
+  if (config.newCharacterStarterProgressionEnabled !== true) {
+    return { success: true, skipped: true, reason: "DISABLED" };
+  }
+
+  const characterID = normalizePositiveInteger(options.characterID, 0);
+  const stationID = normalizePositiveInteger(options.stationID, 0);
+  const characterRecord = options.characterRecord;
+  if (characterID <= 0 || stationID <= 0 || !characterRecord || typeof characterRecord !== "object") {
+    return { success: false, errorMsg: "INVALID_STARTER_PROGRESSION_CONTEXT" };
+  }
+
+  const marker = characterRecord.starterProgression &&
+    typeof characterRecord.starterProgression === "object"
+    ? { ...characterRecord.starterProgression }
+    : {};
+  const errors = [];
+  const createdPlanIDs = [];
+  let injectorGranted = marker.injectorGranted === true;
+
+  if (!injectorGranted) {
+    const injectorTypeID = normalizePositiveInteger(
+      config.newCharacterStarterSkillInjectorTypeID,
+      40520,
+    );
+    const injectorQuantity = normalizePositiveInteger(
+      config.newCharacterStarterSkillInjectorQuantity,
+      1,
+    );
+    const grantResult = grantItemsToCharacterStationHangar(characterID, stationID, [{
+      itemType: injectorTypeID,
+      quantity: injectorQuantity,
+    }]);
+    if (grantResult && grantResult.success === true) {
+      injectorGranted = true;
+      marker.injectorGranted = true;
+      marker.injectorTypeID = injectorTypeID;
+      marker.injectorQuantity = injectorQuantity;
+    } else {
+      errors.push((grantResult && grantResult.errorMsg) || "STARTER_INJECTOR_GRANT_FAILED");
+    }
+  }
+
+  const planDefinitions = buildStarterPlansForRace(options.raceID);
+  const existingPlans = Object.values(getCharacterPlanState(characterID).plans || {});
+  const existingPlanNames = new Set(existingPlans.map((plan) => plan.name));
+  for (const planDefinition of planDefinitions) {
+    if (existingPlanNames.has(planDefinition.name)) {
+      continue;
+    }
+    try {
+      const createdPlan = createPersonalPlan(characterID, planDefinition);
+      createdPlanIDs.push(createdPlan.planID);
+      existingPlanNames.add(planDefinition.name);
+    } catch (error) {
+      errors.push(error.code || error.message || "STARTER_SKILL_PLAN_CREATE_FAILED");
+    }
+  }
+
+  const allPlansSeeded = planDefinitions.every((plan) => existingPlanNames.has(plan.name));
