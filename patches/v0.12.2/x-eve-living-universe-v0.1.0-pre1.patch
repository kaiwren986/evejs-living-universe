@@ -0,0 +1,356 @@
+"use strict";
+
+const assert = require("assert/strict");
+
+const {
+  createIndustrialMiningEventHandler,
+} = require("../src/space/liveEvents/industrialMiningEventHandler");
+
+function cloneValue(value) {
+  return value === undefined ? undefined : JSON.parse(JSON.stringify(value));
+}
+
+function applyAdvance(event, result, nowMs) {
+  return {
+    ...event,
+    ...(result.patch && typeof result.patch === "object" ? cloneValue(result.patch) : {}),
+    phase: result.phase,
+    eventPhase: result.eventPhase,
+    nextTransitionAtMs: result.nextTransitionAtMs || 0,
+    updatedAtMs: nowMs,
+  };
+}
+
+function createFixture() {
+  const systemID = 30000142;
+  const persisted = {
+    101: { entityID: 101, beltID: 77, remainingQuantity: 1_000 },
+    102: { entityID: 102, beltID: 77, remainingQuantity: 750 },
+  };
+  const virtualTransactions = new Map();
+  const reservations = new Map();
+  const fleets = new Map();
+  const calls = {
+    destroyed: 0,
+    released: 0,
+    spawned: 0,
+    virtual: 0,
+    lastSpawnOptions: null,
+    sceneSyncs: 0,
+  };
+  let nextFleetID = 1;
+
+  const miningState = {
+    readPersistedSystemEntities(requestedSystemID) {
+      assert.equal(requestedSystemID, systemID);
+      return cloneValue(persisted);
+    },
+    applyPersistedMiningBatch(request, options) {
+      calls.virtual += 1;
+      assert.equal(options.isSystemSceneLoaded(request.systemID), false);
+      if (virtualTransactions.has(request.transactionID)) {
+        return cloneValue(virtualTransactions.get(request.transactionID));
+      }
+      let totalAcceptedQuantity = 0;
+      const results = [];
+      for (const allocation of request.allocations) {
+        const state = persisted[allocation.entityID];
+        const accepted = Math.min(state.remainingQuantity, allocation.requestedQuantity);
+        state.remainingQuantity -= accepted;
+        totalAcceptedQuantity += accepted;
+        results.push({
+          entityID: allocation.entityID,
+          acceptedQuantity: accepted,
+        });
+      }
+      const result = { success: true, data: { totalAcceptedQuantity, results } };
+      virtualTransactions.set(request.transactionID, cloneValue(result));
+      return result;
+    },
+    ensureSceneMiningState() {},
+    getMineableState(scene, entityID) {
+      return scene.mineableByEntityID.get(entityID) || null;
+    },
+    syncPersistedMiningBatchToScene(scene, transaction) {
+      calls.sceneSyncs += 1;
+      for (const row of transaction.results || []) {
+        if (row.acceptedQuantity > 0 && scene.mineableByEntityID.has(row.entityID)) {
+          scene.mineableByEntityID.get(row.entityID).remainingQuantity =
+            persisted[row.entityID].remainingQuantity;
+        }
+      }
+      return { success: true };
+    },
+  };
+
+  const miningOperations = {
+    spawnManagedMiningFleet(scene, options) {
+      calls.spawned += 1;
+      calls.lastSpawnOptions = cloneValue(options);
+      assert.equal(scene.systemID, systemID);
+      const fleetID = nextFleetID++;
+      const fleetRecord = {
+        fleetID,
+        operatorKind: options.operatorKind,
+        operatorID: options.operatorID,
+        minerEntityIDs: [501, 502, 503, 504],
+        haulerEntityIDs: [505],
+        responseEntityIDs: [],
+      };
+      fleets.set(fleetID, fleetRecord);
+      return {
+        success: true,
+        data: { fleetRecord, entityIDs: [501, 502, 503, 504, 505] },
+      };
+    },
+    getManagedMiningFleet(fleetID, options) {
+      const fleet = fleets.get(fleetID) || null;
+      if (
+        !fleet ||
+        fleet.operatorKind !== options.operatorKind ||
+        fleet.operatorID !== options.operatorID
+      ) {
+        return null;
+      }
+      return fleet;
+    },
+    destroyManagedMiningFleet(fleetID, options) {
+      const fleet = fleets.get(fleetID) || null;
+      if (fleet) {
+        assert.equal(fleet.operatorKind, options.operatorKind);
+        assert.equal(fleet.operatorID, options.operatorID);
+        fleets.delete(fleetID);
+        calls.destroyed += 1;
+      }
+      return { success: true, data: { fleetID, destroyedCount: fleet ? 5 : 0 } };
+    },
+    destroyManagedMiningFleetsByOwner(options) {
+      const fleetIDs = [...fleets.values()]
+        .filter((fleet) => (
+          fleet.operatorKind === options.operatorKind && fleet.operatorID === options.operatorID
+        ))
+        .map((fleet) => fleet.fleetID);
+      let destroyedCount = 0;
+      for (const fleetID of fleetIDs) {
+        const result = this.destroyManagedMiningFleet(fleetID, options);
+        destroyedCount += result.data.destroyedCount;
+      }
+      return { success: true, data: { fleetIDs, destroyedCount } };
+    },
+  };
+
+  const physicalBudget = {
+    canReserve(request) {
+      return request.shipCount <= 15 && !reservations.has(request.reservationID);
+    },
+    reserve(request) {
+      if (!this.canReserve(request)) {
+        return { success: false, reason: "LIMIT" };
+      }
+      const reservation = { ...cloneValue(request), reservedAtMs: 1 };
+      reservations.set(request.reservationID, reservation);
+      return { success: true, reservation };
+    },
+    getReservation(reservationID) {
+      return reservations.get(reservationID) || null;
+    },
+    release(reservationID) {
+      const removed = reservations.delete(reservationID);
+      if (removed) {
+        calls.released += 1;
+      }
+      return removed;
+    },
+    releaseOwner(ownerKind, ownerID) {
+      let released = 0;
+      for (const [reservationID, reservation] of [...reservations.entries()]) {
+        if (reservation.ownerKind === ownerKind && reservation.ownerID === ownerID) {
+          reservations.delete(reservationID);
+          calls.released += 1;
+          released += 1;
+        }
+      }
+      return released;
+    },
+  };
+
+  const spaceRuntime = {
+    scenes: new Map(),
+    isSolarSystemSceneLoaded(requestedSystemID) {
+      return this.scenes.has(requestedSystemID);
+    },
+  };
+  const definition = {
+    definitionID: "industrial.mining.highsec.small",
+    revision: 2,
+    eventType: "industrial_mining",
+    enabled: true,
+    lifecycle: { engagementSeconds: 1_800 },
+    limits: { physicalShips: 15, dynamicObjects: 30 },
+    content: {
+      virtualCycleSeconds: 60,
+      virtualQuantityPerCycle: 500,
+      virtualTargetsPerCycle: 4,
+      emptyCheckLimit: 3,
+      minerCount: 4,
+      haulerCount: 1,
+      lastObserverGraceSeconds: 60,
+    },
+  };
+  const event = {
+    eventID: "test-industrial-0001",
+    eventType: "industrial_mining",
+    definitionID: definition.definitionID,
+    systemID,
+    seed: 3,
+    phase: "scheduled",
+    eventPhase: "scheduled",
+    data: {},
+    metrics: {},
+  };
+  const handler = createIndustrialMiningEventHandler({
+    miningState,
+    miningOperations,
+    physicalBudget,
+    spaceRuntime,
+  });
+  return {
+    calls,
+    definition,
+    event,
+    fleets,
+    handler,
+    persisted,
+    physicalBudget,
+    reservations,
+    spaceRuntime,
+    systemID,
+  };
+}
+
+function advance(fixture, event, nowMs) {
+  const result = fixture.handler.advance({
+    event,
+    definition: fixture.definition,
+    nowMs,
+    spaceRuntime: fixture.spaceRuntime,
+  });
+  return applyAdvance(event, result, nowMs);
+}
+
+function runVerification() {
+  const fixture = createFixture();
+  const startMs = 1_700_000_000_000;
+  let event = advance(fixture, fixture.event, startMs);
+  assert.equal(event.phase, "dormant");
+  assert.equal(event.data.beltID, 77);
+
+  event = advance(fixture, event, startMs + 1);
+  assert.equal(event.eventPhase, "virtual_operation");
+  assert.equal(event.data.virtualCycle, 1);
+  assert.equal(event.data.totalVirtualMined, 500);
+  assert.equal(event.metrics.virtualUnitsMined, 500);
+  assert.equal(fixture.calls.virtual, 1);
+  assert.equal(fixture.persisted[101].remainingQuantity, 500);
+
+  const scene = {
+    systemID: fixture.systemID,
+    sessions: new Map(),
+    staticEntities: [
+      { itemID: 101, kind: "asteroid" },
+      { itemID: 102, kind: "asteroid" },
+    ],
+    mineableByEntityID: new Map([
+      [101, { entityID: 101, beltID: 77, remainingQuantity: 500 }],
+      [102, { entityID: 102, beltID: 77, remainingQuantity: 750 }],
+    ]),
+  };
+  fixture.spaceRuntime.scenes.set(fixture.systemID, scene);
+  event = advance(fixture, event, startMs + 60_001);
+  assert.equal(event.eventPhase, "virtual_operation");
+  assert.equal(fixture.calls.virtual, 2);
+  assert.equal(fixture.calls.sceneSyncs, 1);
+
+  scene.sessions.set(9001, { characterID: 9001 });
+  event = advance(fixture, event, startMs + 60_002);
+  assert.equal(event.phase, "materializing");
+  event = advance(fixture, event, startMs + 60_003);
+  assert.equal(event.phase, "active");
+  assert.equal(event.data.physicalEntityIDs.length, 5);
+  assert.equal(fixture.calls.spawned, 1);
+  assert.equal(fixture.calls.lastSpawnOptions.physicalShipLimit, 15);
+  assert.equal(fixture.calls.lastSpawnOptions.minerAmount, 4);
+  assert.equal(fixture.calls.lastSpawnOptions.haulerAmount, 1);
+  assert.equal(fixture.reservations.size, 1);
+
+  event = advance(fixture, event, startMs + 75_003);
+  assert.equal(event.phase, "active");
+  assert.equal(event.eventPhase, "observed_mining_operation");
+  scene.sessions.clear();
+  event = advance(fixture, event, startMs + 135_004);
+  assert.equal(event.phase, "dormant");
+  assert.equal(event.eventPhase, "virtual_operation");
+  assert.equal(fixture.calls.destroyed, 1);
+  assert.equal(fixture.calls.released, 1);
+  assert.equal(fixture.reservations.size, 0);
+
+  const cleanupEvent = {
+    ...event,
+    phase: "cleanup",
+    eventPhase: "cleanup",
+  };
+  const completed = advance(fixture, cleanupEvent, startMs + 135_005);
+  assert.equal(completed.phase, "completed");
+  assert.equal(completed.data.miningFleetID, 0);
+
+  const orphanEventID = "test-industrial-orphan";
+  fixture.handler.advance({
+    event: { ...fixture.event, eventID: orphanEventID },
+    definition: fixture.definition,
+    nowMs: startMs,
+    spaceRuntime: fixture.spaceRuntime,
+  });
+  fixture.spaceRuntime.scenes.get(fixture.systemID).sessions.set(9001, { characterID: 9001 });
+  const orphanSpawn = fixture.handler.advance({
+    event: {
+      ...fixture.event,
+      eventID: orphanEventID,
+      phase: "materializing",
+      data: { beltID: 77, expiresAtMs: startMs + 1_800_000 },
+    },
+    definition: fixture.definition,
+    nowMs: startMs + 1,
+    spaceRuntime: fixture.spaceRuntime,
+  });
+  assert.equal(orphanSpawn.phase, "active");
+  assert.equal(fixture.fleets.size, 1);
+  assert.equal(fixture.reservations.size, 1);
+  const recovered = advance(fixture, {
+    ...fixture.event,
+    eventID: orphanEventID,
+    phase: "recovery_pending",
+    eventPhase: "recovery_pending",
+    data: {},
+  }, startMs + 2);
+  assert.equal(recovered.phase, "dormant");
+  assert.equal(fixture.fleets.size, 0);
+  assert.equal(fixture.reservations.size, 0);
+
+  return {
+    success: true,
+    virtualUnitsMined: event.metrics.virtualUnitsMined,
+    materializedShips: 5,
+    destroyedFleets: fixture.calls.destroyed,
+    releasedReservations: fixture.calls.released,
+    orphanRecoveryVerified: true,
+  };
+}
+
+if (require.main === module) {
+  console.log(JSON.stringify(runVerification(), null, 2));
+}
+
+module.exports = {
+  createFixture,
+  runVerification,
+};
