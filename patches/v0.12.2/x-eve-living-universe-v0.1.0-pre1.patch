+param(
+  [Parameter(Mandatory = $true)]
+  [string]$ServerRoot,
+  [switch]$CheckOnly,
+  [switch]$Yes
+)
+
+$ErrorActionPreference = "Stop"
+$packageRoot = Split-Path -Parent $MyInvocation.MyCommand.Path
+$resolvedServerRoot = [System.IO.Path]::GetFullPath($ServerRoot)
+$targetPath = Join-Path $resolvedServerRoot "server\src\services\market\marketProxyService.js"
+$verifierSource = Join-Path $packageRoot "patches\verifyMarketOrderWireShape.js"
+$verifierTarget = Join-Path $resolvedServerRoot "server\scripts\verifyMarketOrderWireShape.js"
+$baselineHash = "D2CCD1ED5CB5E1B5E36712949F29661AD7A5950BB3065897E3FCE82B942EDDD1"
+$patchedHash = "7ACD5BA7EF7BA18EE1468D0CDA7C5D72946B022FC4CC577B3E1D49513F37AD89"
+$patchedCanonicalHash = "D96B1116D8638AB83973394E3926D6513AD347CCA3FCCF2238A0C4D167F91DAD"
+$utf8NoBom = New-Object System.Text.UTF8Encoding($false)
+$script:BackupDirectory = $null
+$script:MutationStarted = $false
+$script:VerifierExistedBefore = $false
+
+function Get-Sha256 {
+  param([Parameter(Mandatory = $true)][string]$Path)
+  return (Get-FileHash -Algorithm SHA256 -LiteralPath $Path).Hash.ToUpperInvariant()
+}
+
+function Normalize-Block {
+  param([Parameter(Mandatory = $true)][string]$Value)
+  $normalized = $Value.Replace("`r`n", "`n")
+  return $normalized.TrimEnd([char[]]@("`n"))
+}
+
+function Replace-ExactBlock {
+  param(
+    [Parameter(Mandatory = $true)][string]$Text,
+    [Parameter(Mandatory = $true)][string]$Old,
+    [Parameter(Mandatory = $true)][string]$New,
+    [Parameter(Mandatory = $true)][string]$Label
+  )
+
+  $first = $Text.IndexOf($Old, [System.StringComparison]::Ordinal)
+  if ($first -lt 0) {
+    throw "Patch block '$Label' was not found in the verified baseline file."
+  }
+  $second = $Text.IndexOf(
+    $Old,
+    $first + $Old.Length,
+    [System.StringComparison]::Ordinal
+  )
+  if ($second -ge 0) {
+    throw "Patch block '$Label' appeared more than once; refusing an ambiguous edit."
+  }
+
+  return $Text.Substring(0, $first) + $New + $Text.Substring($first + $Old.Length)
+}
+
+function Resolve-NodeExecutable {
+  $resolved = Get-Command node.exe -ErrorAction SilentlyContinue
+  if ($resolved -and $resolved.Source) {
+    return $resolved.Source
+  }
+  $resolved = Get-Command node -ErrorAction SilentlyContinue
+  if ($resolved -and $resolved.Source) {
+    return $resolved.Source
+  }
+  return $null
+}
+
