+"use strict";
+
+const assert = require("assert/strict");
+
+const miningOperations = require("../src/services/mining/miningNpcOperations");
+const miningState = require("../src/services/mining/miningRuntimeState");
+const asteroidService = require("../src/space/asteroids");
+const livingEconomy = require("../src/space/npc/ambientTraffic/livingEconomyRuntime");
+const livingUniverse = require("../src/space/npc/ambientTraffic/livingUniverseRuntime");
+
+function estimate(shipTypeID, modules, durationMs = 300_000, options = {}) {
+  return miningOperations.estimateNpcMiningVolume({
+    shipTypeID,
+    modules,
+    durationMs,
+    ...options,
+  });
+}
+
+function runVerification() {
+  const standardVenture = estimate(32880, [
+    { typeID: 483, quantity: 2 },
+    { typeID: 22542, quantity: 1 },
+  ]);
+  const veteranVenture = estimate(32880, [
+    { typeID: 482, quantity: 1 },
+    { typeID: 483, quantity: 1 },
+    { typeID: 22542, quantity: 1 },
+  ]);
+  const eliteRetriever = estimate(17478, [
+    { typeID: 17912, quantity: 2 },
+    { typeID: 28576, quantity: 1 },
+  ]);
+  const supportedMackinaw = estimate(22548, [
+    { typeID: 22229, quantity: 2 },
+    { typeID: 28576, quantity: 1 },
+  ], 300_000, {
+    resourceFamily: "ice",
+    supportBonus: {
+      supportClass: "orca",
+      cycleTimeMultiplier: 0.85,
+      rangeMultiplier: 1.25,
+    },
+  });
+
+  assert.equal(standardVenture.moduleCycles.length, 2);
+  assert.equal(veteranVenture.moduleCycles.length, 2);
+  assert.equal(eliteRetriever.moduleCycles.length, 2);
+  assert.ok(standardVenture.estimatedVolumeM3 > 0);
+  assert.ok(veteranVenture.estimatedVolumeM3 > standardVenture.estimatedVolumeM3);
+  assert.ok(eliteRetriever.estimatedVolumeM3 > veteranVenture.estimatedVolumeM3);
+  assert.ok(standardVenture.estimatedVolumeM3 <= standardVenture.capacityM3);
+  assert.ok(eliteRetriever.estimatedVolumeM3 <= eliteRetriever.capacityM3);
+  assert.equal(supportedMackinaw.resourceFamily, "ice");
+  assert.equal(supportedMackinaw.moduleCycles.length, 2);
+  assert.ok(supportedMackinaw.estimatedVolumeM3 > 0);
+  assert.ok(supportedMackinaw.estimatedVolumeM3 <= 35_000);
+  assert.equal(supportedMackinaw.supportBonus.supportClass, "orca");
+
+  const allocations = livingUniverse._testing.buildVirtualMiningAllocations([
+    { entityID: 101, remainingQuantity: 10_000, unitVolume: 0.1 },
+    { entityID: 102, remainingQuantity: 10_000, unitVolume: 0.15 },
+  ], 1_250);
+  assert.deepEqual(allocations, [
+    { entityID: 101, requestedQuantity: 10_000 },
+    { entityID: 102, requestedQuantity: 1_666 },
+  ]);
+
+  const outputs = livingEconomy._testing.buildNpcRefineryOutputs([
+    { typeID: 1230, typeName: "Veldspar", quantity: 1_000, volume: 0.1 },
+    { typeID: 1228, typeName: "Scordite", quantity: 1_000, volume: 0.15 },
+  ]);
+  assert.deepEqual(outputs, [
+    { typeID: 34, typeName: "Tritanium", quantity: 2_750 },
+    { typeID: 35, typeName: "Pyerite", quantity: 550 },
+  ]);
+  const iceOutputs = livingEconomy._testing.buildNpcRefineryOutputs([
+    { typeID: 16265, typeName: "White Glaze", quantity: 10, volume: 1_000 },
+  ]);
+  assert.deepEqual(
+    iceOutputs.map((entry) => entry.typeID),
+    [16272, 16273, 16275, 17888],
+    "the Halaima ice operation must feed all four governed ice products",
+  );
+
+  const population = livingUniverse._testing.buildPopulationPlan(400, 1_700_000_000_000);
+  const minerFlights = Object.values(population.flights)
+    .filter((flight) => flight.family === "miner");
+  assert.equal(minerFlights.length, 24);
+  assert.equal(minerFlights.reduce((sum, flight) => sum + flight.actorIDs.length, 0), 96);
+  const minerActors = Object.values(population.actors).filter((actor) => actor.role === "miner");
+  const supportActors = Object.values(population.actors)
+    .filter((actor) => actor.role === "mining_support");
+  assert.equal(minerActors.length, 88);
+  assert.equal(supportActors.length, 8);
+  assert.ok(supportActors.every((actor) => actor.miningSupportProfile));
+  assert.equal(minerFlights.filter((flight) => flight.resourceFamily === "ice").length, 2);
+  assert.equal(minerFlights.filter((flight) => flight.riskBand === "lowsec").length, 2);
+  assert.ok(minerFlights.every((flight) => flight.miningCycleNumber === 0));
+  assert.ok(minerFlights.every((flight) => flight.miningManifest === null));
+  livingUniverse._testing.setRuntimeStateForTest(population);
+  const firstMinerFlight = minerFlights[0];
+  const firstMinerRoute = livingUniverse._testing.getRouteDefinition(firstMinerFlight.routeID);
+  const manifestStartAtMs = population.createdAtMs + 10_000;
+  firstMinerFlight.phase = livingUniverse.PHASE.DUTY;
+  firstMinerFlight.nextTransitionAtMs = manifestStartAtMs + 60_000;
+  const firstManifest = livingUniverse._testing.ensureMiningManifest(
+    firstMinerFlight,
+    firstMinerRoute,
+    manifestStartAtMs,
+  );
+  assert.ok(
+    firstManifest.cycleID.includes(String(population.createdAtMs)),
+    "mining transaction identity must include the population run to survive pre-release resets",
+  );
+  assert.equal(
+    firstManifest.startedAtMs,
+    manifestStartAtMs,
+    "a randomized reset must not backdate mining output into time before the server run",
+  );
+
+  const authoredBelt = asteroidService.buildSystemAsteroidEntities(30000140, {
+    beltIDs: [40008922],
+  });
+  assert.equal(authoredBelt.success, true);
+  assert.deepEqual(authoredBelt.data.beltIDs, [40008922]);
+  assert.ok(authoredBelt.data.entities.length > 0);
+  const baseline = miningState._testing.buildPersistedAsteroidBaselines(
+    30000140,
+    authoredBelt.data.entities,
+    {},
+    1_700_000_000_000,
+  );
+  assert.equal(baseline.seededCount, authoredBelt.data.entities.length);
+  const firstBaseline = Object.values(baseline.entities)[0];
+  assert.equal(firstBaseline.beltID, 40008922);
+  assert.equal(firstBaseline.yieldKind, "ore");
+  assert.ok(firstBaseline.remainingQuantity > 0);
+  const preserved = {
+    ...firstBaseline,
+    remainingQuantity: firstBaseline.remainingQuantity - 1,
+  };
+  const idempotentBaseline = miningState._testing.buildPersistedAsteroidBaselines(
+    30000140,
+    authoredBelt.data.entities,
+    { [String(firstBaseline.entityID)]: preserved },
+    1_700_000_001_000,
+  );
+  assert.deepEqual(
+    idempotentBaseline.entities[String(firstBaseline.entityID)],
+    preserved,
+    "bootstrap must never replenish an existing depleted asteroid",
+  );
+
+  return {
+    success: true,
+    minerFlights: minerFlights.length,
+    minerPilots: minerActors.length,
+    supportPilots: supportActors.length,
+    fiveMinuteVolumePerHullM3: {
+      standardVenture: standardVenture.estimatedVolumeM3,
+      veteranVenture: veteranVenture.estimatedVolumeM3,
+      eliteRetriever: eliteRetriever.estimatedVolumeM3,
+      supportedMackinaw: supportedMackinaw.estimatedVolumeM3,
+    },
+    refineryExample: outputs,
+    virtualAllocationExample: allocations,
+    offGridLedgerExample: {
+      systemID: 30000140,
+      beltID: 40008922,
+      deterministicResources: authoredBelt.data.entities.length,
+      preservesExistingDepletion: true,
+    },
+  };
+}
+
+if (require.main === module) {
+  process.stdout.write(`${JSON.stringify(runVerification(), null, 2)}\n`);
+}
+
+module.exports = {
+  runVerification,
+};
diff --git a/server/scripts/verifyLivingRegionalEconomy.js b/server/scripts/verifyLivingRegionalEconomy.js
new file mode 100644
index 0000000000000000000000000000000000000000..2153e6a22c82eb356fe2d96b0dd7309f9ebee1d8
--- /dev/null
+++ b/server/scripts/verifyLivingRegionalEconomy.js
@@ -0,0 +1,146 @@
+"use strict";
+
+const assert = require("assert");
+
+const config = require("../src/config");
+config.livingUniverseEnabled = false;
+config.livingEconomyEnabled = false;
+const catalog = require("../src/space/npc/ambientTraffic/livingEconomyCatalog");
+const routePlanner = require("../src/space/npc/ambientTraffic/livingEconomyRoutePlanner");
+const procurement = require("../src/space/npc/ambientTraffic/livingEconomyProcurement");
+const economyState = require("../src/space/npc/ambientTraffic/livingEconomyState");
+const universeRuntime = require("../src/space/npc/ambientTraffic/livingUniverseRuntime");
+const marketTopology = require("../src/services/market/marketTopology");
+
+async function main() {
+  assert.ok(catalog.STATIONS.length >= 1_600);
+  assert.strictEqual(new Set(catalog.STATIONS.map((station) => station.systemID)).size, catalog.STATIONS.length);
+  assert.strictEqual(catalog.PROCUREMENT_GOODS.length, 20);
+  const racialHubs = [
+    [60003760, 1, 210],
+    [60008494, 4, 597],
+    [60011866, 8, 593],
+    [60004588, 2, 587],
+  ];
+  for (const [stationID, raceID, productTypeID] of racialHubs) {
+    const station = catalog.getStation(stationID);
+    const product = catalog.getGood(productTypeID);
+    assert.strictEqual(station.raceID, raceID);
+    assert.ok(catalog.getProducerCeiling(station, product) > 0);
+    assert.ok(racialHubs.filter((entry) => entry[1] !== raceID).every((entry) => (
+      catalog.getProducerCeiling(catalog.getStation(entry[0]), product) === 0
+    )));
+  }
+  assert.ok(universeRuntime._testing.REGIONAL_DUTY_ROUTE_SPECS.length >= 60);
+  const population = universeRuntime._testing.buildPopulationPlan(400, Date.now());
+  const minerFlights = Object.values(population.flights).filter(
+    (flight) => flight.family === "miner",
+  );
+  const minerSystems = new Set(minerFlights.map((flight) => flight.currentSystemID));
+  assert.strictEqual(minerFlights.length, 24);
+  assert.ok(minerSystems.size >= 15, "miner fleets were not distributed across New Eden");
+
+  const jita = catalog.getStation(60003760);
+  const remote = catalog.STATIONS.find((station) => (
+    station.stationID !== jita.stationID &&
+    marketTopology.getJumpCount(jita.systemID, station.systemID) >= 8
+  ));
+  assert.ok(remote, "no distant regional station was found");
+  const route = routePlanner.buildRouteSpec(jita, remote);
+  assert.ok(route && route.systemIDs.length >= 9, "regional shortest path was not built");
+  const registered = universeRuntime._testing.registerDynamicFreightRoute(route);
+  assert.ok(registered && registered.edges.length === route.systemIDs.length - 1);
+
+  const flight = {
+    flightID: "regional-economy-verify",
+    family: "hauler",
+    phase: "docked",
+    materialized: false,
+    currentSystemID: jita.systemID,
+    currentNodeIndex: 0,
+    direction: 1,
+    actorIDs: [],
+  };
+  assert.strictEqual(universeRuntime._testing.assignFreightRoute(flight, route, Date.now()), true);
+  assert.strictEqual(flight.routeID, route.routeID);
+  assert.deepStrictEqual(flight.dynamicRouteSpec.endpointStationIDs, [jita.stationID, remote.stationID]);
+
+  const veldspar = catalog.getGood(1230);
+  const stock = new Map([
+    [`${jita.stationID}:${veldspar.typeID}`, { quantity: 10_000_000, price: 8 }],
+    [`${remote.stationID}:${veldspar.typeID}`, { quantity: 0, price: 12 }],
+  ]);
+  const getStockRow = (map, stationID, typeID) => (
+    map.get(`${stationID}:${typeID}`) || { quantity: 0, price: 0 }
+  );
+  const opportunities = await routePlanner.buildRegionalOpportunities(stock, getStockRow, [{
+    orderID: "verify-order",
+    stationID: remote.stationID,
+    typeID: veldspar.typeID,
+    remainingQuantity: 1_000_000,
+    price: 12,
+    state: "open",
+  }]);
+  const candidate = routePlanner.chooseForFlight(
+    flight,
+    jita.stationID,
+    opportunities,
+    {
+      logisticsClass: route.riskBand === "lowsec" ? "secure" : "trunk",
+      capacityM3: 650_000,
+      shipmentMultiplier: 10,
+      maximumCargoValueISK: 2_500_000_000,
+      lowSecurityAccess: true,
+    },
+  );
+  assert.ok(candidate, "no capacity-aware regional freight opportunity was selected");
+  assert.ok(candidate.quantity > 0 && candidate.cargoVolume <= 650_000);
+
+  const state = economyState.buildDefaultState();
+  const stationCorporation = procurement._testing.ensureCorporation(state, jita, Date.now());
+  state.procurement.orders["verify-order"] = {
+    orderID: "verify-order",
+    corporationID: stationCorporation.corporationID,
+    stationID: jita.stationID,
+    typeID: veldspar.typeID,
+    typeName: veldspar.name,
+    price: 10,
+    enteredQuantity: 1_000,
+    remainingQuantity: 1_000,
+    escrowISK: 10_000,
+    state: "open",
+  };
+  stationCorporation.cashISK -= 10_000;
+  stationCorporation.escrowISK += 10_000;
+  const settlement = procurement.settleFill(state, {
+    orderID: "verify-order",
+    quantity: 250,
+    price: 10,
+    sellerKind: "player",
+  });
+  assert.strictEqual(settlement.success, true);
+  assert.strictEqual(state.procurement.orders["verify-order"].remainingQuantity, 750);
+  assert.strictEqual(state.procurement.orders["verify-order"].escrowISK, 7_500);
+  assert.strictEqual(state.metrics.procurementPlayerIskSpent, 2_500);
+
+  console.log(JSON.stringify({
+    ok: true,
+    regionalStations: catalog.STATIONS.length,
+    regionalMiningRoutes: universeRuntime._testing.REGIONAL_DUTY_ROUTE_SPECS.length,
+    activeMinerSystems: minerSystems.size,
+    procurementInputs: catalog.PROCUREMENT_GOODS.length,
+    routeJumps: route.systemIDs.length - 1,
+    routeRisk: route.riskBand,
+    opportunityCount: opportunities.length,
+    selectedCargoM3: candidate.cargoVolume,
+    fundedSettlement: {
+      playerPaidISK: state.metrics.procurementPlayerIskSpent,
+      remainingEscrowISK: state.procurement.orders["verify-order"].escrowISK,
+    },
+  }, null, 2));
+}
+
+main().catch((error) => {
+  console.error(error);
+  process.exitCode = 1;
+});
diff --git a/server/scripts/verifyLivingUniversePhysicalBehavior.js b/server/scripts/verifyLivingUniversePhysicalBehavior.js
