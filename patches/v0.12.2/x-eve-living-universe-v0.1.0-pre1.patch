diff --git a/server/scripts/Run-LivingUniverseCapacitySweep.ps1 b/server/scripts/Run-LivingUniverseCapacitySweep.ps1
new file mode 100644
index 0000000000000000000000000000000000000000..543b77a2ec80612687e3c9ffed930968de58b58f
--- /dev/null
+++ b/server/scripts/Run-LivingUniverseCapacitySweep.ps1
@@ -0,0 +1,237 @@
+param(
+  [Parameter(Mandatory = $true)]
+  [string]$NodePath,
+  [int[]]$PopulationSteps = @(400, 800, 1200, 2000, 3000, 4000, 5000),
+  [int]$SettleSeconds = 45,
+  [int]$SampleCount = 4,
+  [double]$WarningMs = 125,
+  [double]$HardLimitMs = 130,
+  [switch]$Execute
+)
+
+$ErrorActionPreference = 'Stop'
+$serverRoot = (Resolve-Path (Join-Path $PSScriptRoot '..')).Path
+$workspaceRoot = (Resolve-Path (Join-Path $serverRoot '..')).Path
+$telemetryPath = Join-Path $workspaceRoot '_local\runtime-performance\latest.json'
+$resultDirectory = Join-Path $workspaceRoot '_local\runtime-performance\capacity-sweeps'
+$runID = Get-Date -Format 'yyyyMMdd-HHmmss'
+$resultPath = Join-Path $resultDirectory "capacity-sweep-$runID.json"
+$latestResultPath = Join-Path $resultDirectory 'latest.json'
+
+if (-not $Execute) {
+  Write-Output "Dry run only. Add -Execute to restart the game server and test: $($PopulationSteps -join ', ')."
+  exit 0
+}
+
+New-Item -ItemType Directory -Force -Path $resultDirectory | Out-Null
+New-Item -ItemType Directory -Force -Path (Join-Path $serverRoot 'logs\capacity-sweep') | Out-Null
+
+function Get-GameServerPid {
+  $listener = Get-NetTCPConnection -State Listen -LocalPort 26000 -ErrorAction SilentlyContinue |
+    Select-Object -First 1
+  if ($listener) { return [int]$listener.OwningProcess }
+  return 0
+}
+
+function Stop-GameServer {
+  param([int]$ProcessID)
+  if ($ProcessID -le 0) { return }
+  $process = Get-Process -Id $ProcessID -ErrorAction SilentlyContinue
+  if (-not $process) { return }
+  Stop-Process -Id $ProcessID
+  try { Wait-Process -Id $ProcessID -Timeout 20 -ErrorAction Stop } catch {
+    Stop-Process -Id $ProcessID -Force -ErrorAction SilentlyContinue
+  }
+}
+
+function Checkpoint-GameStore {
+  $checkpointCode = @'
+const Database = require('./node_modules/better-sqlite3');
+const db = new Database('../_local/gameStore/gamestore.sqlite');
+db.pragma('wal_checkpoint(TRUNCATE)');
+db.close();
+'@
+  Push-Location $serverRoot
+  try {
+    Start-Sleep -Seconds 5
+    for ($attempt = 1; $attempt -le 5; $attempt += 1) {
+      & $NodePath -e $checkpointCode
+      if ($LASTEXITCODE -eq 0) { return }
+      if ($attempt -lt 5) { Start-Sleep -Seconds 5 }
+    }
+    throw "Game-store checkpoint failed after five attempts."
+  } finally {
+    Pop-Location
+  }
+}
+
+function Start-GameServer {
+  param([int]$Population)
+  $timestamp = Get-Date -Format 'yyyyMMdd-HHmmss'
+  $stdout = Join-Path $serverRoot "logs\capacity-sweep\population-$Population-$timestamp.out.log"
+  $stderr = Join-Path $serverRoot "logs\capacity-sweep\population-$Population-$timestamp.err.log"
+  $env:EVEJS_LIVING_UNIVERSE_POPULATION_SIZE = [string]$Population
+  try {
+    $process = Start-Process -FilePath $NodePath -ArgumentList @(
+      '--report-on-fatalerror',
+      '--report-uncaught-exception',
+      '--report-dir=./logs/node-reports',
+      '--max-old-space-size=8192',
+      '.'
+    ) -WorkingDirectory $serverRoot -PassThru -WindowStyle Hidden `
+      -RedirectStandardOutput $stdout -RedirectStandardError $stderr
+  } finally {
+    Remove-Item Env:EVEJS_LIVING_UNIVERSE_POPULATION_SIZE -ErrorAction SilentlyContinue
+  }
+  return @{
+    Process = $process
+    Stdout = $stdout
+    Stderr = $stderr
+    StartedAt = [DateTimeOffset]::Now
+  }
+}
+
+function Wait-ServerReady {
+  param([int]$ProcessID, [DateTimeOffset]$StartedAt)
+  $deadline = [DateTimeOffset]::Now.AddSeconds(120)
+  while ([DateTimeOffset]::Now -lt $deadline) {
+    $process = Get-Process -Id $ProcessID -ErrorAction SilentlyContinue
+    if (-not $process) { throw "Game server process $ProcessID exited during startup." }
+    $portsReady = @(26000, 26400, 5222) | ForEach-Object {
+      [bool](Get-NetTCPConnection -State Listen -LocalPort $_ -OwningProcess $ProcessID -ErrorAction SilentlyContinue)
+    }
+    if (($portsReady -notcontains $false) -and (Test-Path -LiteralPath $telemetryPath)) {
+      try {
+        $sample = Get-Content -Raw -LiteralPath $telemetryPath | ConvertFrom-Json
+        if ([int]$sample.process.pid -eq $ProcessID -and
+          [long]$sample.capturedAtMs -ge $StartedAt.ToUnixTimeMilliseconds()) {
+          return
+        }
+      } catch {}
+    }
+    Start-Sleep -Seconds 2
+  }
+  throw "Game server $ProcessID did not become ready within 120 seconds."
+}
+
+function Get-FreshSample {
+  param([int]$ProcessID, [long]$AfterCapturedAtMs)
+  $deadline = [DateTimeOffset]::Now.AddSeconds(30)
+  while ([DateTimeOffset]::Now -lt $deadline) {
+    if (Test-Path -LiteralPath $telemetryPath) {
+      try {
+        $sample = Get-Content -Raw -LiteralPath $telemetryPath | ConvertFrom-Json
+        if ([int]$sample.process.pid -eq $ProcessID -and
+          [long]$sample.capturedAtMs -gt $AfterCapturedAtMs) {
+          return $sample
+        }
+      } catch {}
+    }
+    Start-Sleep -Seconds 2
+  }
+  throw "No fresh performance sample arrived for process $ProcessID."
+}
+
+$results = @()
+$lastSafePopulation = 0
+$currentProcessID = Get-GameServerPid
+$limitReached = $false
+
+try {
+  foreach ($population in $PopulationSteps) {
+    Stop-GameServer -ProcessID $currentProcessID
+    Checkpoint-GameStore
+    $launch = Start-GameServer -Population $population
+    $currentProcessID = [int]$launch.Process.Id
+    Wait-ServerReady -ProcessID $currentProcessID -StartedAt $launch.StartedAt
+    Start-Sleep -Seconds $SettleSeconds
+
+    $samples = @()
+    $capturedAfter = 0
+    for ($sampleIndex = 0; $sampleIndex -lt $SampleCount; $sampleIndex += 1) {
+      $sample = Get-FreshSample -ProcessID $currentProcessID -AfterCapturedAtMs $capturedAfter
+      $capturedAfter = [long]$sample.capturedAtMs
+      $samples += $sample
+    }
+
+    $p95Values = @($samples | ForEach-Object { [double]$_.runtimeTick.intervalMs.p95 })
+    $averageValues = @($samples | ForEach-Object { [double]$_.runtimeTick.intervalMs.average })
+    $maximumValues = @($samples | ForEach-Object { [double]$_.runtimeTick.intervalMs.maximum })
+    $workP95Values = @($samples | ForEach-Object { [double]$_.runtimeTick.workMs.p95 })
+    $schedulerP95Values = @($samples | ForEach-Object { [double]$_.livingUniverse.scheduler.metrics.recentP95PassDurationMs })
+    $oneCoreCpuValues = @($samples | ForEach-Object { [double]$_.process.cpu.oneCorePercent })
+    $machineCpuValues = @($samples | ForEach-Object { [double]$_.process.cpu.machinePercent })
+    $hostCpuValues = @($samples | ForEach-Object { [double]$_.host.cpu.utilizationPercent })
+    $maxP95 = ($p95Values | Measure-Object -Maximum).Maximum
+    $maxAverage = ($averageValues | Measure-Object -Maximum).Maximum
+    $governorValue = [Math]::Max($maxP95, $maxAverage)
+    $classification = if ($governorValue -ge $HardLimitMs) {
+      'hard_limit'
+    } elseif ($governorValue -ge $WarningMs) {
+      'warning'
+    } else {
+      'healthy'
+    }
+    $latest = $samples[-1]
+    $row = [ordered]@{
+      population = $population
+      processID = $currentProcessID
+      classification = $classification
+      tickIntervalAverageMs = [Math]::Round(($averageValues | Measure-Object -Average).Average, 3)
+      tickIntervalAverageMaxMs = [Math]::Round($maxAverage, 3)
+      tickIntervalP95MaxMs = [Math]::Round($maxP95, 3)
+      tickIntervalMaximumMs = [Math]::Round(($maximumValues | Measure-Object -Maximum).Maximum, 3)
+      tickWorkP95MaxMs = [Math]::Round(($workP95Values | Measure-Object -Maximum).Maximum, 3)
+      schedulerP95MaxMs = [Math]::Round(($schedulerP95Values | Measure-Object -Maximum).Maximum, 3)
+      processCpuOneCoreAveragePercent = [Math]::Round(($oneCoreCpuValues | Measure-Object -Average).Average, 3)
+      processCpuMachineAveragePercent = [Math]::Round(($machineCpuValues | Measure-Object -Average).Average, 3)
+      hostCpuAveragePercent = [Math]::Round(($hostCpuValues | Measure-Object -Average).Average, 3)
+      rssMiB = [Math]::Round(([double]$latest.process.rssBytes / 1MB), 2)
+      heapUsedMiB = [Math]::Round(([double]$latest.process.heapUsedBytes / 1MB), 2)
+      flights = [int]$latest.livingUniverse.flightCount
+      materializedShips = [int]$latest.livingUniverse.materializedShips
+      persistenceIntervalMs = [int]$latest.livingUniverse.persistenceIntervalMs
+      capturedAt = [string]$latest.capturedAt
+      stdout = [string]$launch.Stdout
+      stderr = [string]$launch.Stderr
+    }
+    $results += [pscustomobject]$row
+    Write-Output ($row | ConvertTo-Json -Compress)
+
+    if ($classification -eq 'healthy') {
+      $lastSafePopulation = $population
+      continue
+    }
+    $limitReached = $true
+    break
+  }
+
+  if ($limitReached -and $lastSafePopulation -gt 0) {
+    Stop-GameServer -ProcessID $currentProcessID
+    Checkpoint-GameStore
+    $launch = Start-GameServer -Population $lastSafePopulation
+    $currentProcessID = [int]$launch.Process.Id
+    Wait-ServerReady -ProcessID $currentProcessID -StartedAt $launch.StartedAt
+  }
+
+  $summary = [ordered]@{
+    schemaVersion = 1
+    runID = $runID
+    startedAt = $runID
+    completedAt = [DateTimeOffset]::Now.ToString('o')
+    warningMs = $WarningMs
+    hardLimitMs = $HardLimitMs
+    lastSafePopulation = $lastSafePopulation
+    activePopulation = if ($limitReached) { $lastSafePopulation } else { $PopulationSteps[-1] }
+    activeProcessID = $currentProcessID
+    limitReached = $limitReached
+    results = $results
+  }
+  $json = $summary | ConvertTo-Json -Depth 8
+  Set-Content -LiteralPath $resultPath -Value $json -Encoding utf8
+  Set-Content -LiteralPath $latestResultPath -Value $json -Encoding utf8
+  Write-Output "RESULT_PATH=$resultPath"
+} catch {
+  Write-Error $_
+  throw
+}
diff --git a/server/scripts/auditLiveNpcFittedModuleDrops.js b/server/scripts/auditLiveNpcFittedModuleDrops.js
new file mode 100644
index 0000000000000000000000000000000000000000..f55c63c3dfdb1b0926f62a9d5fe346e3f3d204ca
--- /dev/null
+++ b/server/scripts/auditLiveNpcFittedModuleDrops.js
@@ -0,0 +1,212 @@
+"use strict";
+
+const npcData = require("../src/space/npc/npcData");
+const {
+  classifyModuleType,
+  resolveFittedModuleDestruction,
+  resolveNativeNpcFittedModuleRecoveryPolicy,
+  validateGovernedNpcDefinition,
+} = require("../src/space/npc/governance/npcDoctrineGovernance");
+
+function toPositiveInt(value, fallback = 0) {
+  const numeric = Math.trunc(Number(value) || 0);
+  return numeric > 0 ? numeric : fallback;
+}
+
+function buildRecoveryRecord(definition) {
+  const validation = validateGovernedNpcDefinition(definition);
+  if (!validation.success) {
+    throw new Error(
+      `${definition.profile.profileID}: ${validation.errorMsg || "governance validation failed"}`,
+    );
+  }
+  const governed = validation.data.governed === true;
+  const governance = validation.data.governance || {};
+  return {
+    profileID: definition.profile.profileID,
+    loadoutID: definition.loadout.loadoutID,
+    lootTableID: definition.profile.lootTableID,
+    entityType: definition.profile.entityType,
+    npcEntityType: definition.profile.entityType,
+    capitalNpc: definition.profile.capitalNpc === true,
+    capitalClassID: definition.profile.capitalClassID || null,
+    loadoutGoverned: governed,
+    recoverabilityPolicyID: governed ? governance.recoverabilityPolicyID : null,
+    fittedModuleDropChance: governed ? governance.fittedModuleDropChance : null,
+    fittedModuleDropChances: governed ? governance.fittedModuleDropChances : null,
+  };
+}
+
+function expandFittedModules(definition) {
+  const result = [];
+  let itemID = 1;
+  for (const moduleEntry of Array.isArray(definition.loadout.modules)
+    ? definition.loadout.modules
+    : []) {
+    const quantity = Math.max(1, toPositiveInt(moduleEntry && moduleEntry.quantity, 1));
+    for (let index = 0; index < quantity; index += 1) {
+      const classification = classifyModuleType(moduleEntry.typeID);
+      if (!classification) {
+        continue;
+      }
+      result.push({
+        itemID: itemID++,
+        typeID: classification.typeID,
+        groupID: toPositiveInt(classification.itemType.groupID, 0),
+        itemName: classification.name,
+      });
+    }
+  }
+  return result;
+}
+
+function increment(target, key, amount = 1) {
+  target[key] = Number(target[key] || 0) + amount;
+}
+
+function runAudit(options = {}) {
+  const killsPerProfile = Math.max(1, toPositiveInt(options.killsPerProfile, 2_000));
+  const seed = String(options.seed || "evejs-live-npc-fitted-module-audit");
+  const totals = {
+    profiles: 0,
+    profilesWithFittedModules: 0,
+    destructionEvents: 0,
+    fittedModuleRolls: 0,
+    droppedModules: 0,
+    droppedTechOne: 0,
+    droppedTechTwo: 0,
+    droppedSpecialGrade: 0,
+    droppedBasePrice: 0,
+    protectedPolicyDrops: 0,
+    protectedTypeDrops: 0,
+  };
+  const policyStats = {};
+  const droppedTypes = {};
+  const profiles = [];
+
+  for (const profile of npcData.listNpcProfiles()) {
+    const definition = npcData.buildNpcDefinition(profile.profileID);
+    if (!definition) {
+      continue;
+    }
+    totals.profiles += 1;
+    const fittedItems = expandFittedModules(definition);
+    if (fittedItems.length === 0) {
+      continue;
+    }
+    totals.profilesWithFittedModules += 1;
+    const record = buildRecoveryRecord(definition);
+    const policy = resolveNativeNpcFittedModuleRecoveryPolicy(record);
+    const profileResult = {
+      profileID: profile.profileID,
+      loadoutID: definition.loadout.loadoutID,
+      policyID: policy.policyID,
+      protectedReason: policy.protectedReason,
+      fittedModuleCount: fittedItems.length,
+      destructionEvents: killsPerProfile,
+      droppedModules: 0,
+      droppedTechOne: 0,
+      droppedTechTwo: 0,
+      droppedSpecialGrade: 0,
+    };
+    if (!policyStats[policy.policyID]) {
+      policyStats[policy.policyID] = {
+        profileCount: 0,
+        destructionEvents: 0,
+        fittedModuleRolls: 0,
+        droppedModules: 0,
+      };
+    }
+    policyStats[policy.policyID].profileCount += 1;
+
+    for (let killIndex = 0; killIndex < killsPerProfile; killIndex += 1) {
+      const result = resolveFittedModuleDestruction(fittedItems, {
+        dropChances: policy.dropChances,
+        seed: `${seed}:${profile.profileID}:${killIndex}`,
+      });
+      totals.destructionEvents += 1;
+      totals.fittedModuleRolls += fittedItems.length;
+      policyStats[policy.policyID].destructionEvents += 1;
+      policyStats[policy.policyID].fittedModuleRolls += fittedItems.length;
+      for (const item of result.dropped) {
+        totals.droppedModules += 1;
+        profileResult.droppedModules += 1;
+        policyStats[policy.policyID].droppedModules += 1;
+        if (item.recoveryGrade === "techOne") {
+          totals.droppedTechOne += 1;
+          profileResult.droppedTechOne += 1;
+        } else if (item.recoveryGrade === "techTwo") {
+          totals.droppedTechTwo += 1;
+          profileResult.droppedTechTwo += 1;
+        } else {
+          totals.droppedSpecialGrade += 1;
+          profileResult.droppedSpecialGrade += 1;
+        }
+        if (policy.protectedReason) {
+          totals.protectedPolicyDrops += 1;
+        }
+        if (item.nonRecoverableReason) {
+          totals.protectedTypeDrops += 1;
+        }
+        const classification = classifyModuleType(item.typeID);
+        totals.droppedBasePrice += Number(classification && classification.basePrice || 0);
+        if (!droppedTypes[item.typeID]) {
+          droppedTypes[item.typeID] = {
+            typeID: item.typeID,
+            name: item.itemName,
+            recoveryGrade: item.recoveryGrade,
+            drops: 0,
+          };
+        }
+        increment(droppedTypes[item.typeID], "drops");
+      }
+    }
+    profiles.push(profileResult);
+  }
+
+  const safety = {
+    specialGradeDrops: totals.droppedSpecialGrade,
+    protectedPolicyDrops: totals.protectedPolicyDrops,
+    protectedTypeDrops: totals.protectedTypeDrops,
+  };
+  const passed =
+    totals.droppedTechOne > 0 &&
+    totals.droppedTechTwo > 0 &&
+    Object.values(safety).every((value) => value === 0);
+  return {
+    passed,
+    seed,
+    killsPerProfile,
+    totals: {
+      ...totals,
+      droppedBasePrice: Number(totals.droppedBasePrice.toFixed(2)),
+      averageDroppedBasePricePerDestruction: Number(
+        (totals.droppedBasePrice / Math.max(1, totals.destructionEvents)).toFixed(2),
+      ),
+    },
+    safety,
+    policies: policyStats,
+    topDroppedTypes: Object.values(droppedTypes)
+      .sort((left, right) => right.drops - left.drops || left.typeID - right.typeID)
+      .slice(0, 25),
+    profiles: profiles.sort(
+      (left, right) => right.droppedModules - left.droppedModules ||
+        left.profileID.localeCompare(right.profileID),
+    ),
+  };
+}
+
+if (require.main === module) {
+  const killsArgumentIndex = process.argv.indexOf("--kills-per-profile");
+  const seedArgumentIndex = process.argv.indexOf("--seed");
+  const result = runAudit({
+    killsPerProfile: killsArgumentIndex >= 0 ? process.argv[killsArgumentIndex + 1] : undefined,
+    seed: seedArgumentIndex >= 0 ? process.argv[seedArgumentIndex + 1] : undefined,
+  });
+  console.log(JSON.stringify(result, null, 2));
+  process.exitCode = result.passed ? 0 : 1;
+}
+
+module.exports = {
+  runAudit,
+};
diff --git a/server/scripts/auditLivingEconomyTransit.js b/server/scripts/auditLivingEconomyTransit.js
new file mode 100644
index 0000000000000000000000000000000000000000..f443b0129ef6f560cc390181422e463ad4195f41
--- /dev/null
+++ b/server/scripts/auditLivingEconomyTransit.js
@@ -0,0 +1,83 @@
+"use strict";
+
+process.env.EVEJS_SKIP_NPC_STARTUP = "1";
+process.env.EVEJS_LIVING_UNIVERSE_ENABLED = "false";
+process.env.EVEJS_LIVING_ECONOMY_ENABLED = "false";
+
+const path = require("path");
+
+const economyStateStore = require(path.join(
+  __dirname,
+  "../src/space/npc/ambientTraffic/livingEconomyState",
+));
+const universeStateStore = require(path.join(
+  __dirname,
+  "../src/space/npc/ambientTraffic/livingUniverseState",
+));
+const livingUniverseRuntime = require(path.join(
+  __dirname,
+  "../src/space/npc/ambientTraffic/livingUniverseRuntime",
+));
+
+function seconds(milliseconds) {
+  return Math.round(Number(milliseconds || 0) / 100) / 10;
+}
+
+function main() {
+  const economy = economyStateStore.readState();
+  const universe = universeStateStore.readState();
+  livingUniverseRuntime._testing.setRuntimeStateForTest(universe);
+
+  const rows = [];
+  const skipped = [];
+  for (const job of Object.values(economy.jobs || {}).filter(
+    (candidate) => candidate.status === "delivered",
+  )) {
+    const route = livingUniverseRuntime._testing.getRouteDefinition(job.routeID);
+    const flight = universe.flights && universe.flights[job.assignedFlightID];
+    if (!route || !flight || !job.arrivedAtMs || !job.createdAtMs) {
+      skipped.push(job.jobID);
+      continue;
+    }
+    const direction = Number(job.sourceStationID) === Number(route.endpointStationIDs[0])
+      ? 1
+      : -1;
+    const estimate = livingUniverseRuntime._testing.estimateNetworkTrip(
+      route,
+      { ...flight, direction },
+    );
+    const travelMs = Number(job.arrivedAtMs) - Number(job.createdAtMs);
+    const commitMs = Number(job.completedAtMs || job.arrivedAtMs) - Number(job.arrivedAtMs);
+    rows.push({
+      jobID: job.jobID,
+      routeID: job.routeID,
+      travelSeconds: seconds(travelMs),
+      modeledSeconds: seconds(estimate.totalMs),
+      schedulerSlackSeconds: seconds(travelMs - estimate.totalMs),
+      deliveryCommitSeconds: seconds(commitMs),
+      notEarly: travelMs + 2 >= estimate.totalMs,
+    });
+  }
+
+  const violations = rows.filter((row) => !row.notEarly);
+  console.log(JSON.stringify({
+    auditedAt: new Date().toISOString(),
+    deliveredJobsChecked: rows.length,
+    skippedJobs: skipped,
+    earlyArrivalViolations: violations.length,
+    minimumSchedulerSlackSeconds: rows.length
+      ? Math.min(...rows.map((row) => row.schedulerSlackSeconds))
+      : null,
+    maximumSchedulerSlackSeconds: rows.length
+      ? Math.max(...rows.map((row) => row.schedulerSlackSeconds))
+      : null,
+    routes: [...new Set(rows.map((row) => row.routeID))].sort(),
+    sample: rows.slice(0, 20),
+  }, null, 2));
+
+  if (violations.length > 0 || skipped.length > 0) {
+    process.exitCode = 1;
+  }
+}
+
+main();
diff --git a/server/scripts/bootstrapLivingEconomyMarket.js b/server/scripts/bootstrapLivingEconomyMarket.js
new file mode 100644
index 0000000000000000000000000000000000000000..11856b6916e65b7a7224a466f8e9ad74442bcbeb
--- /dev/null
+++ b/server/scripts/bootstrapLivingEconomyMarket.js
@@ -0,0 +1,433 @@
+"use strict";
+
+const fs = require("fs");
+const path = require("path");
+const { spawnSync } = require("child_process");
+const Database = require("better-sqlite3");
+
+const catalog = require(path.join(
+  __dirname,
+  "../src/space/npc/ambientTraffic/livingEconomyCatalog",
+));
+
+const REPO_ROOT = path.resolve(__dirname, "../..");
+const DEFAULT_DATABASE_PATH = path.join(
+  REPO_ROOT,
+  "externalservices/market-server/data/generated/market.sqlite",
+);
+const BACKUP_ROOT = path.join(REPO_ROOT, "_local/living-economy-backups");
+const THE_FORGE_REGION_ID = 10000002;
+
+function parseArguments(argv) {
+  const result = {
+    apply: false,
+    databasePath: DEFAULT_DATABASE_PATH,
+    skipBackup: false,
+    skipRegionRebuild: false,
+    totalReset: false,
+  };
+  for (let index = 0; index < argv.length; index += 1) {
+    const argument = String(argv[index] || "");
+    if (argument === "--apply") {
+      result.apply = true;
+    } else if (argument === "--skip-backup") {
+      result.skipBackup = true;
+    } else if (argument === "--skip-region-rebuild") {
+      result.skipRegionRebuild = true;
+    } else if (argument === "--total-reset") {
+      result.totalReset = true;
+    } else if (argument === "--database" && argv[index + 1]) {
+      result.databasePath = path.resolve(argv[index + 1]);
+      index += 1;
+    }
+  }
+  return result;
+}
+
+function timestampForPath() {
+  return new Date().toISOString().replace(/[:.]/g, "-");
+}
+
+function computePrice(good, station, quantity) {
+  const target = Math.max(1, catalog.getTargetQuantity(station, good));
+  const stockRatio = Math.max(0, Number(quantity || 0) / target);
+  const multiplier = Math.max(0.8, Math.min(1.6, 1 + ((1 - stockRatio) * 0.35)));
+  return Math.max(0.01, Math.round(good.priceAnchor * multiplier * 100) / 100);
+}
+
+function getPilotSystemIDs() {
+  return [...new Set(catalog.STATIONS.map((station) => station.systemID))]
+    .sort((left, right) => left - right);
+}
+
+function buildPlaceholders(values) {
+  return values.map(() => "?").join(",");
+}
+
+function ensureAdjustmentTable(db) {
+  db.exec(`
+    CREATE TABLE IF NOT EXISTS seed_stock_adjustments (
+      adjustment_id TEXT PRIMARY KEY,
+      station_id INTEGER NOT NULL,
+      solar_system_id INTEGER NOT NULL,
+      region_id INTEGER NOT NULL,
+      type_id INTEGER NOT NULL,
+      delta_quantity INTEGER,
+      quantity_after INTEGER NOT NULL,
+      price_after REAL NOT NULL,
+      reason TEXT,
+      applied_at TEXT NOT NULL
+    ) WITHOUT ROWID;
+  `);
+}
+
+function rebuildSystemSeedSummaries(db, systemIDs, updatedAt) {
+  const deleteRows = db.prepare(
+    `DELETE FROM system_seed_summaries WHERE solar_system_id IN (${buildPlaceholders(systemIDs)})`,
+  );
+  deleteRows.run(...systemIDs);
+  const rebuild = db.prepare(`
+    INSERT INTO system_seed_summaries (
+      solar_system_id, type_id, best_ask_price, total_ask_quantity,
+      best_ask_station_id, best_bid_price, total_bid_quantity,
+      best_bid_station_id, updated_at
+    )
+    WITH type_rows AS (
+      SELECT type_id FROM seed_stock
+      WHERE solar_system_id = @systemID AND quantity > 0
+      UNION
+      SELECT type_id FROM seed_buy_orders
+      WHERE solar_system_id = @systemID AND quantity > 0
+    )
+    SELECT
+      @systemID,
+      type_rows.type_id,
+      (
+        SELECT MIN(price) FROM seed_stock
+        WHERE solar_system_id = @systemID AND type_id = type_rows.type_id AND quantity > 0
+      ),
+      COALESCE((
+        SELECT SUM(quantity) FROM seed_stock
+        WHERE solar_system_id = @systemID AND type_id = type_rows.type_id AND quantity > 0
+      ), 0),
+      (
+        SELECT station_id FROM seed_stock
+        WHERE solar_system_id = @systemID AND type_id = type_rows.type_id AND quantity > 0
+        ORDER BY price ASC, station_id ASC LIMIT 1
+      ),
+      (
+        SELECT MAX(price) FROM seed_buy_orders
+        WHERE solar_system_id = @systemID AND type_id = type_rows.type_id AND quantity > 0
+      ),
+      COALESCE((
+        SELECT SUM(quantity) FROM seed_buy_orders
+        WHERE solar_system_id = @systemID AND type_id = type_rows.type_id AND quantity > 0
+      ), 0),
+      (
+        SELECT station_id FROM seed_buy_orders
+        WHERE solar_system_id = @systemID AND type_id = type_rows.type_id AND quantity > 0
+        ORDER BY price DESC, station_id ASC LIMIT 1
+      ),
+      @updatedAt
+    FROM type_rows
+  `);
+  for (const systemID of systemIDs) {
+    rebuild.run({ systemID, updatedAt });
+  }
+}
+
+function updateManifest(db, updatedAt, systemIDs, options = {}) {
+  const row = db.prepare("SELECT value FROM manifest WHERE key = 'manifest_json'").get();
+  if (!row || !row.value) {
+    return;
+  }
+  const manifest = JSON.parse(row.value);
+  if (options.totalReset === true) {
+    manifest.generated_at = updatedAt;
+    manifest.selection_label = "EveJS living economy base reset";
+    manifest.selection_mode = "living_economy_base";
+    manifest.seed_row_count = catalog.STATIONS.reduce((total, station) => (
+      total + catalog.GOODS.filter((good) => catalog.getTargetQuantity(station, good) > 0).length
+    ), 0);
+    manifest.seed_buy_orders_enabled = false;
+    manifest.history_days_seeded = 0;
+  }
+  manifest.living_economy_pilot = {
+    revision: options.totalReset === true ? 2 : 1,
+    applied_at: updatedAt,
+    region_id: THE_FORGE_REGION_ID,
+    region_ids: catalog.ECONOMY_REGION_IDS,
+    system_ids: systemIDs,
+    station_ids: catalog.STATIONS.map((station) => station.stationID),
+    goods: catalog.GOODS.map((good) => ({
+      type_id: good.typeID,
+      name: good.name,
+      category: good.category,
+      price_anchor: good.priceAnchor,
+    })),
+    policy: {
+      reset_scope: options.totalReset === true ? "entire-universe" : "pilot-systems",
+      imported_seed_stock: options.totalReset === true
+        ? "cleared-universe-wide"
+        : "cleared-in-pilot-systems",
+      imported_seed_buy_orders: options.totalReset === true
+        ? "cleared-universe-wide"
+        : "cleared-in-pilot-systems",
+      market_orders: options.totalReset === true ? "cleared" : "preserved",
+      market_order_events: options.totalReset === true ? "cleared" : "preserved",
+      imported_price_history: options.totalReset === true ? "cleared" : "preserved",
+      station_supply: "curated T1/basic targets",
+      freight_conservation: "source reservation then destination delivery",
+    },
+  };
+  db.prepare("UPDATE manifest SET value = ? WHERE key = 'manifest_json'")
+    .run(JSON.stringify(manifest, null, 2));
+}
+
+function summarizeTable(db, tableName, whereClause = "", parameters = []) {
+  return db.prepare(`
+    SELECT COUNT(*) AS rows,
+           SUM(CASE WHEN quantity > 0 THEN 1 ELSE 0 END) AS stocked_rows,
+           SUM(quantity) AS quantity
+    FROM ${tableName} ${whereClause}
+  `).get(...parameters);
+}
+
+function buildPlan(db, options = {}) {
+  const pilotSystemIDs = getPilotSystemIDs();
+  const systemIDs = options.totalReset === true
+    ? db.prepare("SELECT DISTINCT solar_system_id FROM stations ORDER BY solar_system_id")
+      .all().map((row) => Number(row.solar_system_id))
+    : pilotSystemIDs;
+  const pilotStations = db.prepare(
+    `SELECT station_id, solar_system_id, constellation_id, region_id, station_name
+     FROM stations WHERE station_id IN (${buildPlaceholders(catalog.STATIONS)})`,
+  ).all(...catalog.STATIONS.map((station) => station.stationID));
+  const stationsByID = new Map(pilotStations.map((station) => [station.station_id, station]));
+  const marketTypes = db.prepare(
+    `SELECT type_id, name FROM market_types
+     WHERE type_id IN (${buildPlaceholders(catalog.GOODS)})`,
+  ).all(...catalog.GOODS.map((good) => good.typeID));
+  const typesByID = new Map(marketTypes.map((entry) => [entry.type_id, entry]));
+
+  const missingStations = catalog.STATIONS.filter((station) => !stationsByID.has(station.stationID));
+  const missingTypes = catalog.GOODS.filter((good) => !typesByID.has(good.typeID));
+  if (missingStations.length > 0 || missingTypes.length > 0) {
+    throw new Error(
+      `Pilot catalog validation failed: missing stations [${missingStations.map((entry) => entry.stationID).join(", ")}], ` +
+      `missing types [${missingTypes.map((entry) => entry.typeID).join(", ")}]`,
+    );
+  }
+
+  const rows = [];
+  for (const station of catalog.STATIONS) {
+    const metadata = stationsByID.get(station.stationID);
+    for (const good of catalog.GOODS) {
+      const targetQuantity = catalog.getTargetQuantity(station, good);
+      if (targetQuantity <= 0) {
+        continue;
+      }
+      const initialQuantity = catalog.getInitialQuantity(station, good);
+      rows.push({
+        station,
+        metadata,
+        good,
+        targetQuantity,
+        initialQuantity,
+        price: computePrice(good, station, initialQuantity),
+      });
+    }
+  }
+
+  const whereClause = options.totalReset === true
+    ? ""
+    : `WHERE solar_system_id IN (${buildPlaceholders(systemIDs)})`;
+  const parameters = options.totalReset === true ? [] : systemIDs;
+  const before = {
+    seedStock: summarizeTable(db, "seed_stock", whereClause, parameters),
+    seedBuyOrders: summarizeTable(db, "seed_buy_orders", whereClause, parameters),
+    marketOrders: db.prepare("SELECT COUNT(*) AS rows FROM market_orders").get(),
+    marketOrderEvents: db.prepare("SELECT COUNT(*) AS rows FROM market_order_events").get(),
+    priceHistory: db.prepare("SELECT COUNT(*) AS rows FROM price_history").get(),
+  };
+  return { systemIDs, pilotSystemIDs, rows, before };
+}
+
+function applyPlan(db, plan, options = {}) {
+  const updatedAt = new Date().toISOString();
+  const systemPlaceholders = buildPlaceholders(plan.systemIDs);
+  const stationIDs = catalog.STATIONS.map((station) => station.stationID);
+  const transaction = db.transaction(() => {
+    ensureAdjustmentTable(db);
+    if (options.totalReset === true) {
+      db.exec(`
+        DELETE FROM market_order_events;
+        DELETE FROM market_orders;
+        DELETE FROM price_history;
+        DELETE FROM seed_stock_adjustments;
+        DELETE FROM system_seed_summaries;
+        DELETE FROM region_summaries;
+        DELETE FROM seed_buy_orders;
+        DELETE FROM seed_stock;
+      `);
+    } else {
+      db.prepare(
+        `UPDATE seed_stock SET quantity = 0, initial_quantity = 0, updated_at = ?
+         WHERE solar_system_id IN (${systemPlaceholders})`,
+      ).run(updatedAt, ...plan.systemIDs);
+      db.prepare(
+        `UPDATE seed_buy_orders SET quantity = 0, initial_quantity = 0, updated_at = ?
+         WHERE solar_system_id IN (${systemPlaceholders})`,
+      ).run(updatedAt, ...plan.systemIDs);
+      db.prepare(
+        `DELETE FROM seed_stock_adjustments WHERE station_id IN (${buildPlaceholders(stationIDs)})`,
+      ).run(...stationIDs);
+    }
+
+    const upsert = db.prepare(`
+      INSERT INTO seed_stock (
+        station_id, solar_system_id, constellation_id, region_id, type_id,
+        price, quantity, initial_quantity, price_version, updated_at
+      ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, 1, ?)
+      ON CONFLICT(station_id, type_id) DO UPDATE SET
+        solar_system_id = excluded.solar_system_id,
+        constellation_id = excluded.constellation_id,
+        region_id = excluded.region_id,
+        price = excluded.price,
+        quantity = excluded.quantity,
+        initial_quantity = excluded.initial_quantity,
+        price_version = seed_stock.price_version + 1,
+        updated_at = excluded.updated_at
+    `);
+    for (const row of plan.rows) {
+      upsert.run(
+        row.station.stationID,
+        row.metadata.solar_system_id,
+        row.metadata.constellation_id,
+        row.metadata.region_id,
+        row.good.typeID,
+        row.price,
+        row.initialQuantity,
+        row.initialQuantity,
+        updatedAt,
+      );
+    }
+    rebuildSystemSeedSummaries(db, plan.pilotSystemIDs, updatedAt);
+    updateManifest(db, updatedAt, plan.pilotSystemIDs, options);
+  });
+  transaction();
+
+  const after = {
+    seedStock: summarizeTable(db, "seed_stock"),
+    seedBuyOrders: summarizeTable(db, "seed_buy_orders"),
+    marketOrders: db.prepare("SELECT COUNT(*) AS rows FROM market_orders").get(),
+    marketOrderEvents: db.prepare("SELECT COUNT(*) AS rows FROM market_order_events").get(),
+    priceHistory: db.prepare("SELECT COUNT(*) AS rows FROM price_history").get(),
+  };
+  return { updatedAt, after };
+}
+
+function rebuildRegionSummaries(totalReset = false) {
+  const executable = path.join(
+    REPO_ROOT,
+    "tools/market-seed/target/release/market-seed.exe",
+  );
+  const configPath = path.join(
+    REPO_ROOT,
+    "tools/market-seed/config/market-seed.local.toml",
+  );
+  if (!fs.existsSync(executable)) {
+    return {
+      success: false,
+      message: "market-seed.exe is not built; rebuild region summaries before starting the market server",
+    };
+  }
+  const argumentsList = ["--config", configPath, "rebuild-summaries"];
+  if (totalReset !== true) {
+    argumentsList.push("--region-id", String(THE_FORGE_REGION_ID));
+  }
+  const result = spawnSync(
+    executable,
+    argumentsList,
+    {
+      cwd: path.join(REPO_ROOT, "tools/market-seed"),
+      encoding: "utf8",
+      windowsHide: true,
+    },
+  );
+  return {
+    success: result.status === 0,
+    status: result.status,
+    stdout: String(result.stdout || "").trim(),
+    stderr: String(result.stderr || "").trim(),
+  };
+}
+
+async function main() {
+  const options = parseArguments(process.argv.slice(2));
+  if (!fs.existsSync(options.databasePath)) {
+    throw new Error(`Market database not found: ${options.databasePath}`);
+  }
+  const db = new Database(options.databasePath);
+  db.pragma("busy_timeout = 5000");
+  const plan = buildPlan(db, options);
+
+  const report = {
+    mode: options.apply ? "apply" : "dry-run",
+    scope: options.totalReset === true ? "entire-universe" : "pilot-systems",
+    databasePath: options.databasePath,
+    resetSystems: plan.systemIDs.length,
+    pilotSystems: plan.pilotSystemIDs.length,
+    stations: catalog.STATIONS.length,
+    goods: catalog.GOODS.length,
+    curatedRows: plan.rows.length,
+    before: plan.before,
+  };
+
+  if (!options.apply) {
+    db.close();
+    console.log(JSON.stringify(report, null, 2));
+    console.log("Dry run only. Re-run with --apply while the game and market servers are stopped.");
+    return;
+  }
+
+  if (!options.skipBackup) {
+    const backupDirectory = path.join(BACKUP_ROOT, timestampForPath());
+    fs.mkdirSync(backupDirectory, { recursive: true });
+    const backupPath = path.join(backupDirectory, "market.sqlite");
+    await db.backup(backupPath);
+    report.backupPath = backupPath;
+  }
+
+  const applied = applyPlan(db, plan, options);
+  db.close();
+  report.appliedAt = applied.updatedAt;
+  report.after = applied.after;
+
+  // Freight job IDs restart at LEF-000001 after a pilot bootstrap. Remove the
+  // matching Node-side ledger while the game server is offline.
+  if (path.resolve(options.databasePath) === path.resolve(DEFAULT_DATABASE_PATH)) {
+    try {
+      const economyState = require(path.join(
+        __dirname,
+        "../src/space/npc/ambientTraffic/livingEconomyState",
+      ));
+      report.economyStateReset = Boolean(economyState.removeState().success);
+    } catch (error) {
+      report.economyStateReset = false;
+      report.economyStateResetError = error.message;
+    }
+  } else {
+    report.economyStateReset = "skipped-for-nondefault-database";
+  }
+
+  if (!options.skipRegionRebuild) {
+    report.regionSummaryRebuild = rebuildRegionSummaries(options.totalReset);
+  }
+  console.log(JSON.stringify(report, null, 2));
+}
+
+main().catch((error) => {
+  console.error(error.stack || error.message);
+  process.exitCode = 1;
+});
