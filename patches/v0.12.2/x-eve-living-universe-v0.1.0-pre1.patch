@@ -0,0 +1,646 @@
+"use strict";
+
+const fs = require("fs");
+const path = require("path");
+
+const {
+  GENERIC_RANDOM_LOOT_TABLE_ID,
+  chooseWeighted,
+  classifyModuleType,
+  createDeterministicRng,
+  resolveCargoDestruction,
+  resolveFittedModuleDestruction,
+  validateDoctrine,
+} = require("../src/space/npc/governance/npcDoctrineGovernance");
+const {
+  CARGO_PROFILES,
+  DOCTRINE_REVISION,
+  TRAFFIC_DOCTRINES,
+  TRAFFIC_LOOT_TABLES,
+  selectJitaDoctrineForActor,
+} = require("../src/space/npc/governance/trafficDoctrineCatalog");
+const npcData = require("../src/space/npc/npcData");
+const {
+  resolveItemByTypeID,
+} = require("../src/services/inventory/itemTypeRegistry");
+
+const DEFAULT_COUNT = 100_000;
+const DEFAULT_SEED = "jita-phase3-governance-v1";
+
+function parseArgs(argv) {
+  const options = {
+    count: DEFAULT_COUNT,
+    seed: DEFAULT_SEED,
+    reportPath: null,
+    jsonPath: null,
+  };
+  for (let index = 0; index < argv.length; index += 1) {
+    const arg = String(argv[index] || "");
+    if (arg === "--count") {
+      options.count = Math.max(1, Math.trunc(Number(argv[++index]) || DEFAULT_COUNT));
+    } else if (arg === "--seed") {
+      options.seed = String(argv[++index] || DEFAULT_SEED);
+    } else if (arg === "--report") {
+      options.reportPath = path.resolve(String(argv[++index] || ""));
+    } else if (arg === "--json") {
+      options.jsonPath = path.resolve(String(argv[++index] || ""));
+    } else if (arg === "--help" || arg === "-h") {
+      options.help = true;
+    } else {
+      throw new Error(`Unknown argument: ${arg}`);
+    }
+  }
+  return options;
+}
+
+function increment(record, key, amount = 1) {
+  const normalizedKey = String(key);
+  record[normalizedKey] = (Number(record[normalizedKey]) || 0) + Number(amount || 0);
+}
+
+function randomIntInclusive(minimum, maximum, rng) {
+  const min = Math.trunc(Number(minimum) || 0);
+  const max = Math.max(min, Math.trunc(Number(maximum) || min));
+  return min + Math.floor(rng() * ((max - min) + 1));
+}
+
+function chooseWithoutReplacement(entries, count, rng) {
+  const candidates = [...(Array.isArray(entries) ? entries : [])];
+  const selected = [];
+  while (selected.length < count && candidates.length > 0) {
+    const index = Math.min(candidates.length - 1, Math.floor(rng() * candidates.length));
+    selected.push(candidates[index]);
+    candidates.splice(index, 1);
+  }
+  return selected;
+}
+
+function buildCargoManifest(role, rng) {
+  const profile = CARGO_PROFILES[role] || [];
+  if (profile.length === 0) {
+    return [];
+  }
+  const stackCount = role === "hauler"
+    ? randomIntInclusive(2, Math.min(4, profile.length), rng)
+    : 1;
+  return chooseWithoutReplacement(profile, stackCount, rng).map((entry, index) => ({
+    itemID: -10_000 - index,
+    typeID: entry.typeID,
+    quantity: randomIntInclusive(entry.minQuantity, entry.maxQuantity, rng),
+    singleton: false,
+  }));
+}
+
+function rollExplicitLootTable(lootTable, rng) {
+  if (!lootTable) {
+    return [];
+  }
+  const count = randomIntInclusive(lootTable.minEntries, lootTable.maxEntries, rng);
+  const candidates = [...(Array.isArray(lootTable.entries) ? lootTable.entries : [])];
+  const drops = [];
+  for (let index = 0; index < count && candidates.length > 0; index += 1) {
+    const chosen = chooseWeighted(candidates, rng);
+    if (!chosen) {
+      break;
+    }
+    drops.push({
+      typeID: chosen.typeID,
+      quantity: randomIntInclusive(chosen.minQuantity || 1, chosen.maxQuantity || 1, rng),
+    });
+    if (lootTable.allowDuplicates !== true) {
+      const chosenIndex = candidates.indexOf(chosen);
+      if (chosenIndex >= 0) {
+        candidates.splice(chosenIndex, 1);
+      }
+    }
+  }
+  return drops;
+}
+
+function findLatestMarketSnapshot() {
+  const snapshotDirectory = path.resolve(__dirname, "../../_local/market-universe-mirror/snapshots");
+  if (!fs.existsSync(snapshotDirectory)) {
+    return null;
+  }
+  const filenames = fs.readdirSync(snapshotDirectory)
+    .filter((filename) => filename.endsWith(".sqlite"))
+    .sort();
+  return filenames.length > 0
+    ? path.join(snapshotDirectory, filenames[filenames.length - 1])
+    : null;
+}
+
+function buildPriceResolver() {
+  const snapshotPath = findLatestMarketSnapshot();
+  let database = null;
+  let statement = null;
+  if (snapshotPath) {
+    try {
+      const Database = require("better-sqlite3");
+      database = new Database(snapshotPath, { readonly: true, fileMustExist: true });
+      statement = database.prepare(
+        "SELECT adjusted_price AS adjustedPrice, average_price AS averagePrice FROM reference_prices WHERE type_id = ?",
+      );
+    } catch (_error) {
+      database = null;
+      statement = null;
+    }
+  }
+
+  const cache = new Map();
+  function resolve(typeID) {
+    const numericTypeID = Math.trunc(Number(typeID) || 0);
+    if (cache.has(numericTypeID)) {
+      return cache.get(numericTypeID);
+    }
+    const itemType = resolveItemByTypeID(numericTypeID) || {};
+    const referenceRow = statement ? statement.get(numericTypeID) : null;
+    const averagePrice = Number(referenceRow && referenceRow.averagePrice);
+    const adjustedPrice = Number(referenceRow && referenceRow.adjustedPrice);
+    const basePrice = Number(itemType.basePrice);
+    let value = 0;
+    let source = "none";
+    if (Number.isFinite(averagePrice) && averagePrice > 0) {
+      value = averagePrice;
+      source = "market-average";
+    } else if (Number.isFinite(adjustedPrice) && adjustedPrice > 0) {
+      value = adjustedPrice;
+      source = "market-adjusted";
+    } else if (Number.isFinite(basePrice) && basePrice > 0) {
+      value = basePrice;
+      source = "static-base";
+    }
+    const resolved = {
+      typeID: numericTypeID,
+      name: String(itemType.name || `Type ${numericTypeID}`),
+      value,
+      source,
+    };
+    cache.set(numericTypeID, resolved);
+    return resolved;
+  }
+
+  return {
+    snapshotPath,
+    resolve,
+    close() {
+      if (database) {
+        database.close();
+      }
+    },
+  };
+}
+
+function sortedCounts(record) {
+  return Object.fromEntries(
+    Object.entries(record).sort((left, right) => right[1] - left[1] || left[0].localeCompare(right[0])),
+  );
+}
+
+function calculateItemValueMap(quantityMap, priceResolver) {
+  const details = [];
+  let totalValue = 0;
+  for (const [typeID, quantity] of Object.entries(quantityMap)) {
+    const reference = priceResolver.resolve(Number(typeID));
+    const value = reference.value * Number(quantity || 0);
+    totalValue += value;
+    details.push({
+      typeID: Number(typeID),
+      name: reference.name,
+      quantity,
+      unitValue: reference.value,
+      valueSource: reference.source,
+      totalValue: value,
+    });
+  }
+  details.sort((left, right) => right.totalValue - left.totalValue || left.typeID - right.typeID);
+  return { totalValue, details };
+}
+
+function validateCatalog() {
+  const validations = new Map();
+  const errors = [];
+  for (const doctrine of TRAFFIC_DOCTRINES) {
+    const result = validateDoctrine(doctrine);
+    if (!result.success) {
+      errors.push({
+        doctrineID: doctrine.doctrineID,
+        errorMsg: result.errorMsg,
+        data: result.data || null,
+      });
+    } else {
+      validations.set(doctrine.doctrineID, result.data);
+    }
+  }
+
+  const lootTableIDs = new Set(TRAFFIC_LOOT_TABLES.map((table) => table.lootTableID));
+  for (const doctrine of TRAFFIC_DOCTRINES) {
+    const lootTableID = doctrine.recoveryPolicy && doctrine.recoveryPolicy.bonusLootTableID;
+    if (lootTableID && !lootTableIDs.has(lootTableID)) {
+      errors.push({
+        doctrineID: doctrine.doctrineID,
+        errorMsg: "NPC_DOCTRINE_LOOT_TABLE_NOT_FOUND",
+        data: { lootTableID },
+      });
+    }
+  }
+  for (const lootTable of TRAFFIC_LOOT_TABLES) {
+    if (lootTable.lootTableID === GENERIC_RANDOM_LOOT_TABLE_ID) {
+      errors.push({
+        lootTableID: lootTable.lootTableID,
+        errorMsg: "NPC_GOVERNED_GENERIC_LOOT_FORBIDDEN",
+      });
+    }
+    for (const entry of lootTable.entries || []) {
+      const classification = classifyModuleType(entry.typeID);
+      if (classification && Number(classification.itemType.categoryID) === 7) {
+        errors.push({
+          lootTableID: lootTable.lootTableID,
+          errorMsg: "NPC_PHASE3_BONUS_TABLE_MODULE_DUPLICATION_RISK",
+          data: {
+            typeID: entry.typeID,
+            name: classification.name,
+          },
+        });
+      } else if (classification && (classification.techTwo || classification.specialGrade)) {
+        errors.push({
+          lootTableID: lootTable.lootTableID,
+          errorMsg: "NPC_PHASE3_RARE_LOOT_NOT_APPROVED",
+          data: {
+            typeID: entry.typeID,
+            name: classification.name,
+            techTwo: classification.techTwo,
+            specialGrade: classification.specialGrade,
+          },
+        });
+      } else if (!resolveItemByTypeID(entry.typeID)) {
+        errors.push({
+          lootTableID: lootTable.lootTableID,
+          errorMsg: "NPC_PHASE3_LOOT_TYPE_NOT_FOUND",
+          data: { typeID: entry.typeID },
+        });
+      }
+    }
+  }
+
+  return { validations, errors };
+}
+
+function runSimulation(options) {
+  const startedAtMs = Date.now();
+  const catalog = validateCatalog();
+  if (catalog.errors.length > 0) {
+    return {
+      passed: false,
+      catalogErrors: catalog.errors,
+      actorCount: 0,
+    };
+  }
+
+  const lootTablesByID = new Map(
+    TRAFFIC_LOOT_TABLES.map((table) => [table.lootTableID, table]),
+  );
+
+  const counts = {
+    roles: {},
+    bands: {},
+    roleBands: {},
+    doctrines: {},
+    techTwoModulesPerActor: {},
+  };
+  const cargoOriginal = {};
+  const cargoSurvived = {};
+  const cargoDestroyed = {};
+  const fittedModuleDrops = {};
+  const bonusLoot = {};
+  let totalFittedModules = 0;
+  let totalTechTwoModules = 0;
+  let actorsWithTechTwo = 0;
+  let totalSpecialGradeModules = 0;
+  let actorsWithSpecialGrade = 0;
+  let civilianTechTwoViolations = 0;
+  let droppedFittedModules = 0;
+  let destroyedFittedModules = 0;
+  let droppedTechOneModules = 0;
+  let droppedTechTwoModules = 0;
+  let droppedSpecialGradeModules = 0;
+  let cargoStacksOriginal = 0;
+  let cargoStacksSurvived = 0;
+  let cargoStacksDestroyed = 0;
+
+  for (let actorIndex = 0; actorIndex < options.count; actorIndex += 1) {
+    const actorSeed = `${options.seed}:actor:${actorIndex}`;
+    const selection = selectJitaDoctrineForActor(actorSeed);
+    if (!selection) {
+      throw new Error(`No doctrine selection for actor ${actorIndex}`);
+    }
+    const { role, equipmentBand, doctrine } = selection;
+    const validation = catalog.validations.get(doctrine.doctrineID);
+
+    increment(counts.roles, role);
+    increment(counts.bands, equipmentBand);
+    increment(counts.roleBands, `${role}:${equipmentBand}`);
+    increment(counts.doctrines, doctrine.doctrineID);
+    increment(counts.techTwoModulesPerActor, validation.techTwoModuleCount);
+    totalFittedModules += validation.moduleCount;
+    totalTechTwoModules += validation.techTwoModuleCount;
+    totalSpecialGradeModules += validation.specialGradeModuleCount;
+    if (validation.techTwoModuleCount > 0) {
+      actorsWithTechTwo += 1;
+    }
+    if (validation.specialGradeModuleCount > 0) {
+      actorsWithSpecialGrade += 1;
+    }
+    if (equipmentBand === "civilian" && validation.techTwoModuleCount > 0) {
+      civilianTechTwoViolations += 1;
+    }
+
+    const recoveryPolicy = doctrine.recoveryPolicy || {};
+    const fittedModuleResolution = resolveFittedModuleDestruction(validation.fittedItems, {
+      dropChances: recoveryPolicy.fittedModuleDropChances,
+      dropChance: recoveryPolicy.fittedModuleDropChance,
+      rng: createDeterministicRng(`${actorSeed}:fitted-modules`),
+    });
+    droppedFittedModules += fittedModuleResolution.dropped.length;
+    destroyedFittedModules += fittedModuleResolution.destroyed.length;
+    for (const item of fittedModuleResolution.dropped) {
+      increment(fittedModuleDrops, item.typeID, 1);
+      if (item.recoveryGrade === "techTwo") {
+        droppedTechTwoModules += 1;
+      } else if (item.recoveryGrade === "specialGrade") {
+        droppedSpecialGradeModules += 1;
+      } else {
+        droppedTechOneModules += 1;
+      }
+    }
+
+    const cargoRng = createDeterministicRng(`${actorSeed}:cargo`);
+    const cargo = buildCargoManifest(role, cargoRng);
+    const cargoResolution = resolveCargoDestruction(cargo, {
+      survivalChance: recoveryPolicy.cargoSurvivalChance,
+      rng: cargoRng,
+    });
+    cargoStacksOriginal += cargo.length;
+    cargoStacksSurvived += cargoResolution.survivors.length;
+    cargoStacksDestroyed += cargoResolution.destroyed.length;
+    for (const item of cargo) {
+      increment(cargoOriginal, item.typeID, item.quantity);
+    }
+    for (const item of cargoResolution.survivors) {
+      increment(cargoSurvived, item.typeID, item.quantity);
+    }
+    for (const item of cargoResolution.destroyed) {
+      increment(cargoDestroyed, item.typeID, item.quantity);
+    }
+
+    const lootTableID = recoveryPolicy.bonusLootTableID || null;
+    const lootDrops = rollExplicitLootTable(
+      lootTablesByID.get(lootTableID),
+      createDeterministicRng(`${actorSeed}:bonus-loot`),
+    );
+    for (const item of lootDrops) {
+      increment(bonusLoot, item.typeID, item.quantity);
+    }
+  }
+
+  const conservationFailures = [];
+  for (const [typeID, originalQuantity] of Object.entries(cargoOriginal)) {
+    const survivedQuantity = Number(cargoSurvived[typeID]) || 0;
+    const destroyedQuantity = Number(cargoDestroyed[typeID]) || 0;
+    if (survivedQuantity + destroyedQuantity !== originalQuantity) {
+      conservationFailures.push({
+        typeID: Number(typeID),
+        originalQuantity,
+        survivedQuantity,
+        destroyedQuantity,
+      });
+    }
+  }
+
+  const governedProfileGenericLoot = npcData.listNpcProfiles()
+    .filter((profile) => profile && profile.loadoutID)
+    .filter((profile) => {
+      const loadout = npcData.getNpcLoadout(profile.loadoutID);
+      return loadout && loadout.governance && loadout.governance.enabled === true;
+    })
+    .filter((profile) => profile.lootTableID === GENERIC_RANDOM_LOOT_TABLE_ID)
+    .map((profile) => profile.profileID);
+  const legacyGenericRandomProfiles = npcData.listNpcProfiles()
+    .filter((profile) => profile && profile.lootTableID === GENERIC_RANDOM_LOOT_TABLE_ID)
+    .map((profile) => profile.profileID);
+
+  const priceResolver = buildPriceResolver();
+  const cargoOriginalValue = calculateItemValueMap(cargoOriginal, priceResolver);
+  const cargoSurvivedValue = calculateItemValueMap(cargoSurvived, priceResolver);
+  const cargoDestroyedValue = calculateItemValueMap(cargoDestroyed, priceResolver);
+  const fittedModuleDropValue = calculateItemValueMap(fittedModuleDrops, priceResolver);
+  const bonusLootValue = calculateItemValueMap(bonusLoot, priceResolver);
+  const marketSnapshotPath = priceResolver.snapshotPath;
+  priceResolver.close();
+
+  const passed = (
+    catalog.errors.length === 0 &&
+    civilianTechTwoViolations === 0 &&
+    totalSpecialGradeModules === 0 &&
+    droppedSpecialGradeModules === 0 &&
+    conservationFailures.length === 0 &&
+    governedProfileGenericLoot.length === 0
+  );
+
+  return {
+    passed,
+    seed: options.seed,
+    doctrineRevision: DOCTRINE_REVISION,
+    actorCount: options.count,
+    durationMs: Date.now() - startedAtMs,
+    marketSnapshotPath,
+    counts: {
+      roles: sortedCounts(counts.roles),
+      bands: sortedCounts(counts.bands),
+      roleBands: sortedCounts(counts.roleBands),
+      doctrines: sortedCounts(counts.doctrines),
+      techTwoModulesPerActor: sortedCounts(counts.techTwoModulesPerActor),
+    },
+    fitting: {
+      totalFittedModules,
+      totalTechTwoModules,
+      actorsWithTechTwo,
+      totalSpecialGradeModules,
+      actorsWithSpecialGrade,
+      civilianTechTwoViolations,
+      droppedFittedModules,
+      destroyedFittedModules,
+      droppedTechOneModules,
+      droppedTechTwoModules,
+      droppedSpecialGradeModules,
+      fittedModuleDrops: fittedModuleDropValue,
+    },
+    cargo: {
+      stacksOriginal: cargoStacksOriginal,
+      stacksSurvived: cargoStacksSurvived,
+      stacksDestroyed: cargoStacksDestroyed,
+      observedStackSurvivalRate: cargoStacksOriginal > 0
+        ? cargoStacksSurvived / cargoStacksOriginal
+        : 0,
+      original: cargoOriginalValue,
+      survived: cargoSurvivedValue,
+      destroyed: cargoDestroyedValue,
+      conservationFailures,
+    },
+    bonusLoot: bonusLootValue,
+    safety: {
+      catalogErrors: catalog.errors,
+      governedProfileGenericLoot,
+      legacyGenericRandomProfileCount: legacyGenericRandomProfiles.length,
+      legacyGenericRandomProfiles,
+    },
+  };
+}
+
+function formatNumber(value, maximumFractionDigits = 0) {
+  return Number(value || 0).toLocaleString("en-US", { maximumFractionDigits });
+}
+
+function formatIsk(value) {
+  return `${formatNumber(value, 2)} ISK`;
+}
+
+function buildMarkdownReport(report) {
+  const lines = [
+    "# EveJS Phase 3 NPC Loadout and Economy Simulation",
+    "",
+    `**Result:** ${report.passed ? "PASS" : "FAIL"}`,
+    "",
+    `- Actors destroyed: ${formatNumber(report.actorCount)}`,
+    `- Deterministic seed: \`${report.seed}\``,
+    `- Doctrine revision: ${report.doctrineRevision}`,
+    `- Runtime: ${formatNumber(report.durationMs)} ms`,
+    `- Price reference: ${report.marketSnapshotPath ? `\`${report.marketSnapshotPath}\`` : "static item base prices"}`,
+    "",
+    "## Population",
+    "",
+    "| Role | Actors | Share |",
+    "|---|---:|---:|",
+  ];
+  for (const [role, count] of Object.entries(report.counts.roles)) {
+    lines.push(`| ${role} | ${formatNumber(count)} | ${formatNumber((count / report.actorCount) * 100, 2)}% |`);
+  }
+  lines.push(
+    "",
+    "| Equipment band | Actors | Share |",
+    "|---|---:|---:|",
+  );
+  for (const [band, count] of Object.entries(report.counts.bands)) {
+    lines.push(`| ${band} | ${formatNumber(count)} | ${formatNumber((count / report.actorCount) * 100, 2)}% |`);
+  }
+  lines.push(
+    "",
+    "## Fitting safety",
+    "",
+    `- Total fitted modules evaluated: ${formatNumber(report.fitting.totalFittedModules)}`,
+    `- Actors carrying any T2 module: ${formatNumber(report.fitting.actorsWithTechTwo)} (${formatNumber((report.fitting.actorsWithTechTwo / report.actorCount) * 100, 2)}%)`,
+    `- Total T2 modules: ${formatNumber(report.fitting.totalTechTwoModules)}`,
+    `- Civilian actors with T2: ${formatNumber(report.fitting.civilianTechTwoViolations)}`,
+    `- Special-grade fitted modules: ${formatNumber(report.fitting.totalSpecialGradeModules)}`,
+    `- Actual fitted modules recovered: ${formatNumber(report.fitting.droppedFittedModules)}`,
+    `- Recovered T1 / T2 / special-grade: ${formatNumber(report.fitting.droppedTechOneModules)} / ${formatNumber(report.fitting.droppedTechTwoModules)} / ${formatNumber(report.fitting.droppedSpecialGradeModules)}`,
+    `- Recovered fitted-module reference value: ${formatIsk(report.fitting.fittedModuleDrops.totalValue)}`,
+    `- Average fitted-module faucet per destroyed actor: ${formatIsk(report.actorCount > 0 ? report.fitting.fittedModuleDrops.totalValue / report.actorCount : 0)}`,
+    "",
+    "| Recovered fitted module | Quantity | Reference value |",
+    "|---|---:|---:|",
+  );
+  for (const item of report.fitting.fittedModuleDrops.details.slice(0, 20)) {
+    lines.push(`| ${item.name} (${item.typeID}) | ${formatNumber(item.quantity)} | ${formatIsk(item.totalValue)} |`);
+  }
+  lines.push(
+    "",
+    "## Cargo destruction",
+    "",
+    `- Original cargo stacks: ${formatNumber(report.cargo.stacksOriginal)}`,
+    `- Surviving cargo stacks: ${formatNumber(report.cargo.stacksSurvived)}`,
+    `- Destroyed cargo stacks: ${formatNumber(report.cargo.stacksDestroyed)}`,
+    `- Observed stack survival rate: ${formatNumber(report.cargo.observedStackSurvivalRate * 100, 3)}%`,
+    `- Original reference value: ${formatIsk(report.cargo.original.totalValue)}`,
+    `- Recovered reference value: ${formatIsk(report.cargo.survived.totalValue)}`,
+    `- Destroyed economic sink: ${formatIsk(report.cargo.destroyed.totalValue)}`,
+    `- Conservation failures: ${report.cargo.conservationFailures.length}`,
+    "",
+    "## Bonus loot faucet",
+    "",
+    `- Total reference value: ${formatIsk(report.bonusLoot.totalValue)}`,
+    `- Average per destroyed actor: ${formatIsk(report.actorCount > 0 ? report.bonusLoot.totalValue / report.actorCount : 0)}`,
+    "",
+    "| Item | Quantity | Reference value |",
+    "|---|---:|---:|",
+  );
+  for (const item of report.bonusLoot.details.slice(0, 20)) {
+    lines.push(`| ${item.name} (${item.typeID}) | ${formatNumber(item.quantity)} | ${formatIsk(item.totalValue)} |`);
+  }
+  lines.push(
+    "",
+    "## Safety gates",
+    "",
+    `- Governed profiles using \`${GENERIC_RANDOM_LOOT_TABLE_ID}\`: ${report.safety.governedProfileGenericLoot.length}`,
+    `- Legacy, not-yet-governed profiles using it: ${report.safety.legacyGenericRandomProfileCount}`,
+    `- Catalog validation errors: ${report.safety.catalogErrors.length}`,
+    "",
+    report.safety.legacyGenericRandomProfileCount > 0
+      ? "The legacy count is reported for migration work but does not authorize those profiles for the Phase 3 traffic population. Only governed doctrines were included in this simulation."
+      : "No NPC profile retains the unrestricted random-loot assignment. Only governed Phase 3 doctrines were included in the destruction population.",
+    "",
+  );
+  return lines.join("\n");
+}
+
+function writeOutput(filename, contents) {
+  fs.mkdirSync(path.dirname(filename), { recursive: true });
+  fs.writeFileSync(filename, contents, "utf8");
+}
+
+function main() {
+  const options = parseArgs(process.argv.slice(2));
+  if (options.help) {
+    console.log("Usage: node scripts/simulateNpcDoctrineEconomy.js [--count 100000] [--seed text] [--report report.md] [--json report.json]");
+    return;
+  }
+  const report = runSimulation(options);
+  if (options.reportPath) {
+    writeOutput(options.reportPath, buildMarkdownReport(report));
+  }
+  if (options.jsonPath) {
+    writeOutput(options.jsonPath, `${JSON.stringify(report, null, 2)}\n`);
+  }
+  console.log(JSON.stringify({
+    passed: report.passed,
+    actorCount: report.actorCount,
+    durationMs: report.durationMs,
+    actorsWithTechTwo: report.fitting && report.fitting.actorsWithTechTwo,
+    specialGradeModules: report.fitting && report.fitting.totalSpecialGradeModules,
+    droppedFittedModules: report.fitting && report.fitting.droppedFittedModules,
+    droppedTechTwoModules: report.fitting && report.fitting.droppedTechTwoModules,
+    fittedModuleDropReferenceValue:
+      report.fitting && report.fitting.fittedModuleDrops.totalValue,
+    cargoStackSurvivalRate: report.cargo && report.cargo.observedStackSurvivalRate,
+    cargoConservationFailures: report.cargo && report.cargo.conservationFailures.length,
+    bonusLootReferenceValue: report.bonusLoot && report.bonusLoot.totalValue,
+    governedGenericLootProfiles: report.safety && report.safety.governedProfileGenericLoot.length,
+    legacyGenericLootProfiles: report.safety && report.safety.legacyGenericRandomProfileCount,
+    reportPath: options.reportPath,
+    jsonPath: options.jsonPath,
+  }, null, 2));
+  if (!report.passed) {
+    process.exitCode = 1;
+  }
+}
+
+if (require.main === module) {
+  main();
+}
+
+module.exports = {
+  buildMarkdownReport,
+  parseArgs,
+  rollExplicitLootTable,
+  runSimulation,
+};
diff --git a/server/scripts/syncLivingUniversePortraits.js b/server/scripts/syncLivingUniversePortraits.js
new file mode 100644
index 0000000000000000000000000000000000000000..8b71e8076f3e95da5eeeed268a6f3a9a0f59ba4f
--- /dev/null
+++ b/server/scripts/syncLivingUniversePortraits.js
@@ -0,0 +1,117 @@
+"use strict";
+
+const fs = require("fs");
+const path = require("path");
+
+const config = require(path.join(__dirname, "../src/config"));
+const {
+  getCharacterPortraitFilePath,
+} = require(path.join(
+  __dirname,
+  "../src/services/character/portraitImageStore",
+));
+const {
+  loadPortraitAgentPool,
+} = require(path.join(
+  __dirname,
+  "../src/space/npc/ambientTraffic/livingUniversePilotDirectory",
+));
+
+function readNumericOption(name, fallback) {
+  const prefix = `--${name}=`;
+  const raw = process.argv.slice(2).find((value) => value.startsWith(prefix));
+  const numeric = Number(raw ? raw.slice(prefix.length) : fallback);
+  return Number.isFinite(numeric) ? Math.trunc(numeric) : fallback;
+}
+
+function delay(ms) {
+  return new Promise((resolve) => setTimeout(resolve, ms));
+}
+
+async function fetchPortrait(agentID, size, attempt = 1) {
+  const targetPath = getCharacterPortraitFilePath(agentID, size, "jpg");
+  if (fs.existsSync(targetPath) && fs.statSync(targetPath).size > 1_000) {
+    return { agentID, status: "existing", targetPath };
+  }
+
+  const controller = new AbortController();
+  const timeout = setTimeout(() => controller.abort(), 20_000);
+  try {
+    const response = await fetch(
+      `https://images.evetech.net/characters/${agentID}/portrait?size=${size}`,
+      {
+        headers: { "user-agent": "EveJS-Living-Universe-Portrait-Sync/1.0" },
+        redirect: "follow",
+        signal: controller.signal,
+      },
+    );
+    if (!response.ok) {
+      throw new Error(`HTTP_${response.status}`);
+    }
+    const bytes = Buffer.from(await response.arrayBuffer());
+    if (bytes.length <= 1_000) {
+      throw new Error(`PORTRAIT_TOO_SMALL:${bytes.length}`);
+    }
+    fs.mkdirSync(path.dirname(targetPath), { recursive: true });
+    const temporaryPath = `${targetPath}.download`;
+    fs.writeFileSync(temporaryPath, bytes);
+    fs.renameSync(temporaryPath, targetPath);
+    return { agentID, status: "downloaded", targetPath, bytes: bytes.length };
+  } catch (error) {
+    if (attempt < 3) {
+      await delay(250 * attempt);
+      return fetchPortrait(agentID, size, attempt + 1);
+    }
+    return { agentID, status: "failed", error: error.message };
+  } finally {
+    clearTimeout(timeout);
+  }
+}
+
+async function main() {
+  const configuredPopulation = Math.max(
+    1,
+    Math.trunc(Number(config.livingUniversePopulationSize) || 400),
+  );
+  const count = Math.max(1, readNumericOption("count", configuredPopulation));
+  const size = Math.max(32, readNumericOption("size", 256));
+  const concurrency = Math.max(1, Math.min(24, readNumericOption("concurrency", 12)));
+  const agentIDs = loadPortraitAgentPool().slice(0, count);
+  let cursor = 0;
+  const results = [];
+
+  async function worker() {
+    while (cursor < agentIDs.length) {
+      const index = cursor;
+      cursor += 1;
+      const result = await fetchPortrait(agentIDs[index], size);
+      results.push(result);
+      if (results.length % 25 === 0 || results.length === agentIDs.length) {
+        process.stdout.write(
+          `[LivingUniversePortraits] ${results.length}/${agentIDs.length}\n`,
+        );
+      }
+    }
+  }
+
+  await Promise.all(
+    Array.from({ length: Math.min(concurrency, agentIDs.length) }, () => worker()),
+  );
+  const summary = results.reduce((counts, result) => {
+    counts[result.status] = (counts[result.status] || 0) + 1;
+    return counts;
+  }, {});
+  process.stdout.write(`${JSON.stringify({ count, size, ...summary })}\n`);
+  const failures = results.filter((result) => result.status === "failed");
+  if (failures.length > 0) {
+    process.stderr.write(
+      `${JSON.stringify(failures.slice(0, 20), null, 2)}\n`,
+    );
+    process.exitCode = 1;
+  }
+}
+
+main().catch((error) => {
+  process.stderr.write(`[LivingUniversePortraits] ${error.stack || error.message}\n`);
+  process.exitCode = 1;
+});
