index 0000000000000000000000000000000000000000..4ce06b4bc2a92f4bc8859641b568135a5318662e
--- /dev/null
+++ b/server/scripts/verifyLivingIndustrialWorkforce.js
@@ -0,0 +1,211 @@
+"use strict";
+
+const assert = require("assert/strict");
+
+const catalog = require("../src/space/npc/ambientTraffic/livingEconomyCatalog");
+const industry = require("../src/space/npc/ambientTraffic/livingEconomyIndustry");
+const workforce = require("../src/space/npc/ambientTraffic/livingEconomyIndustrialWorkforce");
+const stateStore = require("../src/space/npc/ambientTraffic/livingEconomyState");
+
+function key(stationID, typeID) {
+  return `${Number(stationID)}:${Number(typeID)}`;
+}
+
+function getStockRow(stockMap, stationID, typeID) {
+  return stockMap.get(key(stationID, typeID)) || {
+    station_id: Number(stationID),
+    type_id: Number(typeID),
+    quantity: 0,
+    price: catalog.getGood(typeID)?.priceAnchor || 1,
+  };
+}
+
+async function main() {
+  const nowMs = 1_700_100_000_000;
+  const state = stateStore.buildDefaultState();
+  const seeded = workforce.seed(state, nowMs);
+  const workforceStatus = workforce.getStatus(state);
+  assert.ok(seeded.created >= 200, "regional industrial workforce was not seeded");
+  assert.ok(workforceStatus.highsec > 0, "high-sec industrialists are missing");
+  assert.ok(workforceStatus.lowsec > 0, "low-sec industrialists are missing");
+
+  const station = catalog.getStation(60003760);
+  const product = catalog.getGood(210);
+  const recipe = industry.getRecipe(product);
+  const stockMap = new Map();
+  stockMap.set(key(station.stationID, product.typeID), {
+    station_id: station.stationID,
+    type_id: product.typeID,
+    quantity: 0,
+    price: product.priceAnchor,
+  });
+  for (const material of recipe.materials) {
+    stockMap.set(key(station.stationID, material.typeID), {
+      station_id: station.stationID,
+      type_id: material.typeID,
+      quantity: 1_000_000,
+      price: catalog.getGood(material.typeID).priceAnchor,
+    });
+  }
+  const candidate = industry._testing.buildCandidate(
+    state,
+    stockMap,
+    getStockRow,
+    station,
+    product,
+    nowMs,
+  );
+  assert.ok(candidate, "manufacturing shortage did not produce a candidate");
+
+  const adjustments = [];
+  const dependencies = {
+    getStockRow,
+    async adjustStock(details) {
+      const row = getStockRow(stockMap, details.station.stationID, details.good.typeID);
+      const next = { ...row, quantity: Math.max(0, row.quantity + details.deltaQuantity) };
+      stockMap.set(key(details.station.stationID, details.good.typeID), next);
+      adjustments.push(details);
+      return { success: true, response: next };
+    },
+    addEvent() {},
+  };
+
+  const original = industry._testing.ensureBlueprintOriginal(state, candidate, nowMs);
+  assert.equal(original.original, true);
+  assert.equal(original.materialEfficiency, 6);
+  assert.equal(original.timeEfficiency, 10);
+
+  const materialResearcher = workforce.choosePilot(state, station.stationID, "science");
+  const materialResearch = industry._testing.createBlueprintJob(
+    state,
+    candidate,
+    original,
+    industry.ACTIVITY.RESEARCH_MATERIAL,
+    materialResearcher,
+    nowMs,
+  );
+  assert.ok(materialResearch.endsAtMs > nowMs, "ME research has no real deadline");
+  assert.equal(
+    await industry._testing.completeJob(
+      state,
+      materialResearch,
+      stockMap,
+      dependencies,
+      materialResearch.endsAtMs,
+    ),
+    true,
+  );
+  assert.equal(original.materialEfficiency, 8);
+
+  const timeResearcher = workforce.choosePilot(state, station.stationID, "science");
+  const timeResearch = industry._testing.createBlueprintJob(
+    state,
+    candidate,
+    original,
+    industry.ACTIVITY.RESEARCH_TIME,
+    timeResearcher,
+    materialResearch.endsAtMs,
+  );
+  await industry._testing.completeJob(
+    state,
+    timeResearch,
+    stockMap,
+    dependencies,
+    timeResearch.endsAtMs,
+  );
+  assert.equal(original.timeEfficiency, 16);
+
+  const copyResearcher = workforce.choosePilot(state, station.stationID, "science");
+  const copyJob = industry._testing.createBlueprintJob(
+    state,
+    candidate,
+    original,
+    industry.ACTIVITY.COPYING,
+    copyResearcher,
+    timeResearch.endsAtMs,
+  );
+  await industry._testing.completeJob(
+    state,
+    copyJob,
+    stockMap,
+    dependencies,
+    copyJob.endsAtMs,
+  );
+  const copy = industry._testing.findUsableCopy(state, candidate);
+  assert.ok(copy && copy.original === false, "copying did not create a finite BPC");
+  assert.equal(copy.runsRemaining, candidate.runs);
+
+  const manufacturer = workforce.choosePilot(state, station.stationID, "manufacturing");
+  const manufacturingJob = industry._testing.createManufacturingJob(
+    state,
+    candidate,
+    copy,
+    manufacturer,
+    stockMap,
+    getStockRow,
+    copyJob.endsAtMs,
+  );
+  const baseTritanium = recipe.materials.find((material) => material.typeID === 34)
+    .quantityPerRun * candidate.runs;
+  const actualTritanium = manufacturingJob.inputs.find((input) => input.typeID === 34).quantity;
+  assert.ok(actualTritanium < baseTritanium, "researched ME did not reduce materials");
+  assert.ok(
+    manufacturingJob.durationSeconds < candidate.durationSeconds,
+    "TE and installer skills did not reduce manufacturing time",
+  );
+  assert.equal(
+    await industry._testing.reserveInputs(
+      state,
+      manufacturingJob,
+      stockMap,
+      dependencies,
+      copyJob.endsAtMs,
+    ),
+    true,
+  );
+  assert.equal(state.industryBlueprints[copy.blueprintAssetID].runsRemaining, 0);
+  assert.equal(
+    await industry._testing.completeJob(
+      state,
+      manufacturingJob,
+      stockMap,
+      dependencies,
+      manufacturingJob.endsAtMs,
+    ),
+    true,
+  );
+  assert.equal(state.industryBlueprints[copy.blueprintAssetID], undefined);
+  assert.equal(getStockRow(stockMap, station.stationID, product.typeID).quantity, candidate.outputQuantity);
+
+  console.log(JSON.stringify({
+    success: true,
+    workforce: workforceStatus,
+    pilot: {
+      name: manufacturer.name,
+      corporationID: manufacturer.corporationID,
+      skills: manufacturer.skills,
+      manufacturingSlots: manufacturer.manufacturingSlots,
+    },
+    blueprint: {
+      blueprintTypeID: original.blueprintTypeID,
+      materialEfficiency: original.materialEfficiency,
+      timeEfficiency: original.timeEfficiency,
+      copiedRuns: copyJob.copyRuns,
+      consumedRuns: manufacturingJob.runs,
+    },
+    manufacturing: {
+      product: product.name,
+      outputQuantity: manufacturingJob.productQuantity,
+      baseDurationSeconds: candidate.durationSeconds,
+      skilledDurationSeconds: manufacturingJob.durationSeconds,
+      baseTritanium,
+      actualTritanium,
+      marketAdjustments: adjustments.length,
+    },
+  }, null, 2));
+}
+
+main().catch((error) => {
+  console.error(error.stack || error.message);
+  process.exitCode = 1;
+});
