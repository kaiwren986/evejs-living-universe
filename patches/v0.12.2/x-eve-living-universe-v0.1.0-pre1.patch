@@ -0,0 +1,101 @@
+#!/usr/bin/env node
+
+const assert = require("assert");
+const path = require("path");
+
+const {
+  buildShipResourceState,
+} = require(path.join(__dirname, "../src/services/fitting/liveFittingState"));
+const {
+  resolveItemByTypeID,
+} = require(path.join(__dirname, "../src/services/inventory/itemTypeRegistry"));
+
+const GILA_TYPE_ID = 17715;
+const LARGE_SHIELD_EXTENDER_II_TYPE_ID = 3841;
+const MEDIUM_CORE_DEFENSE_FIELD_EXTENDER_I_TYPE_ID = 31790;
+const SHIELD_MANAGEMENT_TYPE_ID = 3419;
+const EXPECTED_UNSKILLED_SHIELD_CAPACITY = 16729.625;
+const EXPECTED_SKILLED_SHIELD_CAPACITY = 20912.03125;
+const LEGACY_INCORRECT_SHIELD_CAPACITY = 17946.325;
+
+function createItem(typeID, itemID, flagID = 0) {
+  const metadata = resolveItemByTypeID(typeID);
+  if (!metadata) {
+    throw new Error(`Missing item metadata for type ${typeID}.`);
+  }
+
+  return {
+    ...metadata,
+    itemID,
+    typeID,
+    flagID,
+    moduleState: {
+      online: true,
+    },
+  };
+}
+
+function createFittedItems() {
+  return [
+    ...[19, 20, 21].map((flagID, index) => (
+      createItem(LARGE_SHIELD_EXTENDER_II_TYPE_ID, 910000010 + index, flagID)
+    )),
+    ...[92, 93, 94].map((flagID, index) => (
+      createItem(
+        MEDIUM_CORE_DEFENSE_FIELD_EXTENDER_I_TYPE_ID,
+        910000020 + index,
+        flagID,
+      )
+    )),
+  ];
+}
+
+function buildGilaShieldCapacity(skillLevel) {
+  const ship = createItem(GILA_TYPE_ID, 910000001);
+  const skillMap = skillLevel > 0
+    ? new Map([[
+        SHIELD_MANAGEMENT_TYPE_ID,
+        {
+          typeID: SHIELD_MANAGEMENT_TYPE_ID,
+          effectiveSkillLevel: skillLevel,
+        },
+      ]])
+    : new Map();
+  const resourceState = buildShipResourceState(0, ship, {
+    fittedItems: createFittedItems(),
+    skillMap,
+    includeActiveImplantModifiers: false,
+  });
+  return resourceState.shieldCapacity;
+}
+
+const unskilledShieldCapacity = buildGilaShieldCapacity(0);
+const skilledShieldCapacity = buildGilaShieldCapacity(5);
+
+assert.strictEqual(
+  unskilledShieldCapacity,
+  EXPECTED_UNSKILLED_SHIELD_CAPACITY,
+  "Extenders and rigs must apply to the Gila base shield capacity.",
+);
+assert.strictEqual(
+  skilledShieldCapacity,
+  EXPECTED_SKILLED_SHIELD_CAPACITY,
+  "Shield Management V must multiply the base capacity plus additive extenders.",
+);
+assert.notStrictEqual(
+  skilledShieldCapacity,
+  LEGACY_INCORRECT_SHIELD_CAPACITY,
+  "The legacy skill-before-extender result must not return.",
+);
+
+console.log(JSON.stringify({
+  shipTypeID: GILA_TYPE_ID,
+  fit: {
+    largeShieldExtenderII: 3,
+    mediumCoreDefenseFieldExtenderI: 3,
+    shieldManagementLevel: 5,
+  },
+  unskilledShieldCapacity,
+  skilledShieldCapacity,
+  legacyIncorrectShieldCapacity: LEGACY_INCORRECT_SHIELD_CAPACITY,
+}, null, 2));
