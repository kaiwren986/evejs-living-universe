+"use strict";
+
+const crypto = require("node:crypto");
+const fs = require("node:fs");
+const net = require("node:net");
+const path = require("node:path");
+
+const TOOL_NAME = "EveJS-Universe-Market-Mirror";
+const TOOL_VERSION = "0.1.0";
+const DEFAULT_CONFIG = {
+  esiBaseUrl: "https://esi.evetech.net/latest",
+  compatibilityDate: "2026-07-19",
+  userAgent: "",
+  concurrency: 4,
+  requestTimeoutMs: 60000,
+  maxRetries: 6,
+  coherenceGuardSeconds: 15,
+  pricePolicy: {
+    mode: "clamped_live",
+    liveStatistic: "weighted_average",
+    anchorPriority: ["average", "adjusted", "base"],
+    minimumAnchorMultiplier: 0.5,
+    maximumAnchorMultiplier: 2.0,
+    referenceSpreadPercent: 5,
+  },
+  quantityScale: 1,
+  maximumQuantity: 9007199254740991,
+};
+
+function usage() {
+  return [
+    TOOL_NAME + " " + TOOL_VERSION,
+    "",
+    "Commands:",
+    "  snapshot --server-root <EveJS> [--config <json>] [--region <id> ...]",
+    "  apply    --server-root <EveJS> --snapshot <sqlite> [--config <json>]",
+    "  doctor   --server-root <EveJS>",
+    "",
+    "Options:",
+    "  --output <path>       Exact snapshot SQLite output path",
+    "  --cache-dir <path>    Raw ESI page cache directory",
+    "  --region <id>         Limit snapshot to one or more regions",
+    "  --config <path>       JSON configuration file",
+  ].join("\n");
+}
+
+function parseArgs(argv) {
+  const args = { command: null, regions: [] };
+  const input = [...argv];
+  args.command = input.shift() || "help";
+  while (input.length > 0) {
+    const token = input.shift();
+    if (token === "--server-root") args.serverRoot = input.shift();
+    else if (token === "--config") args.configPath = input.shift();
+    else if (token === "--snapshot") args.snapshotPath = input.shift();
+    else if (token === "--output") args.outputPath = input.shift();
+    else if (token === "--cache-dir") args.cacheDir = input.shift();
+    else if (token === "--region") args.regions.push(Number(input.shift()));
+    else if (token === "--help" || token === "-h") args.command = "help";
+    else throw new Error("Unknown argument: " + token);
+  }
+  return args;
+}
+
+function isObject(value) {
+  return Boolean(value) && typeof value === "object" && !Array.isArray(value);
+}
+
+function mergeDeep(base, override) {
+  const result = { ...base };
+  for (const [key, value] of Object.entries(override || {})) {
+    result[key] =
+      isObject(value) && isObject(base[key])
+        ? mergeDeep(base[key], value)
+        : value;
+  }
+  return result;
+}
+
+function readJson(filePath) {
+  return JSON.parse(fs.readFileSync(filePath, "utf8"));
+}
+
+function writeJson(filePath, value) {
+  fs.mkdirSync(path.dirname(filePath), { recursive: true });
+  fs.writeFileSync(filePath, JSON.stringify(value, null, 2) + "\n", "utf8");
+}
+
+function optionalHeaderNumber(value) {
+  if (value === null || value === undefined || String(value).trim() === "") return null;
+  const parsed = Number(value);
+  return Number.isFinite(parsed) ? parsed : null;
+}
+
+function loadConfig(configPath) {
+  const user = configPath ? readJson(path.resolve(configPath)) : {};
+  const config = mergeDeep(DEFAULT_CONFIG, user);
+  if (!String(config.userAgent || "").trim()) {
+    throw new Error(
+      "config.userAgent is required. Use an app/version plus an email, source URL, Discord name, or EVE character.",
+    );
+  }
+  if (!/^\d{4}-\d{2}-\d{2}$/.test(String(config.compatibilityDate || ""))) {
+    throw new Error("config.compatibilityDate must use YYYY-MM-DD.");
+  }
+  config.concurrency = Math.max(1, Math.min(12, Math.trunc(Number(config.concurrency) || 1)));
+  return config;
+}
+
+function requireServerRoot(args) {
+  if (!args.serverRoot) throw new Error("--server-root is required.");
+  const root = path.resolve(args.serverRoot);
+  for (const relative of [
+    "server",
+    "_local/gameStore/data/stations/data.json",
+    "_local/gameStore/data/solarSystems/data.json",
+    "externalservices/market-server/data/generated/market.sqlite",
+  ]) {
+    if (!fs.existsSync(path.join(root, relative))) {
+      throw new Error("EveJS path is missing: " + path.join(root, relative));
+    }
+  }
+  return root;
+}
+
+function loadDatabaseConstructor(serverRoot) {
+  return require(path.join(serverRoot, "server", "node_modules", "better-sqlite3"));
+}
+
+function recordsFromFile(filePath, key) {
+  const document = readJson(filePath);
+  const records = document[key];
+  if (!Array.isArray(records)) {
+    throw new Error("Expected array " + key + " in " + filePath);
+  }
+  return records;
+}
+
+function loadTopology(serverRoot) {
+  const dataRoot = path.join(serverRoot, "_local", "gameStore", "data");
+  const stations = recordsFromFile(path.join(dataRoot, "stations", "data.json"), "stations");
+  const solarSystems = recordsFromFile(
+    path.join(dataRoot, "solarSystems", "data.json"),
+    "solarSystems",
+  );
+  const stationById = new Map();
+  const regionNames = new Map();
+  for (const station of stations) {
+    const stationId = Number(station.stationID);
+    stationById.set(stationId, {
+      stationId,
+      stationName: String(station.stationName || station.itemName || stationId),
+      solarSystemId: Number(station.solarSystemID),
+      constellationId: Number(station.constellationID),
+      regionId: Number(station.regionID),
+      regionName: String(station.regionName || station.regionID),
+      security: Number(station.security) || 0,
+    });
+    regionNames.set(Number(station.regionID), String(station.regionName || station.regionID));
+  }
+  return { stations, solarSystems, stationById, regionNames };
+}
+
+function loadMarketTypes(Database, databasePath) {
+  const database = new Database(databasePath, { readonly: true, fileMustExist: true });
+  try {
+    const rows = database.prepare(
+      "SELECT type_id, base_price, published FROM market_types",
+    ).all();
+    return new Map(
+      rows
+        .filter((row) => Number(row.published) === 1)
+        .map((row) => [
+          Number(row.type_id),
+          {
+            typeId: Number(row.type_id),
+            basePrice: positiveNumber(row.base_price),
+          },
+        ]),
+    );
+  } finally {
+    database.close();
+  }
+}
+
+function positiveNumber(value) {
+  const number = Number(value);
+  return Number.isFinite(number) && number > 0 ? number : null;
+}
+
+function clamp(value, minimum, maximum) {
+  return Math.min(maximum, Math.max(minimum, value));
+}
+
+function roundPrice(value) {
+  const price = Math.max(0.01, Number(value) || 0.01);
+  if (price < 100) return Math.round(price * 100) / 100;
+  if (price < 1000) return Math.round(price * 10) / 10;
+  return Math.round(price);
+}
+
+function selectAnchor(type, reference, policy, mode = null) {
+  const effectiveMode = mode || policy.mode;
+  const values = {
+    average: positiveNumber(reference && reference.averagePrice),
+    adjusted: positiveNumber(reference && reference.adjustedPrice),
+    base: positiveNumber(type && type.basePrice),
+  };
+  const priority =
+    effectiveMode === "static_base"
+      ? ["base", "average", "adjusted"]
+      : policy.anchorPriority;
+  for (const key of priority || []) {
+    if (values[key]) return { value: values[key], source: key };
+  }
+  return { value: null, source: null };
+}
+
+function sideLivePrice(entry, statistic) {
+  if (!entry) return null;
+  if (statistic === "best") return positiveNumber(entry.bestPrice);
+  const quantity = positiveNumber(entry.quantity);
+  const notional = positiveNumber(entry.notional);
+  return quantity && notional ? notional / quantity : positiveNumber(entry.bestPrice);
+}
+
+function calculatePairPrices(entries, type, reference, pricePolicy) {
+  const bySide = new Map(entries.map((entry) => [Number(entry.bid), entry]));
+  const anchorResult = selectAnchor(type, reference, pricePolicy);
+  const anchor = anchorResult.value;
+  const spreadHalf = Math.max(0, Number(pricePolicy.referenceSpreadPercent) || 0) / 200;
+  const result = new Map();
+  for (const bid of [0, 1]) {
+    const entry = bySide.get(bid);
+    if (!entry) continue;
+    const live = sideLivePrice(entry, pricePolicy.liveStatistic);
+    let price = live;
+    if (pricePolicy.mode === "reference" || pricePolicy.mode === "static_base") {
+      const selected = selectAnchor(type, reference, pricePolicy, pricePolicy.mode).value || live;
+      price = selected * (bid ? 1 - spreadHalf : 1 + spreadHalf);
+    } else if (pricePolicy.mode === "clamped_live") {
+      price = anchor
+        ? clamp(
+            live || anchor,
+            anchor * Number(pricePolicy.minimumAnchorMultiplier || 0),
+            anchor * Number(pricePolicy.maximumAnchorMultiplier || Number.MAX_VALUE),
+          )
+        : live;
+    } else if (pricePolicy.mode !== "live") {
+      throw new Error("Unknown pricePolicy.mode: " + pricePolicy.mode);
+    }
+    result.set(bid, roundPrice(price || anchor || 100));
+  }
+  if (result.has(0) && result.has(1) && result.get(1) >= result.get(0)) {
+    const center =
+      anchor ||
+      Math.max(0.01, (Number(result.get(0)) + Number(result.get(1))) / 2);
+    result.set(1, roundPrice(center * 0.98));
+    result.set(0, roundPrice(center * 1.02));
+    if (result.get(1) >= result.get(0)) {
+      result.set(1, roundPrice(Math.max(0.01, result.get(0) * 0.99)));
+    }
+  }
+  return { prices: result, anchorSource: anchorResult.source };
+}
+
+function createSnapshotDatabase(Database, snapshotPath) {
+  if (fs.existsSync(snapshotPath)) {
+    throw new Error("Snapshot output already exists: " + snapshotPath);
+  }
+  fs.mkdirSync(path.dirname(snapshotPath), { recursive: true });
+  const database = new Database(snapshotPath);
+  database.pragma("journal_mode = WAL");
+  database.pragma("synchronous = NORMAL");
+  database.pragma("temp_store = MEMORY");
+  database.exec(
+    [
+      "CREATE TABLE meta (key TEXT PRIMARY KEY, value TEXT NOT NULL) WITHOUT ROWID;",
+      "CREATE TABLE reference_prices (",
+      "  type_id INTEGER PRIMARY KEY, adjusted_price REAL, average_price REAL",
+      ") WITHOUT ROWID;",
+      "CREATE TABLE aggregates (",
+      "  station_id INTEGER NOT NULL, type_id INTEGER NOT NULL, bid INTEGER NOT NULL,",
+      "  quantity INTEGER NOT NULL, notional REAL NOT NULL, best_price REAL NOT NULL,",
+      "  order_count INTEGER NOT NULL,",
+      "  PRIMARY KEY (station_id, type_id, bid)",
+      ") WITHOUT ROWID;",
+      "CREATE TABLE plan_rows (",
+      "  station_id INTEGER NOT NULL, solar_system_id INTEGER NOT NULL,",
+      "  constellation_id INTEGER NOT NULL, region_id INTEGER NOT NULL,",
+      "  type_id INTEGER NOT NULL, bid INTEGER NOT NULL, price REAL NOT NULL,",
+      "  quantity INTEGER NOT NULL,",
+      "  PRIMARY KEY (station_id, type_id, bid)",
+      ") WITHOUT ROWID;",
+      "CREATE TABLE unknown_locations (",
+      "  location_id INTEGER NOT NULL, region_id INTEGER NOT NULL, order_count INTEGER NOT NULL,",
+      "  PRIMARY KEY (location_id, region_id)",
+      ") WITHOUT ROWID;",
+      "CREATE TABLE region_stats (",
+      "  region_id INTEGER PRIMARY KEY, pages INTEGER NOT NULL, raw_orders INTEGER NOT NULL,",
+      "  accepted_orders INTEGER NOT NULL, skipped_unknown_location INTEGER NOT NULL,",
+      "  skipped_unknown_type INTEGER NOT NULL, last_modified TEXT",
+      ") WITHOUT ROWID;",
+    ].join("\n"),
+  );
+  return database;
+}
+
+function setMeta(database, key, value) {
+  database
+    .prepare("INSERT OR REPLACE INTO meta (key, value) VALUES (?, ?)")
+    .run(String(key), JSON.stringify(value));
+}
+
+function getMeta(database, key, fallback = null) {
+  const row = database.prepare("SELECT value FROM meta WHERE key = ?").get(String(key));
+  return row ? JSON.parse(row.value) : fallback;
+}
+
+function sleep(ms) {
+  return new Promise((resolve) => setTimeout(resolve, ms));
+}
+
+async function fetchJsonPage(url, outputPath, config) {
+  let lastError = null;
+  for (let attempt = 0; attempt <= config.maxRetries; attempt += 1) {
+    try {
+      const response = await fetch(url, {
+        headers: {
+          Accept: "application/json",
+          "User-Agent": config.userAgent,
+          "X-Compatibility-Date": config.compatibilityDate,
+        },
+        signal: AbortSignal.timeout(config.requestTimeoutMs),
+      });
+      if (response.status === 429) {
+        const retrySeconds = Math.max(1, Number(response.headers.get("retry-after")) || 5);
+        await sleep(retrySeconds * 1000);
+        continue;
+      }
+      if (response.status >= 500) {
+        throw new Error("ESI " + response.status + " for " + url);
+      }
+      if (!response.ok) {
+        throw new Error("ESI " + response.status + " for " + url);
+      }
+      const text = await response.text();
+      const data = JSON.parse(text);
+      fs.mkdirSync(path.dirname(outputPath), { recursive: true });
+      fs.writeFileSync(outputPath, text, "utf8");
+      const headers = {
+        etag: response.headers.get("etag"),
+        expires: response.headers.get("expires"),
+        lastModified: response.headers.get("last-modified"),
+        pages: Number(response.headers.get("x-pages")) || 1,
+        rateLimitRemaining: optionalHeaderNumber(
+          response.headers.get("x-ratelimit-remaining"),
+        ),
+        errorLimitRemaining: optionalHeaderNumber(
+          response.headers.get("x-esi-error-limit-remain"),
+        ),
+      };
+      writeJson(outputPath + ".meta.json", {
+        fetchedAt: new Date().toISOString(),
+        url,
+        headers,
+      });
+      if (
+        Number.isFinite(headers.rateLimitRemaining) &&
+        headers.rateLimitRemaining < 100
+      ) {
+        throw new Error("ESI market-order token bucket is nearly empty; stop and resume later.");
+      }
+      if (
+        Number.isFinite(headers.errorLimitRemaining) &&
+        headers.errorLimitRemaining < 10
+      ) {
+        throw new Error("ESI error limit is nearly exhausted; stop and inspect failures.");
+      }
+      return { data, headers };
+    } catch (error) {
+      lastError = error;
+      if (attempt >= config.maxRetries) break;
+      const waitMs = Math.min(30000, 750 * 2 ** attempt) + Math.floor(Math.random() * 250);
+      await sleep(waitMs);
+    }
+  }
+  throw lastError;
+}
+
+async function mapLimit(items, concurrency, worker) {
+  const results = new Array(items.length);
+  let next = 0;
+  async function run() {
+    while (true) {
+      const index = next;
+      next += 1;
+      if (index >= items.length) return;
+      results[index] = await worker(items[index], index);
+    }
+  }
+  await Promise.all(Array.from({ length: Math.min(concurrency, items.length) }, run));
+  return results;
+}
+
+function regionPageUrl(config, regionId, page) {
+  return (
+    config.esiBaseUrl.replace(/\/$/, "") +
+    "/markets/" +
+    regionId +
+    "/orders/?order_type=all&page=" +
+    page
+  );
+}
+
+function ingestRegionPages(
+  database,
+  pages,
+  regionId,
+  topology,
+  marketTypes,
+  lastModified,
+) {
+  const upsert = database.prepare(
+    [
+      "INSERT INTO aggregates",
+      "(station_id, type_id, bid, quantity, notional, best_price, order_count)",
+      "VALUES (?, ?, ?, ?, ?, ?, 1)",
+      "ON CONFLICT(station_id, type_id, bid) DO UPDATE SET",
+      " quantity = quantity + excluded.quantity,",
+      " notional = notional + excluded.notional,",
+      " best_price = CASE WHEN excluded.bid = 1",
+      "   THEN MAX(best_price, excluded.best_price)",
+      "   ELSE MIN(best_price, excluded.best_price) END,",
+      " order_count = order_count + 1",
+    ].join("\n"),
+  );
+  const unknown = database.prepare(
+    [
+      "INSERT INTO unknown_locations (location_id, region_id, order_count)",
+      "VALUES (?, ?, 1)",
+      "ON CONFLICT(location_id, region_id) DO UPDATE SET",
+      " order_count = order_count + 1",
+    ].join("\n"),
+  );
+  const stats = {
+    raw: 0,
+    accepted: 0,
+    unknownLocation: 0,
+    unknownType: 0,
+  };
+  const transaction = database.transaction(() => {
+    for (const page of pages) {
+      for (const order of page) {
+        stats.raw += 1;
+        const stationId = Number(order.location_id);
+        const typeId = Number(order.type_id);
+        const station = topology.stationById.get(stationId);
+        if (!station) {
+          stats.unknownLocation += 1;
+          unknown.run(stationId, regionId);
+          continue;
+        }
+        if (!marketTypes.has(typeId)) {
+          stats.unknownType += 1;
+          continue;
+        }
+        const quantity = Math.max(0, Math.trunc(Number(order.volume_remain) || 0));
+        const price = positiveNumber(order.price);
+        if (quantity <= 0 || !price) continue;
+        upsert.run(
+          stationId,
+          typeId,
+          order.is_buy_order ? 1 : 0,
+          quantity,
+          price * quantity,
+          price,
+        );
+        stats.accepted += 1;
+      }
+    }
+    database
+      .prepare(
+        [
+          "INSERT OR REPLACE INTO region_stats",
+          "(region_id, pages, raw_orders, accepted_orders, skipped_unknown_location,",
+          " skipped_unknown_type, last_modified) VALUES (?, ?, ?, ?, ?, ?, ?)",
+        ].join("\n"),
+      )
+      .run(
+        regionId,
+        pages.length,
+        stats.raw,
+        stats.accepted,
+        stats.unknownLocation,
+        stats.unknownType,
+        lastModified,
+      );
+  });
+  transaction();
+  return stats;
+}
+
+async function fetchRegion(
+  database,
+  regionId,
+  rawRoot,
+  config,
+  topology,
+  marketTypes,
+) {
+  const regionDir = path.join(rawRoot, "regions", String(regionId));
+  let first = await fetchJsonPage(
+    regionPageUrl(config, regionId, 1),
+    path.join(regionDir, "page-1.json"),
+    config,
+  );
+  const expiry = Date.parse(first.headers.expires || "");
+  if (
+    first.headers.pages > 1 &&
+    Number.isFinite(expiry) &&
+    expiry - Date.now() < config.coherenceGuardSeconds * 1000
+  ) {
+    await sleep(Math.max(1000, expiry - Date.now() + 1500));
+    first = await fetchJsonPage(
+      regionPageUrl(config, regionId, 1),
+      path.join(regionDir, "page-1.json"),
+      config,
+    );
+  }
+  const pageNumbers = Array.from(
+    { length: Math.max(0, first.headers.pages - 1) },
+    (_, index) => index + 2,
+  );
+  const rest = await mapLimit(pageNumbers, config.concurrency, async (page) => {
+    return fetchJsonPage(
+      regionPageUrl(config, regionId, page),
+      path.join(regionDir, "page-" + page + ".json"),
+      config,
+    );
+  });
+  const expectedLastModified = first.headers.lastModified;
+  for (const result of rest) {
+    if (
+      expectedLastModified &&
+      result.headers.lastModified &&
+      result.headers.lastModified !== expectedLastModified
+    ) {
+      throw new Error(
+        "Region " + regionId + " changed while pages were downloading; rerun the snapshot.",
+      );
+    }
+  }
+  const pages = [first.data, ...rest.map((result) => result.data)];
+  return ingestRegionPages(
+    database,
+    pages,
+    regionId,
+    topology,
+    marketTypes,
+    expectedLastModified,
+  );
+}
