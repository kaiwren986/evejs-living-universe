+      toFiniteNumber(economyState.metrics.industryBlueprintCopiesCreated, 0) + 1;
+    economyState.metrics.industryBlueprintCopyRunsCreated =
+      toFiniteNumber(economyState.metrics.industryBlueprintCopyRunsCreated, 0) +
