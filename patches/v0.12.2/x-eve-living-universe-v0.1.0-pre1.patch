+  assert.equal(seeded.success, true, seeded.errorMsg);
+
+  for (let index = 0; index < mockEntities.length; index += 1) {
+    const result = prologueRuntime.handleCombatEntityDestroyed(
+      { systemID: 31000355 },
+      mockEntities[index],
+      { nowMs: 1_800_000_001_000 + index },
