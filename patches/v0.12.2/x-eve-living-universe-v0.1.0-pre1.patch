+function portOpen(port) {
+  return new Promise((resolve) => {
+    const socket = net.createConnection({ host: "127.0.0.1", port });
+    const finish = (value) => {
+      socket.destroy();
+      resolve(value);
+    };
+    socket.setTimeout(750);
+    socket.once("connect", () => finish(true));
+    socket.once("timeout", () => finish(false));
+    socket.once("error", () => finish(false));
+  });
+}
+
+async function assertServicesStopped() {
+  const ports = [26000, 26002, 40110, 40111];
+  const states = await Promise.all(ports.map(async (port) => [port, await portOpen(port)]));
+  const open = states.filter((entry) => entry[1]).map((entry) => entry[0]);
+  if (open.length > 0) {
+    throw new Error(
+      "Stop the EveJS game and market servers before applying. Open ports: " + open.join(", "),
+    );
+  }
+}
+
+function copyDatabaseFamily(databasePath, backupDir) {
+  fs.mkdirSync(backupDir, { recursive: true });
+  const copied = [];
+  for (const suffix of ["", "-wal", "-shm"]) {
+    const source = databasePath + suffix;
+    if (fs.existsSync(source)) {
+      const destination = path.join(backupDir, path.basename(databasePath) + suffix);
+      fs.copyFileSync(source, destination);
+      copied.push(destination);
+    }
+  }
+  return copied;
+}
