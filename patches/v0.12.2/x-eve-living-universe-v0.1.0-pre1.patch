+async function fetchRegionIds(rawRoot, config) {
+  const result = await fetchJsonPage(
+    config.esiBaseUrl.replace(/\/$/, "") + "/universe/regions/",
+    path.join(rawRoot, "regions.json"),
+    config,
+  );
+  return result.data.map(Number).filter((value) => Number.isInteger(value) && value > 0);
+}
+
+function buildPlan(database, topology, marketTypes, config) {
+  const insert = database.prepare(
+    [
+      "INSERT INTO plan_rows",
+      "(station_id, solar_system_id, constellation_id, region_id, type_id, bid, price, quantity)",
+      "VALUES (?, ?, ?, ?, ?, ?, ?, ?)",
+    ].join("\n"),
+  );
+  const rows = database.prepare(
+    [
+      "SELECT a.station_id, a.type_id, a.bid, a.quantity, a.notional,",
+      " a.best_price, a.order_count, r.adjusted_price, r.average_price",
+      "FROM aggregates a LEFT JOIN reference_prices r ON r.type_id = a.type_id",
+      "ORDER BY a.station_id, a.type_id, a.bid",
+    ].join("\n"),
+  ).all();
+  let index = 0;
+  let crosses = 0;
+  const anchorSources = {};
+  const transaction = database.transaction(() => {
+    while (index < rows.length) {
+      const first = rows[index];
+      const entries = [first];
+      index += 1;
+      while (
+        index < rows.length &&
+        rows[index].station_id === first.station_id &&
+        rows[index].type_id === first.type_id
+      ) {
+        entries.push(rows[index]);
+        index += 1;
+      }
+      const station = topology.stationById.get(Number(first.station_id));
+      const type = marketTypes.get(Number(first.type_id));
+      if (!station || !type) continue;
+      const beforeCross =
+        entries.length === 2 &&
+        sideLivePrice(entries.find((entry) => Number(entry.bid) === 1), config.pricePolicy.liveStatistic) >=
+          sideLivePrice(entries.find((entry) => Number(entry.bid) === 0), config.pricePolicy.liveStatistic);
+      const calculated = calculatePairPrices(
+        entries,
+        type,
+        {
+          adjustedPrice: first.adjusted_price,
+          averagePrice: first.average_price,
+        },
+        config.pricePolicy,
+      );
+      if (beforeCross) crosses += 1;
+      anchorSources[calculated.anchorSource || "none"] =
+        (anchorSources[calculated.anchorSource || "none"] || 0) + 1;
+      for (const entry of entries) {
+        const quantity = Math.max(
+          1,
+          Math.min(
+            Number(config.maximumQuantity),
+            Math.round(Number(entry.quantity) * Number(config.quantityScale || 1)),
+          ),
+        );
+        insert.run(
+          station.stationId,
+          station.solarSystemId,
+          station.constellationId,
+          station.regionId,
+          Number(entry.type_id),
+          Number(entry.bid),
+          calculated.prices.get(Number(entry.bid)),
+          quantity,
+        );
+      }
+    }
+  });
+  transaction();
+  return {
+    rows: Number(database.prepare("SELECT COUNT(*) count FROM plan_rows").get().count),
+    sellRows: Number(
+      database.prepare("SELECT COUNT(*) count FROM plan_rows WHERE bid = 0").get().count,
+    ),
+    buyRows: Number(
+      database.prepare("SELECT COUNT(*) count FROM plan_rows WHERE bid = 1").get().count,
+    ),
+    stations: Number(
+      database.prepare("SELECT COUNT(DISTINCT station_id) count FROM plan_rows").get().count,
+    ),
+    systems: Number(
+      database.prepare("SELECT COUNT(DISTINCT solar_system_id) count FROM plan_rows").get().count,
+    ),
+    regions: Number(
+      database.prepare("SELECT COUNT(DISTINCT region_id) count FROM plan_rows").get().count,
+    ),
+    normalizedLiveCrosses: crosses,
+    anchorSources,
+  };
+}
