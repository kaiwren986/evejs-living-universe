+"use strict";
+
+const assert = require("node:assert/strict");
+const test = require("node:test");
+const {
+  DEFAULT_CONFIG,
+  calculatePairPrices,
+  mergeDeep,
+  optionalHeaderNumber,
+  parseArgs,
+  roundPrice,
+  selectAnchor,
+} = require("./market-universe-mirror");
+
+function entry(bid, quantity, weightedPrice, bestPrice = weightedPrice) {
+  return {
+    bid,
+    quantity,
+    notional: quantity * weightedPrice,
+    bestPrice,
+  };
+}
+
+test("argument parser collects repeated region filters", () => {
+  const args = parseArgs([
+    "snapshot",
+    "--server-root",
+    "D:/EveJS",
+    "--region",
+    "10000002",
+    "--region",
+    "10000043",
+  ]);
+  assert.equal(args.command, "snapshot");
+  assert.deepEqual(args.regions, [10000002, 10000043]);
+});
+
+test("deep configuration merge preserves nested defaults", () => {
+  const merged = mergeDeep(DEFAULT_CONFIG, {
+    pricePolicy: { mode: "static_base" },
+  });
+  assert.equal(merged.pricePolicy.mode, "static_base");
+  assert.equal(
+    merged.pricePolicy.maximumAnchorMultiplier,
+    DEFAULT_CONFIG.pricePolicy.maximumAnchorMultiplier,
+  );
+});
+
+test("missing optional rate-limit headers remain unknown instead of becoming zero", () => {
+  assert.equal(optionalHeaderNumber(null), null);
+  assert.equal(optionalHeaderNumber(""), null);
+  assert.equal(optionalHeaderNumber("11998"), 11998);
+});
+
+test("anchor priority uses average, adjusted, then static base", () => {
+  const selected = selectAnchor(
+    { basePrice: 100 },
+    { averagePrice: 125, adjustedPrice: 110 },
+    DEFAULT_CONFIG.pricePolicy,
+  );
+  assert.deepEqual(selected, { value: 125, source: "average" });
+});
+
+test("clamped live prices preserve sane regional differences", () => {
+  const calculated = calculatePairPrices(
+    [entry(0, 100, 1000), entry(1, 100, 1)],
+    { basePrice: 100 },
+    { averagePrice: 100, adjustedPrice: 95 },
+    DEFAULT_CONFIG.pricePolicy,
+  );
+  assert.equal(calculated.prices.get(0), 200);
+  assert.equal(calculated.prices.get(1), 50);
+});
+
+test("clamped live prices fall back to live when no anchor exists", () => {
+  const calculated = calculatePairPrices(
+    [entry(0, 10, 321.5)],
+    { basePrice: null },
+    { averagePrice: null, adjustedPrice: null },
+    DEFAULT_CONFIG.pricePolicy,
+  );
+  assert.equal(calculated.prices.get(0), 321.5);
+});
+
+test("static base policy creates a spread around the base price", () => {
+  const policy = {
+    ...DEFAULT_CONFIG.pricePolicy,
+    mode: "static_base",
+    referenceSpreadPercent: 10,
+  };
+  const calculated = calculatePairPrices(
+    [entry(0, 5, 1000), entry(1, 5, 900)],
+    { basePrice: 200 },
+    { averagePrice: 800, adjustedPrice: 750 },
+    policy,
+  );
+  assert.equal(calculated.prices.get(0), 210);
+  assert.equal(calculated.prices.get(1), 190);
+});
+
+test("crossed books are normalized to buy below sell", () => {
+  const calculated = calculatePairPrices(
+    [entry(0, 5, 90), entry(1, 5, 110)],
+    { basePrice: 100 },
+    { averagePrice: 100, adjustedPrice: 100 },
+    { ...DEFAULT_CONFIG.pricePolicy, mode: "live" },
+  );
+  assert.ok(calculated.prices.get(1) < calculated.prices.get(0));
+});
+
+test("price rounding follows compact client-friendly ticks", () => {
+  assert.equal(roundPrice(1.234), 1.23);
+  assert.equal(roundPrice(123.45), 123.5);
+  assert.equal(roundPrice(1234.56), 1235);
+});
