@@ -0,0 +1,56 @@
+"use strict";
+
+const assert = require("assert");
+
+const runtimeState = require("../src/services/dungeon/dungeonRuntimeState");
+const dungeonRuntime = require("../src/services/dungeon/dungeonRuntime");
+
+const instance = {
+  instanceID: 7,
+  templateID: "fixture",
+  solarSystemID: 30000142,
+  siteKey: "fixture:site",
+  lifecycleState: "seeded",
+  siteFamily: "combat",
+  siteOrigin: "universe_dungeon",
+  runtimeFlags: {
+    universeSeeded: true,
+  },
+  metadata: {
+    spawnFamilyKey: "combat",
+    definitionHash: "same",
+  },
+};
+
+runtimeState.listInstanceSummariesBySystem = () => [instance];
+runtimeState.getInstanceSnapshot = () => instance;
+runtimeState.mutateState = () => {
+  throw new Error("unchanged reconciliation entered the full-state mutation path");
+};
+
+const result = dungeonRuntime.reconcileUniverseSeededInstances([
+  {
+    templateID: "fixture",
+    solarSystemID: 30000142,
+    siteKey: "fixture:site",
+    metadata: {
+      definitionHash: "same",
+    },
+  },
+], {
+  systemIDs: [30000142],
+  spawnFamilyFilter: ["combat"],
+});
+
+assert.deepStrictEqual(result, {
+  desiredCount: 1,
+  createdCount: 0,
+  retainedCount: 1,
+  replacedCount: 0,
+  removedCount: 0,
+});
+
+console.log(JSON.stringify({
+  ok: true,
+  result,
+}, null, 2));
diff --git a/server/scripts/verifyFamilyEstate.js b/server/scripts/verifyFamilyEstate.js
