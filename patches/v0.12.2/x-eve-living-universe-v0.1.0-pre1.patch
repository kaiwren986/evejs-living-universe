+const REGION_SUMMARY_SQL = [
+  "WITH sells AS (",
+  " SELECT type_id, price, quantity AS quantity_value, station_id",
+  " FROM seed_stock WHERE region_id = ? AND quantity > 0",
+  " UNION ALL",
+  " SELECT type_id, price, vol_remaining, station_id FROM market_orders",
+  " WHERE region_id = ? AND state = 'open' AND bid = 0 AND vol_remaining > 0",
+  "), buys AS (",
+  " SELECT type_id, price, quantity AS quantity_value, station_id",
+  " FROM seed_buy_orders WHERE region_id = ? AND quantity > 0",
+  " UNION ALL",
+  " SELECT type_id, price, vol_remaining, station_id FROM market_orders",
+  " WHERE region_id = ? AND state = 'open' AND bid = 1 AND source = 'player'",
+  " AND vol_remaining > 0",
+  "), sell_totals AS (",
+  " SELECT type_id, MIN(price) best_price, SUM(quantity_value) total_quantity",
+  " FROM sells GROUP BY type_id",
+  "), buy_totals AS (",
+  " SELECT type_id, MAX(price) best_price, SUM(quantity_value) total_quantity",
+  " FROM buys GROUP BY type_id",
+  "), type_ids AS (",
+  " SELECT type_id FROM sell_totals UNION SELECT type_id FROM buy_totals",
+  ") INSERT INTO region_summaries (",
+  " region_id, type_id, best_ask_price, total_ask_quantity, best_ask_station_id,",
+  " best_bid_price, total_bid_quantity, best_bid_station_id, updated_at",
+  ") SELECT ?, type_ids.type_id, sell_totals.best_price,",
+  " COALESCE(sell_totals.total_quantity, 0),",
+  " (SELECT MIN(station_id) FROM sells WHERE sells.type_id = type_ids.type_id",
+  "  AND sells.price = sell_totals.best_price),",
+  " buy_totals.best_price, COALESCE(buy_totals.total_quantity, 0),",
+  " (SELECT MIN(station_id) FROM buys WHERE buys.type_id = type_ids.type_id",
+  "  AND buys.price = buy_totals.best_price), ?",
+  " FROM type_ids",
+  " LEFT JOIN sell_totals ON sell_totals.type_id = type_ids.type_id",
+  " LEFT JOIN buy_totals ON buy_totals.type_id = type_ids.type_id",
+].join("\n");
+
+const SYSTEM_SUMMARY_SQL = [
+  "WITH sells AS (",
+  " SELECT type_id, price, quantity AS quantity_value, station_id",
+  " FROM seed_stock WHERE solar_system_id = ? AND quantity > 0",
+  "), buys AS (",
+  " SELECT type_id, price, quantity AS quantity_value, station_id",
+  " FROM seed_buy_orders WHERE solar_system_id = ? AND quantity > 0",
+  "), sell_totals AS (",
+  " SELECT type_id, MIN(price) best_price, SUM(quantity_value) total_quantity",
+  " FROM sells GROUP BY type_id",
+  "), buy_totals AS (",
+  " SELECT type_id, MAX(price) best_price, SUM(quantity_value) total_quantity",
+  " FROM buys GROUP BY type_id",
+  "), type_ids AS (",
+  " SELECT type_id FROM sell_totals UNION SELECT type_id FROM buy_totals",
+  ") INSERT INTO system_seed_summaries (",
+  " solar_system_id, type_id, best_ask_price, total_ask_quantity, best_ask_station_id,",
+  " best_bid_price, total_bid_quantity, best_bid_station_id, updated_at",
+  ") SELECT ?, type_ids.type_id, sell_totals.best_price,",
+  " COALESCE(sell_totals.total_quantity, 0),",
+  " (SELECT MIN(station_id) FROM sells WHERE sells.type_id = type_ids.type_id",
+  "  AND sells.price = sell_totals.best_price),",
+  " buy_totals.best_price, COALESCE(buy_totals.total_quantity, 0),",
+  " (SELECT MIN(station_id) FROM buys WHERE buys.type_id = type_ids.type_id",
+  "  AND buys.price = buy_totals.best_price), ?",
+  " FROM type_ids",
+  " LEFT JOIN sell_totals ON sell_totals.type_id = type_ids.type_id",
+  " LEFT JOIN buy_totals ON buy_totals.type_id = type_ids.type_id",
+].join("\n");
