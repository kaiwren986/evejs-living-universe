+  getProductDemandFactor,
+  getProductProductionFactor,
+  getProductRaceID,
+  getTargetQuantity,
+  getProducerCeiling,
+  getInitialQuantity,
+  getStation,
+  getStationForSystem,
+  isMineralGood,
+  isProcurementGood,
+  getGood,
+  getRoute,
+};
