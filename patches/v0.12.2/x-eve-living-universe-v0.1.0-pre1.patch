+    flight.freightJobID = job.jobID;
+    const result = await adjustStock({
+      adjustmentID: `${job.jobID}:reserve`,
+      station,
+      good,
+      deltaQuantity: -toPositiveInt(job.quantity, 0),
+      reason: `living freight reservation recovery ${job.jobID}`,
+      stockMap,
+      workBudget,
+    });
