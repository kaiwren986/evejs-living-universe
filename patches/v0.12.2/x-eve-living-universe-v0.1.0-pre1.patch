+"use strict";
+
+const assert = require("node:assert/strict");
+const path = require("node:path");
+
+const MarketProxyService = require(path.join(
+  __dirname,
+  "../src/services/market/marketProxyService",
+));
+const { marshalDecode, marshalEncode } = require(path.join(
+  __dirname,
+  "../src/network/tcp/utils/marshal",
+));
+
+const { buildOrderRowset } = MarketProxyService.__testHooks;
+
+function normalizeColumnNames(columns) {
+  return columns.map(([name, type]) => [
+    Buffer.isBuffer(name) ? name.toString("utf8") : name,
+    type,
+  ]);
+}
+
+const expectedColumns = [
+  ["price", 6],
+  ["volRemaining", 5],
+  ["typeID", 3],
+  ["range", 2],
+  ["orderID", 20],
+  ["volEntered", 3],
+  ["minVolume", 3],
+  ["bid", 11],
+  ["issueDate", 64],
+  ["duration", 2],
+  ["stationID", 20],
+  ["regionID", 3],
+  ["solarSystemID", 3],
+  ["jumps", 3],
+];
+
+const rowList = buildOrderRowset(
+  [
+    {
+      price: 20.6,
+      vol_remaining: 2147483647,
+      type_id: 1228,
+      range_value: 32767,
+      order_id: "4257714186837034188",
+      vol_entered: 2147483647,
+      min_volume: 1,
+      bid: true,
+      issued_at: "2026-07-16T19:58:30.547Z",
+      duration_days: 100,
+      station_id: 60003760,
+      region_id: 10000002,
+      solar_system_id: 30000142,
+    },
+    {
+      price: 3.79,
+      vol_remaining: 10350368127,
+      type_id: 34,
+      range_value: 0,
+      order_id: "2257714186837032994",
+      vol_entered: 10350368127,
+      min_volume: 1,
+      bid: false,
+      issued_at: "2026-07-16T19:56:33.269Z",
+      duration_days: 100,
+      station_id: 60003760,
+      region_id: 10000002,
+      solar_system_id: 30000142,
+    },
+  ],
+  {
+    currentStationID: 60003760,
+    currentSolarSystemID: 30000142,
+  },
+);
+
+assert.equal(rowList.type, "objectex2");
+assert.equal(
+  rowList.header[0][0].value,
+  "eve.common.script.sys.rowset.RowList",
+);
+assert.deepEqual(rowList.list[0].columns, expectedColumns);
+assert.equal(rowList.list[0].fields.price, 206000n);
+assert.equal(rowList.list[0].fields.bid, true);
+assert.equal(rowList.list[0].fields.volRemaining, 2147483647);
+assert.equal(rowList.list[0].fields.range, 32767);
+assert.equal(rowList.list[1].fields.price, 37900n);
+assert.equal(rowList.list[1].fields.bid, false);
+assert.equal(rowList.list[1].fields.volRemaining, 2147483647);
+assert.equal(rowList.list[1].fields.volEntered, 2147483647);
+
+const decoded = marshalDecode(marshalEncode(rowList));
+assert.equal(decoded.type, "objectex2");
+assert.deepEqual(normalizeColumnNames(decoded.list[0].columns), expectedColumns);
+assert.equal(decoded.list[0].fields.price, 206000);
+assert.equal(decoded.list[0].fields.bid, true);
+assert.equal(decoded.list[0].fields.volRemaining, 2147483647);
+assert.equal(decoded.list[0].fields.orderID, 4257714186837034188n);
+assert.equal(decoded.list[0].fields.stationID, 60003760);
+assert.equal(decoded.list[1].fields.price, 37900);
+assert.equal(decoded.list[1].fields.bid, false);
+assert.equal(decoded.list[1].fields.volRemaining, 2147483647);
+assert.equal(decoded.list[1].fields.volEntered, 2147483647);
+assert.equal(decoded.list[1].fields.orderID, 2257714186837032994n);
+
+console.log(
