+  assert.equal(baseline.periodSeconds, 0);
+
+  economy.miningDeposits.deposit1 = {
+    status: "delivered",
+    deliveredAtMs: startedAtMs + 120_000,
+    oreUnits: 10_000,
+    oreVolumeM3: 1_000,
+    grossMarketValue: 500_000,
+    outputValuations: [
+      { typeID: 34, typeName: "Tritanium", quantity: 20_000, grossValue: 500_000 },
