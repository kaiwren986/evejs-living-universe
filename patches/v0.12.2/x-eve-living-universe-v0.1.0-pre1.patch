+function deterministic(seed, salt = 0) {
+  let value = (toPositiveInt(seed, 1) ^ Math.imul(toPositiveInt(salt, 1), 0x45d9f3b)) >>> 0;
+  value = Math.imul(value ^ (value >>> 16), 0x45d9f3b) >>> 0;
+  value = Math.imul(value ^ (value >>> 16), 0x45d9f3b) >>> 0;
