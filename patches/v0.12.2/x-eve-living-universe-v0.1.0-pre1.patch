--- /dev/null
+++ b/tools/market-universe-mirror/Update-UniverseMarket.ps1
@@ -0,0 +1,45 @@
+[CmdletBinding()]
+param(
+  [Parameter(Mandatory = $true)]
+  [ValidateSet("Snapshot", "Apply", "Doctor")]
+  [string]$Action,
+
+  [Parameter(Mandatory = $true)]
+  [string]$ServerRoot,
+
+  [string]$Snapshot,
+  [string]$Config,
+  [long[]]$Region
+)
+
+$ErrorActionPreference = "Stop"
+$node = "C:\Program Files\nodejs\node.exe"
+if (-not (Test-Path -LiteralPath $node -PathType Leaf)) {
+  $node = (Get-Command node -ErrorAction Stop).Source
+}
+
+$toolScript = Join-Path $PSScriptRoot "market-universe-mirror.js"
+$configPath = if ([string]::IsNullOrWhiteSpace($Config)) {
+  Join-Path $PSScriptRoot "config.local.json"
+} else {
+  $Config
+}
+$arguments = @($toolScript, $Action.ToLowerInvariant(), "--server-root", $ServerRoot)
+
+if ($Action -ne "Doctor") {
+  $arguments += @("--config", $configPath)
+}
+if ($Action -eq "Apply") {
+  if ([string]::IsNullOrWhiteSpace($Snapshot)) {
+    throw "-Snapshot is required in Apply mode."
+  }
+  $arguments += @("--snapshot", $Snapshot)
+}
+if ($Action -eq "Snapshot" -and $Region) {
+  foreach ($regionId in $Region) {
+    $arguments += @("--region", [string]$regionId)
+  }
+}
+
+& $node @arguments
+exit $LASTEXITCODE
