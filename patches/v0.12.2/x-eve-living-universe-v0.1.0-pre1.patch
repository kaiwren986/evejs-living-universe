+      id: settlementID,
+      atMs: throughMs,
+      kind: "commercial_settlement",
+      corporationID: context.claimState.ownerCorporationID,
+      grossISK,
+      expenseISK,
+      netISK,
+      note: `${dueIntervals}h | residents ${perHour.residents} | conduits ${perHour.permanentConnections + perHour.randomConnections}`,
+    });
