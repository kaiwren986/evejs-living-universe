+  const expenseISK = roundIsk(50_000 + (reprocessing ? 125_000 : 0));
+  return {
+    grossISK,
+    expenseISK,
+    netISK: roundIsk(grossISK - expenseISK),
+    residents,
+    permanentConnections,
+    randomConnections,
+  };
