+  return makeCombatDoctrine({
+    doctrineID: `regional_${empire.key}_${groupKey.toLowerCase()}_${slot}_v1`,
+    meta: empire,
+    empire,
+    role,
+    band,
+    shipTypeID,
+    shipClass,
+    support,
+    combatPower: power,
+  });
