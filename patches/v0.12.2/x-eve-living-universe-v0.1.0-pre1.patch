+function buildDefaultMeta(nowMs = Date.now()) {
+  const normalizedNowMs = normalizeNowMs(nowMs);
+  return {
+    schemaVersion: SCHEMA_VERSION,
+    createdAtMs: normalizedNowMs,
+    updatedAtMs: normalizedNowMs,
