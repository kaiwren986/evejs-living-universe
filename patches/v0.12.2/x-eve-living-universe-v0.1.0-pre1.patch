+);
diff --git a/server/scripts/verifyNpcDoctrineGovernance.js b/server/scripts/verifyNpcDoctrineGovernance.js
new file mode 100644
index 0000000000000000000000000000000000000000..bc54c9195cf0a44cf4b963e69f5406798a69be2c
--- /dev/null
+++ b/server/scripts/verifyNpcDoctrineGovernance.js
@@ -0,0 +1,204 @@
+"use strict";
+
+const assert = require("assert/strict");
+
+const npcData = require("../src/space/npc/npcData");
+const {
+  createDeterministicRng,
+  resolveCargoDestruction,
+  resolveFittedModuleDestruction,
+  resolveNativeNpcFittedModuleRecoveryPolicy,
+  validateDoctrine,
+  validateGovernedNpcDefinition,
+} = require("../src/space/npc/governance/npcDoctrineGovernance");
+const {
+  TRAFFIC_DOCTRINES,
+  TRAFFIC_LOOT_TABLES,
+} = require("../src/space/npc/governance/trafficDoctrineCatalog");
+const {
+  runSimulation,
+} = require("./simulateNpcDoctrineEconomy");
+
+for (const doctrine of TRAFFIC_DOCTRINES) {
+  const result = validateDoctrine(doctrine);
+  assert.equal(
+    result.success,
+    true,
+    `${doctrine.doctrineID} must validate: ${result.errorMsg || "unknown"} ${JSON.stringify(result.data || {})}`,
+  );
+}
+
+const civilianT2 = validateDoctrine({
+  doctrineID: "test_civilian_t2_rejected",
+  role: "hauler",
+  equipmentBand: "civilian",
+  shipTypeID: 648,
+  modules: [{ typeID: 2048, quantity: 1 }],
+});
+assert.equal(civilianT2.success, false);
+assert.equal(civilianT2.errorMsg, "NPC_DOCTRINE_T2_LIMIT_EXCEEDED");
+
+const standardFaction = validateDoctrine({
+  doctrineID: "test_standard_faction_rejected",
+  role: "escort",
+  equipmentBand: "standard",
+  shipTypeID: 603,
+  modules: [{ typeID: 13811, quantity: 1 }],
+});
+assert.equal(standardFaction.success, false);
+assert.equal(standardFaction.errorMsg, "NPC_DOCTRINE_SPECIAL_GRADE_FORBIDDEN");
+
+const deterministicLeft = resolveCargoDestruction(
+  [
+    { typeID: 34, quantity: 100 },
+    { typeID: 35, quantity: 100 },
+    { typeID: 36, quantity: 100 },
+    { typeID: 37, quantity: 100 },
+  ],
+  { survivalChance: 0.5, seed: "same-ship-same-wreck" },
+);
+const deterministicRight = resolveCargoDestruction(
+  [
+    { typeID: 34, quantity: 100 },
+    { typeID: 35, quantity: 100 },
+    { typeID: 36, quantity: 100 },
+    { typeID: 37, quantity: 100 },
+  ],
+  { survivalChance: 0.5, seed: "same-ship-same-wreck" },
+);
+assert.deepEqual(deterministicLeft, deterministicRight);
+assert.equal(
+  deterministicLeft.survivors.length + deterministicLeft.destroyed.length,
+  4,
+  "every cargo stack must survive or be destroyed exactly once",
+);
+
+const moduleRecovery = resolveFittedModuleDestruction(
+  [
+    { itemID: 1, typeID: 2046, itemName: "Damage Control I" },
+    { itemID: 2, typeID: 2048, itemName: "Damage Control II" },
+    { itemID: 3, typeID: 13811, itemName: "Dark Blood Small Focused Pulse Laser" },
+  ],
+  {
+    dropChances: {
+      techOne: 1,
+      techTwo: 0,
+      specialGrade: 0,
+    },
+    seed: "module-recovery-grade-test",
+  },
+);
+assert.deepEqual(moduleRecovery.dropped.map((item) => item.typeID), [2046]);
+assert.deepEqual(moduleRecovery.destroyed.map((item) => item.typeID), [2048, 13811]);
+
+const standardLegacyRecovery = resolveNativeNpcFittedModuleRecoveryPolicy({
+  profileID: "guristas_frigate",
+  entityType: "npc",
+});
+assert.equal(standardLegacyRecovery.policyID, "legacy_standard_npc");
+assert.deepEqual(standardLegacyRecovery.dropChances, {
+  techOne: 0.25,
+  techTwo: 0.05,
+  specialGrade: 0,
+});
+
+const industrialLegacyRecovery = resolveNativeNpcFittedModuleRecoveryPolicy({
+  profileID: "ore_mining_hulk",
+  loadoutID: "ore_mining_hulk_loadout",
+  entityType: "npc",
+});
+assert.equal(industrialLegacyRecovery.policyID, "legacy_industrial_conservative");
+assert.deepEqual(industrialLegacyRecovery.dropChances, {
+  techOne: 0.2,
+  techTwo: 0.03,
+  specialGrade: 0,
+});
+
+for (const protectedRecord of [
+  { profileID: "concord_response", npcEntityType: "concord" },
+  { profileID: "capital_dark_blood_titan", capitalNpc: true },
+]) {
+  const protectedPolicy = resolveNativeNpcFittedModuleRecoveryPolicy(protectedRecord);
+  assert.deepEqual(protectedPolicy.dropChances, {
+    techOne: 0,
+    techTwo: 0,
+    specialGrade: 0,
+  });
+  assert.ok(protectedPolicy.protectedReason);
+}
+
+const protectedTypeRecovery = resolveFittedModuleDestruction(
+  [
+    { itemID: 4, typeID: 16128, itemName: "CONCORD Medium Pulse Laser" },
+    { itemID: 5, typeID: 24550, itemName: "'Judgment' Electromagnetic Doomsday" },
+  ],
+  {
+    dropChances: {
+      techOne: 1,
+      techTwo: 1,
+      specialGrade: 1,
+    },
+    seed: "protected-module-recovery-test",
+  },
+);
+assert.equal(protectedTypeRecovery.dropped.length, 0);
+assert.deepEqual(
+  protectedTypeRecovery.destroyed.map((item) => item.nonRecoverableReason),
+  ["protected_type", "protected_group"],
+);
+
+const rngA = createDeterministicRng("stable-seed");
+const rngB = createDeterministicRng("stable-seed");
+assert.deepEqual(
+  Array.from({ length: 10 }, () => rngA()),
+  Array.from({ length: 10 }, () => rngB()),
+  "loadout and destruction random streams must replay exactly",
+);
+
+for (const profileID of [
+  "ambient_caldari_state_hauler",
+  "ambient_caldari_convoy_escort",
+  "evermore_gate_customs_major",
+  "evermore_gate_customs_official",
+]) {
+  const definition = npcData.buildNpcDefinition(profileID);
+  assert.ok(definition, `${profileID} must resolve`);
+  assert.notEqual(
+    definition.profile.lootTableID,
+    "generic_random_any",
+    `${profileID} must not use unrestricted random loot`,
+  );
+  const validation = validateGovernedNpcDefinition(definition);
+  assert.equal(
+    validation.success,
+    true,
+    `${profileID} governance must validate: ${validation.errorMsg || "unknown"}`,
+  );
+  assert.equal(validation.data.governed, true, `${profileID} must opt into governance`);
+}
+
+for (const lootTable of TRAFFIC_LOOT_TABLES) {
+  assert.ok(
+    npcData.getNpcLootTable(lootTable.lootTableID),
+    `${lootTable.lootTableID} must be registered in NPC data`,
+  );
+}
+
+const simulation = runSimulation({
+  count: 10_000,
+  seed: "governance-verification-seed",
+});
+assert.equal(simulation.passed, true, JSON.stringify(simulation.safety || {}));
+assert.equal(simulation.fitting.civilianTechTwoViolations, 0);
+assert.equal(simulation.fitting.totalSpecialGradeModules, 0);
+assert.ok(simulation.fitting.droppedFittedModules > 0);
+assert.ok(simulation.fitting.droppedTechOneModules > 0);
+assert.ok(simulation.fitting.droppedTechTwoModules > 0);
+assert.equal(simulation.fitting.droppedSpecialGradeModules, 0);
+assert.equal(simulation.cargo.conservationFailures.length, 0);
+assert.equal(simulation.safety.governedProfileGenericLoot.length, 0);
+
+console.log(
+  `NPC doctrine governance verified: ${TRAFFIC_DOCTRINES.length} doctrines, ` +
+  `${TRAFFIC_LOOT_TABLES.length} safe loot tables, ${simulation.actorCount} deterministic destructions.`,
+);
diff --git a/server/scripts/verifyNpcPhysicalBudget.js b/server/scripts/verifyNpcPhysicalBudget.js
new file mode 100644
index 0000000000000000000000000000000000000000..ec48a10d9f32fad2da7d9e755f69d5305b5f55f2
--- /dev/null
+++ b/server/scripts/verifyNpcPhysicalBudget.js
@@ -0,0 +1,80 @@
+"use strict";
+
+const assert = require("assert");
+const path = require("path");
+
+const budget = require(path.join(__dirname, "../src/space/npc/npcPhysicalBudget"));
+
+function request(reservationID, ownerKind, ownerID, systemID, shipCount) {
+  return {
+    reservationID,
+    ownerKind,
+    ownerID,
+    systemID,
+    shipCount,
+  };
+}
+
+function run() {
+  budget._testing.resetForTests({
+    limits: {
+      global: 5,
+      perSystem: 3,
+    },
+  });
+
+  const first = request("living:a", "livingUniverse", "a", 30000142, 2);
+  assert.strictEqual(budget.canReserve(first), true);
+  assert.strictEqual(budget.reserve(first).reason, "RESERVED");
+  assert.strictEqual(budget.reserve(first).reason, "ALREADY_RESERVED");
+
+  const conflicting = { ...first, shipCount: 1 };
+  assert.strictEqual(budget.reserve(conflicting).reason, "RESERVATION_ID_CONFLICT");
+
+  const second = request("living:b", "livingUniverse", "b", 30000142, 1);
+  assert.strictEqual(budget.reserve(second).success, true);
+
+  const systemDenied = request("event:c", "liveEvent", "c", 30000142, 1);
+  assert.strictEqual(budget.canReserve(systemDenied), false);
+  assert.strictEqual(budget.reserve(systemDenied).reason, "SYSTEM_LIMIT");
+
+  const otherSystem = request("event:d", "liveEvent", "d", 30000144, 2);
+  assert.strictEqual(budget.reserve(otherSystem).success, true);
+
+  const globalDenied = request("event:e", "liveEvent", "e", 30000144, 1);
+  assert.strictEqual(budget.reserve(globalDenied).reason, "GLOBAL_LIMIT");
+
+  assert.strictEqual(budget.release("living:b"), true);
+  assert.strictEqual(budget.reserve(globalDenied).success, true);
+  assert.strictEqual(budget.releaseOwner("liveEvent"), 2);
+  assert.strictEqual(budget.release("missing"), false);
+
+  const status = budget.getStatus({ includeReservations: true });
+  assert.strictEqual(status.reservedShips, 2);
+  assert.strictEqual(status.reservationCount, 1);
+  assert.deepStrictEqual(status.reservedBySystem, { 30000142: 2 });
+  assert.deepStrictEqual(status.reservedByOwnerKind, { livingUniverse: 2 });
+  assert.strictEqual(status.metrics.reservationsGranted, 4);
+  assert.strictEqual(status.metrics.idempotentReservations, 1);
+  assert.strictEqual(status.metrics.deniedSystem, 1);
+  assert.strictEqual(status.metrics.deniedGlobal, 1);
+  assert.strictEqual(status.metrics.deniedConflict, 1);
+  assert.strictEqual(status.metrics.releases, 3);
+  assert.strictEqual(status.metrics.releaseMisses, 1);
+
+  budget._testing.resetForTests();
+  process.stdout.write(`${JSON.stringify({
+    success: true,
+    finalStatus: status,
+  }, null, 2)}\n`);
+}
+
+try {
+  run();
+} catch (error) {
+  budget._testing.resetForTests();
+  console.error(error);
+  process.exitCode = 1;
+}
+
+
diff --git a/server/scripts/verifyNpcTestBulkLoad.js b/server/scripts/verifyNpcTestBulkLoad.js
new file mode 100644
index 0000000000000000000000000000000000000000..29668cfaa89db447d9116811683028c44880ace1
--- /dev/null
+++ b/server/scripts/verifyNpcTestBulkLoad.js
@@ -0,0 +1,180 @@
+"use strict";
+
+process.env.EVEJS_DISABLE_NPC_COMBAT_DORMANCY = "1";
+process.env.EVEJS_DISABLE_NPC_ANCHOR_RELEVANCE = "1";
+
+const assert = require("assert/strict");
+const { performance } = require("perf_hooks");
+
+const spaceRuntime = require("../src/space/runtime");
+const npcService = require("../src/space/npc/npcService");
+const npcTestService = require("../src/space/npc/npcTestService");
+
+const SYSTEM_ID = 30000142;
+const TARGET_SHIP_ID = 3999999999999999;
+const LOAD_SHIP_COUNT = 500;
+const JOB_TIMEOUT_MS = 300_000;
+
+function waitForJob(startJob) {
+  return new Promise((resolve, reject) => {
+    const timeout = setTimeout(() => {
+      reject(new Error(`NPC test job did not complete within ${JOB_TIMEOUT_MS} ms`));
+    }, JOB_TIMEOUT_MS);
+    startJob({
+      resolve(value) {
+        clearTimeout(timeout);
+        resolve(value);
+      },
+      reject(error) {
+        clearTimeout(timeout);
+        reject(error);
+      },
+    });
+  });
+}
+
+async function runVerification() {
+  const scene = spaceRuntime.ensureScene(SYSTEM_ID);
+  assert.ok(scene, "Jita scene must load");
+  const shipEntity = {
+    kind: "ship",
+    itemID: TARGET_SHIP_ID,
+    systemID: SYSTEM_ID,
+    position: { x: 0, y: 0, z: 0 },
+    velocity: { x: 0, y: 0, z: 0 },
+    direction: { x: 0, y: 0, z: 1 },
+  };
+  const session = {
+    characterID: 0,
+    _space: {
+      systemID: SYSTEM_ID,
+      shipID: TARGET_SHIP_ID,
+    },
+  };
+  const sceneSessionKey = "npc-test-bulk-load-verifier";
+  scene.sessions.set(sceneSessionKey, session);
+
+  const memoryBefore = process.memoryUsage();
+  let maxEventLoopDelayMs = 0;
+  let lastMonitorAt = performance.now();
+  const monitor = setInterval(() => {
+    const now = performance.now();
+    maxEventLoopDelayMs = Math.max(maxEventLoopDelayMs, now - lastMonitorAt - 50);
+    lastMonitorAt = now;
+  }, 50);
+
+  const completedStatus = await waitForJob(({ resolve, reject }) => {
+    const startResult = npcTestService.__testing.startNpcTestSpawnJob({
+      systemID: SYSTEM_ID,
+      shipID: TARGET_SHIP_ID,
+      scene,
+      shipEntity,
+    }, {
+      mode: "player",
+      amount: LOAD_SHIP_COUNT,
+      batchSize: npcTestService.NPCTEST_BULK_BATCH_SIZE,
+      onProgress(status) {
+        if (
+          status.state === "spawning" &&
+          status.spawnedAmount > 0 &&
+          status.spawnedAmount % 100 === 0
+        ) {
+          console.log(
+            `[BulkLoad] spawn ${status.spawnedAmount}/${status.requestedAmount} ` +
+              `maxBatch=${status.maxBatchDurationMs}ms`,
+          );
+        }
+        if (
+          status.state === "activating" &&
+          status.activatedAmount > 0 &&
+          status.activatedAmount % 100 === 0
+        ) {
+          console.log(
+            `[BulkLoad] activate ${status.activatedAmount}/${status.requestedAmount}`,
+          );
+        }
+      },
+      onComplete: resolve,
+      onFailure(status) {
+        reject(new Error(`bulk spawn failed: ${status.errorMsg || "unknown"}`));
+      },
+    });
+    if (!startResult.success) {
+      reject(new Error(startResult.errorMsg || "bulk spawn did not start"));
+    }
+  });
+  clearInterval(monitor);
+
+  assert.equal(completedStatus.state, "completed");
+  assert.equal(completedStatus.spawnedAmount, LOAD_SHIP_COUNT);
+  assert.equal(completedStatus.activeAmount, LOAD_SHIP_COUNT);
+  assert.equal(
+    npcTestService.__testing.listNpcTestControllerIDs(
+      SYSTEM_ID,
+      npcTestService.NPCTEST_OPERATOR_KIND,
+    ).length,
+    LOAD_SHIP_COUNT,
+  );
+  const operatorSummary = npcService.getNpcOperatorSummary().filter(
+    (controller) => controller.systemID === SYSTEM_ID && controller.operatorKind === "npctest",
+  );
+  assert.equal(operatorSummary.length, LOAD_SHIP_COUNT);
+  assert.ok(operatorSummary.every((controller) => controller.transient === true));
+
+  const memoryAtFullLoad = process.memoryUsage();
+  const cleanupStatus = await waitForJob(({ resolve, reject }) => {
+    const clearResult = npcTestService.clearNpcTestForSession(session, {
+      mode: "player",
+      onProgress(status) {
+        if (status.clearedAmount > 0 && status.clearedAmount % 100 === 0) {
+          console.log(
+            `[BulkLoad] cleanup ${status.clearedAmount}/${status.cleanupTargetAmount}`,
+          );
+        }
+      },
+      onCancel: resolve,
+    });
+    if (!clearResult.success) {
+      reject(new Error(clearResult.errorMsg || "bulk cleanup did not start"));
+    }
+  });
+  assert.equal(cleanupStatus.state, "cancelled");
+  assert.equal(cleanupStatus.clearedAmount, LOAD_SHIP_COUNT);
+  assert.equal(
+    npcTestService.__testing.listNpcTestControllerIDs(
+      SYSTEM_ID,
+      npcTestService.NPCTEST_OPERATOR_KIND,
+    ).length,
+    0,
+  );
+  scene.sessions.delete(sceneSessionKey);
+
+  return {
+    success: true,
+    systemID: SYSTEM_ID,
+    requestedShips: LOAD_SHIP_COUNT,
+    spawn: completedStatus,
+    cleanup: cleanupStatus,
+    performance: {
+      maxEventLoopDelayMs: Number(Math.max(0, maxEventLoopDelayMs).toFixed(2)),
+      rssIncreaseAtFullLoadBytes: memoryAtFullLoad.rss - memoryBefore.rss,
+      heapUsedIncreaseAtFullLoadBytes: memoryAtFullLoad.heapUsed - memoryBefore.heapUsed,
+    },
+    remainingTestControllers: 0,
+  };
+}
+
+if (require.main === module) {
+  runVerification()
+    .then((result) => {
+      console.log(JSON.stringify(result, null, 2));
+    })
+    .catch((error) => {
+      console.error(error && error.stack ? error.stack : error);
+      process.exitCode = 1;
+    });
+}
+
+module.exports = {
+  runVerification,
+};
