+async function fetchReferencePrices(database, rawRoot, config) {
+  const result = await fetchJsonPage(
+    config.esiBaseUrl.replace(/\/$/, "") + "/markets/prices/",
+    path.join(rawRoot, "market-prices.json"),
+    config,
+  );
+  const insert = database.prepare(
+    "INSERT OR REPLACE INTO reference_prices (type_id, adjusted_price, average_price) VALUES (?, ?, ?)",
+  );
+  database.transaction(() => {
+    for (const row of result.data) {
+      insert.run(
+        Number(row.type_id),
+        positiveNumber(row.adjusted_price),
+        positiveNumber(row.average_price),
+      );
+    }
+  })();
+  return result.data.length;
+}
