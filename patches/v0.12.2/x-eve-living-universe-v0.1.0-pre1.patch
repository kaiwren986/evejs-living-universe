+  };
+  economy.jobs.job1 = {
+    status: "delivered",
+    typeID: 215,
+    typeName: "Iron Charge S",
+    quantity: 5_000,
+    reservedAtMs: startedAtMs + 90_000,
+    completedAtMs: startedAtMs + 420_000,
+    purchaseValue: 50_000,
+    saleValue: 65_000,
