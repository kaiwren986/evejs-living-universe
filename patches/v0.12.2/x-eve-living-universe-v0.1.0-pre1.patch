+    sourceQuantityBefore: toPositiveInt(sourceRow.quantity, 0),
+    createdAtMs: nowMs,
+    lastUpdatedAtMs: nowMs,
+    reservationAttempts: 0,
+    sourceReservationStatus: "pending",
+    deliveryAttempts: 0,
