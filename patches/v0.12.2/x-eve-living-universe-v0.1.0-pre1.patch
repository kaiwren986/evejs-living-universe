+async function snapshotCommand(args) {
+  const serverRoot = requireServerRoot(args);
+  const config = loadConfig(args.configPath);
+  const Database = loadDatabaseConstructor(serverRoot);
+  const marketDatabasePath = path.join(
+    serverRoot,
+    "externalservices",
+    "market-server",
+    "data",
+    "generated",
+    "market.sqlite",
+  );
+  const topology = loadTopology(serverRoot);
+  const marketTypes = loadMarketTypes(Database, marketDatabasePath);
+  const snapshotPath = path.resolve(
+    args.outputPath ||
+      path.join(
+        serverRoot,
+        "_local",
+        "market-universe-mirror",
+        "snapshots",
+        "universe-market-" + timestampForPath() + ".sqlite",
+      ),
+  );
+  const rawRoot = path.resolve(
+    args.cacheDir ||
+      path.join(
+        serverRoot,
+        "_local",
+        "market-universe-mirror",
+        "raw",
+        path.basename(snapshotPath, ".sqlite"),
+      ),
+  );
+  const database = createSnapshotDatabase(Database, snapshotPath);
+  try {
+    setMeta(database, "tool", { name: TOOL_NAME, version: TOOL_VERSION });
+    setMeta(database, "generated_at", new Date().toISOString());
+    setMeta(database, "compatibility_date", config.compatibilityDate);
+    setMeta(database, "price_policy", config.pricePolicy);
+    setMeta(database, "raw_cache", rawRoot);
+    const referenceCount = await fetchReferencePrices(database, rawRoot, config);
+    let regions =
+      args.regions.length > 0 ? args.regions : await fetchRegionIds(rawRoot, config);
+    regions = [...new Set(regions)].sort((a, b) => a - b);
+    setMeta(database, "regions_requested", regions);
+    console.log("Fetching " + regions.length + " ESI market regions...");
+    let ordinal = 0;
+    for (const regionId of regions) {
+      ordinal += 1;
+      const stats = await fetchRegion(
+        database,
+        regionId,
+        rawRoot,
+        config,
+        topology,
+        marketTypes,
+      );
+      console.log(
+        "[" +
+          ordinal +
+          "/" +
+          regions.length +
+          "] region " +
+          regionId +
+          ": " +
+          stats.accepted +
+          " NPC-station orders accepted from " +
+          stats.raw,
+      );
+    }
+    const plan = buildPlan(database, topology, marketTypes, config);
+    const totals = database.prepare(
+      [
+        "SELECT SUM(pages) pages, SUM(raw_orders) rawOrders,",
+        " SUM(accepted_orders) acceptedOrders,",
+        " SUM(skipped_unknown_location) unknownLocationOrders,",
+        " SUM(skipped_unknown_type) unknownTypeOrders",
+        "FROM region_stats",
+      ].join("\n"),
+    ).get();
+    const report = {
+      ok: true,
+      snapshotPath,
+      rawRoot,
+      generatedAt: getMeta(database, "generated_at"),
+      compatibilityDate: config.compatibilityDate,
+      referencePriceTypes: referenceCount,
+      regionsRequested: regions.length,
+      pages: Number(totals.pages || 0),
+      rawOrders: Number(totals.rawOrders || 0),
+      acceptedNpcStationOrders: Number(totals.acceptedOrders || 0),
+      skippedUnknownLocationOrders: Number(totals.unknownLocationOrders || 0),
+      skippedUnknownTypeOrders: Number(totals.unknownTypeOrders || 0),
+      plan,
+    };
+    setMeta(database, "report", report);
+    database.pragma("wal_checkpoint(TRUNCATE)");
+    console.log(JSON.stringify(report, null, 2));
+    return report;
+  } finally {
+    database.close();
+  }
+}
