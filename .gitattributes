* text=auto

# Keep the canonical patch and its integrity metadata byte-stable on Windows.
*.patch text eol=lf
*.json text eol=lf
SHA256SUMS text eol=lf

# Repository documentation and automation use stable source line endings.
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# These entry points are intended for Windows hosts.
*.ps1 text eol=crlf
*.bat text eol=crlf
