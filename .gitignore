# This repository intentionally publishes only the X-Eve delta and its public
# documentation/install tooling. Everything else is ignored by default.
/*

!/.gitignore
!/.gitattributes
!/README
!/README.md
!/README.txt
!/LICENSE
!/LICENSE.md
!/LICENSE.txt
!/CHANGELOG
!/CHANGELOG.md
!/CHANGELOG.txt

!/.github/
!/.github/**
!/docs/
!/docs/**
!/installer/
!/installer/**
!/patches/
!/patches/**
!/scripts/
!/scripts/**

# Never admit complete source trees, generated state, machine-local settings,
# deployment material, databases, logs, certificates, or credentials—even if
# they are accidentally placed inside an allowed public-package directory.
**/server/
**/externalservices/
**/docker/
**/tools/
**/deploy/
**/deployment/
**/remote/
**/PlayerConnect/
**/node_modules/
**/_local/
**/runtime/
**/runtime-data/
**/runtime_data/
**/database/
**/databases/
**/cert/
**/certs/
**/certificate/
**/certificates/
**/logs/
**/secrets/
**/private/

**/.env
**/.env.*
**/evejs.config.local.json
**/*config-local*
**/*config.local*
**/*.local.json

**/*.db
**/*.db3
**/*.sqlite
**/*.sqlite3
**/*.sqlite-wal
**/*.sqlite-shm
**/*.log

**/*.pem
**/*.key
**/*.pfx
**/*.p12
**/*.ppk
**/*.crt
**/*.cer
**/*.der
**/*.jks
**/*.keystore
**/id_rsa
**/id_dsa
**/id_ecdsa
**/id_ed25519
**/authorized_keys
